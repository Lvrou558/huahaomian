.page { padding: 16rpx 18rpx 56rpx; background: #f4fbf9; min-height: 100vh; }
.card { background:#fff; border-radius:18rpx; padding:20rpx; margin-bottom:14rpx; box-shadow:0 4rpx 14rpx rgba(37,114,93,0.06); }
.section-title { font-size:28rpx; font-weight:700; color:#1f443c; margin-bottom:10rpx; }

.overview-card { background: linear-gradient(145deg,#ecfaf5 0%,#fff 70%); }
.overview-head { display:flex; align-items:center; justify-content:space-between; }
.overview-title { font-size:30rpx; color:#1f8a6f; font-weight:700; }
.overview-summary { margin-top: 8rpx; font-size:24rpx; color:#4f7269; line-height:1.55; }

.risk-group-card { border:1rpx solid #e2eee9; border-radius:12rpx; margin-top:10rpx; overflow:hidden; }
.risk-group-head { display:flex; align-items:center; gap:10rpx; padding:12rpx; background:#fbfefd; }
.risk-level-tag { font-size:20rpx; color:#fff; border-radius:999rpx; padding:4rpx 12rpx; flex-shrink:0; }
.risk-group-card.level-mild .risk-level-tag { background:#4caf50; }
.risk-group-card.level-moderate .risk-level-tag { background:#ff9800; }
.risk-group-card.level-severe .risk-level-tag { background:#ef5350; }
.risk-head-text { flex:1; font-size:22rpx; color:#466a61; line-height:1.45; }
.risk-toggle { font-size:20rpx; color:#1f8a6f; }

.risk-group-body { padding:10rpx 12rpx 12rpx; border-top:1rpx solid #edf5f2; }
.risk-factor-line { display:flex; flex-wrap:wrap; gap:8rpx; }
.risk-factor-chip { font-size:19rpx; color:#5d7f76; background:#f0f7f4; border-radius:999rpx; padding:4rpx 10rpx; }
.risk-evidence-link { margin-top:10rpx; font-size:21rpx; color:#1f8a6f; }

.action-item { margin-top:10rpx; display:flex; align-items:flex-start; gap:10rpx; }
.action-checkbox {
  width:32rpx;
  height:32rpx;
  line-height:32rpx;
  border:2rpx solid #c8ddd7;
  border-radius:8rpx;
  text-align:center;
  font-size:21rpx;
  color:#fff;
  flex-shrink:0;
  margin-top:2rpx;
}
.action-checkbox.checked { background:#1f8a6f; border-color:#1f8a6f; }
.action-text { font-size:23rpx; color:#3f645b; line-height:1.55; }
.action-text.done { color:#89a39d; text-decoration: line-through; }

.upgrade-tip {
  margin-top: 4rpx;
  padding: 8rpx 6rpx;
  text-align:center;
  color:#7e9790;
  font-size:20rpx;
}

.heart-health-card { padding-bottom: 22rpx; }
.heart-block-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #1f443c;
  line-height: 1.4;
}
.heart-block-title-spaced { margin-top: 22rpx; }
.heart-block-sub {
  margin-top: 10rpx;
  font-size: 22rpx;
  color: #577970;
  line-height: 1.55;
}
.heart-risk-item {
  margin-top: 14rpx;
  font-size: 23rpx;
  color: #3f645b;
  line-height: 1.58;
}
.heart-risk-num { font-weight: 700; color: #1f443c; }
.heart-risk-strong { font-weight: 700; color: #1f443c; }
.heart-risk-text { color: #4f7269; }

.heart-advice-block { margin-top: 14rpx; }
.heart-advice-heading {
  font-size: 23rpx;
  font-weight: 700;
  color: #1f443c;
  line-height: 1.45;
}
.heart-advice-line {
  margin-top: 8rpx;
  padding-left: 8rpx;
  display: flex;
  align-items: flex-start;
  gap: 4rpx;
}
.heart-advice-dash {
  flex-shrink: 0;
  font-size: 22rpx;
  color: #5d7f76;
  line-height: 1.55;
}
.heart-advice-text {
  flex: 1;
  font-size: 22rpx;
  color: #4f7269;
  line-height: 1.58;
}
.heart-evidence-link {
  margin-top: 16rpx;
  font-size: 21rpx;
  color: #1f8a6f;
}