          <text class="caret">⌄</text>
        </view>
      </view>

      <view class="alert-check-list">
        <view class="alert-check-row" bindtap="toggleNotify" data-field="bedWechat">
          <view class="alert-check-box {{alertConfig.bedWechat ? 'checked' : ''}}">
            <text wx:if="{{alertConfig.bedWechat}}">✓</text>
          </view>
          <text class="alert-check-text">微信消息通知</text>
        </view>
        <view class="alert-check-row" bindtap="toggleNotify" data-field="bedCall">
          <view class="alert-check-box {{alertConfig.bedCall ? 'checked' : ''}}">
            <text wx:if="{{alertConfig.bedCall}}">✓</text>
          </view>
          <text class="alert-check-text">电话通知</text>
        </view>
        <view class="alert-check-row" bindtap="toggleNotify" data-field="bedSms">
          <view class="alert-check-box {{alertConfig.bedSms ? 'checked' : ''}}">
            <text wx:if="{{alertConfig.bedSms}}">✓</text>
          </view>
          <text class="alert-check-text">短信通知</text>
        </view>
      </view>
