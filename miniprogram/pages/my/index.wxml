        <view class="user-field"><text class="user-field-label">床垫厚度(cm)</text><text class="user-field-text">{{userInfo.mattressThickness}}cm</text></view>
        <view class="user-field"><text class="user-field-label">床垫宽度(cm)</text><text class="user-field-text">{{userInfo.mattressWidth}}cm</text></view>
      </view>
    </block>

    <!-- 编辑视图 -->
    <block wx:if="{{editingUser}}">
      <view class="user-card">
        <view class="user-card-title">基础信息</view>
