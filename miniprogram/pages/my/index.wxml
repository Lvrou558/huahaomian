          <input class="user-input" value="{{userEditDraft.chronic}}" bindinput="onDraftInput" data-field="chronic" placeholder="如无填写 --" />
        </view>
        <view class="user-edit-row">
          <text class="user-field-label">是否为失能老人</text>
          <view class="user-input chip" bindtap="openPicker" data-field="isDisabled" data-title="是否为失能老人">
            <text>{{userEditDraft.isDisabled}}</text><text class="caret">⌄</text>
