  <!-- 5. 预警设置                                      -->
  <!-- ============================================== -->
  <block wx:if="{{currentView === 'alert'}}">
    <!-- 紧急联系人 -->
    <view class="alert-emergency">
      <view class="alert-emergency-title">紧急联系人电话</view>
      <view class="alert-emergency-edit" bindtap="editEmergencyPhone">
        <text class="alert-emergency-icon">✎</text>
      </view>
      <input wx:if="{{alertConfig.emergencyPhone || true}}" class="alert-emergency-input"
             type="number" maxlength="11"
             value="{{alertConfig.emergencyPhone}}" bindinput="onEmergencyPhoneInput"
             placeholder="点击输入电话号码" />
    </view>

    <view class="alert-thin-divider"></view>

    <!-- 心率预警 -->
    <view class="alert-section">
      <view class="alert-section-head">
        <text class="alert-section-title">心率预警</text>
        <switch color="#3DB9F0" checked="{{alertConfig.hrEnabled}}" data-field="hrEnabled" bindchange="toggleAlert" />
      </view>

      <view class="alert-label">心率预警时间</view>
      <view class="alert-row">
        <view class="alert-chip" bindtap="openTimePicker" data-field="hrStart" data-title="心率预警开始">
          <text>当日{{alertConfig.hrStartHour}}:{{alertConfig.hrStartMin}}</text>
          <text class="caret">⌄</text>
        </view>
        <text class="alert-sep">至</text>
        <view class="alert-chip" bindtap="openTimePicker" data-field="hrEnd" data-title="心率预警结束">
          <text>次日{{alertConfig.hrEndHour}}:{{alertConfig.hrEndMin}}</text>
          <text class="caret">⌄</text>
        </view>
      </view>

      <view class="alert-label">心率预警阈值</view>
      <view class="alert-row">
        <view class="alert-chip" bindtap="openPicker" data-field="hrLow" data-title="心率低于（bpm）">
          <text>心率低于 {{alertConfig.hrLow}}</text>
          <text class="caret">⌄</text>
        </view>
        <text class="alert-sep">/</text>
        <view class="alert-chip" bindtap="openPicker" data-field="hrHigh" data-title="高于（bpm）">
          <text>高于 {{alertConfig.hrHigh}}</text>
          <text class="caret">⌄</text>
        </view>
      </view>

      <view class="alert-check-list">
        <view class="alert-check-row" bindtap="toggleNotify" data-field="hrWechat">
          <view class="alert-check-box {{alertConfig.hrWechat ? 'checked' : ''}}">
            <text wx:if="{{alertConfig.hrWechat}}">✓</text>
          </view>
          <text class="alert-check-text">微信消息通知</text>
        </view>
        <view class="alert-check-row" bindtap="toggleNotify" data-field="hrCall">
          <view class="alert-check-box {{alertConfig.hrCall ? 'checked' : ''}}">
            <text wx:if="{{alertConfig.hrCall}}">✓</text>
          </view>
          <text class="alert-check-text">电话通知</text>
        </view>
        <view class="alert-check-row" bindtap="toggleNotify" data-field="hrSms">
          <view class="alert-check-box {{alertConfig.hrSms ? 'checked' : ''}}">
            <text wx:if="{{alertConfig.hrSms}}">✓</text>
          </view>
          <text class="alert-check-text">短信通知</text>
        </view>
      </view>
    </view>

    <view class="alert-thin-divider"></view>

    <!-- 呼吸率预警 -->
    <view class="alert-section">
      <view class="alert-section-head">
        <text class="alert-section-title">呼吸率预警</text>
        <switch color="#3DB9F0" checked="{{alertConfig.brEnabled}}" data-field="brEnabled" bindchange="toggleAlert" />
      </view>

      <view class="alert-label">呼吸率预警时间</view>
      <view class="alert-row">
        <view class="alert-chip" bindtap="openTimePicker" data-field="brStart" data-title="呼吸率预警开始">
          <text>当日{{alertConfig.brStartHour}}:{{alertConfig.brStartMin}}</text>
          <text class="caret">⌄</text>
        </view>
        <text class="alert-sep">至</text>
        <view class="alert-chip" bindtap="openTimePicker" data-field="brEnd" data-title="呼吸率预警结束">
          <text>次日{{alertConfig.brEndHour}}:{{alertConfig.brEndMin}}</text>
          <text class="caret">⌄</text>
        </view>
      </view>

      <view class="alert-label">呼吸率预警阈值</view>
      <view class="alert-row">
        <view class="alert-chip" bindtap="openPicker" data-field="brLow" data-title="呼吸率低于（次/分）">
          <text>呼吸率低于 {{alertConfig.brLow}}</text>
          <text class="caret">⌄</text>
        </view>
        <text class="alert-sep">/</text>
        <view class="alert-chip" bindtap="openPicker" data-field="brHigh" data-title="高于（次/分）">
          <text>高于 {{alertConfig.brHigh}}</text>
          <text class="caret">⌄</text>
        </view>
      </view>

      <view class="alert-check-list">
        <view class="alert-check-row" bindtap="toggleNotify" data-field="brWechat">
          <view class="alert-check-box {{alertConfig.brWechat ? 'checked' : ''}}">
            <text wx:if="{{alertConfig.brWechat}}">✓</text>
          </view>
          <text class="alert-check-text">微信消息通知</text>
        </view>
        <view class="alert-check-row" bindtap="toggleNotify" data-field="brCall">
          <view class="alert-check-box {{alertConfig.brCall ? 'checked' : ''}}">
            <text wx:if="{{alertConfig.brCall}}">✓</text>
          </view>
          <text class="alert-check-text">电话通知</text>
        </view>
        <view class="alert-check-row" bindtap="toggleNotify" data-field="brSms">
          <view class="alert-check-box {{alertConfig.brSms ? 'checked' : ''}}">
            <text wx:if="{{alertConfig.brSms}}">✓</text>
          </view>
          <text class="alert-check-text">短信通知</text>
        </view>
      </view>
    </view>

    <view class="alert-thin-divider"></view>

    <!-- 夜间离床未归预警 -->
    <view class="alert-section">
      <view class="alert-section-head">
        <text class="alert-section-title">夜间长时离床未归预警</text>
        <switch color="#3DB9F0" checked="{{alertConfig.bedEnabled}}" data-field="bedEnabled" bindchange="toggleAlert" />
      </view>

      <view class="alert-label">夜间长时离床未归预警时间</view>
      <view class="alert-row">
        <view class="alert-chip" bindtap="openTimePicker" data-field="bedStart" data-title="预警开始">
          <text>次日{{alertConfig.bedStartHour}}:{{alertConfig.bedStartMin}}</text>
          <text class="caret">⌄</text>
        </view>
        <text class="alert-sep">至</text>
        <view class="alert-chip" bindtap="openTimePicker" data-field="bedEnd" data-title="预警结束">
          <text>次日{{alertConfig.bedEndHour}}:{{alertConfig.bedEndMin}}</text>
          <text class="caret">⌄</text>
