        <text class="more-item-arrow">›</text>
      </view>
      <view class="more-item" bindtap="onMoreItemTap" data-key="reset">
        <text class="more-item-label">恢复出厂设置</text>
        <text class="more-item-arrow">›</text>
      </view>
      <view class="more-item" bindtap="onMoreItemTap" data-key="log">
        <text class="more-item-label">权限调用记录</text>
        <text class="more-item-arrow">›</text>
      </view>
      <view class="more-item" bindtap="onMoreItemTap" data-key="version">
        <text class="more-item-label">当前版本</text>
        <text class="more-item-extra">v1.2.0</text>
        <text class="more-item-arrow">›</text>
      </view>
      <view class="more-item" bindtap="onMoreItemTap" data-key="checkUpdate">
        <text class="more-item-label">检查小程序更新</text>
        <text class="more-item-arrow">›</text>
      </view>
      <view class="more-item" bindtap="onMoreItemTap" data-key="clearCache">
