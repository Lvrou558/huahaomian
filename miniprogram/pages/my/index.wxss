.page {
  min-height: 100vh;
  background: #f4f6f8;
  padding-bottom: 60rpx;
}

/* ========== 主页顶部 ========== */
.topbar-spacer { height: 24rpx; }

/* ========== 主页菜单 ========== */
.menu-list {
  padding: 8rpx 28rpx 0;
  display: flex;
  flex-direction: column;
  gap: 22rpx;
}

.menu-item {
  height: 144rpx;
  background: #ffffff;
  border-radius: 30rpx;
  display: flex;
  align-items: center;
  padding: 0 32rpx;
  box-shadow: 0 4rpx 18rpx rgba(0,0,0,0.06);
}

.menu-icon-wrap {
  width: 88rpx;
  height: 88rpx;
  border-radius: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.menu-icon {
  font-size: 48rpx;
  line-height: 1;
}

.menu-title {
  flex: 1;
  margin-left: 28rpx;
  font-size: 36rpx;
  color: #1a2c24;
  font-weight: 500;
}

/* 带副标题的菜单项（账号与服务等）：标题 + 副标题垂直堆叠 */
.menu-item-with-sub .menu-text {
  flex: 1;
  margin-left: 28rpx;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}
.menu-item-with-sub .menu-title {
  flex: none;
  margin-left: 0;
  font-size: 32rpx;
  font-weight: 700;
  color: #14443a;
}
.menu-item-with-sub .menu-subtitle {
  font-size: 22rpx;
  color: #8a978f;
  line-height: 1.4;
}

.menu-arrow {
  font-size: 42rpx;
  color: #9aa8a2;
  line-height: 1;
}

/* ========== 子页头部（sticky 顶部，向下滚动也常驻） ========== */
.subpage-header {
  position: sticky;
  top: 0;
  z-index: 100;
  height: 100rpx;
  display: flex;
  align-items: center;
  padding: 0 16rpx;
  background: rgba(244, 246, 248, 0.96);
  backdrop-filter: blur(10rpx);
}

.back-btn {
  width: 100rpx;
  height: 100rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.85);
  border-radius: 50%;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
}
.back-btn:active { background: #f0f4f7; transform: scale(0.92); }

.back-arrow {
  font-size: 52rpx;
  color: #1a2c24;
  font-weight: 400;
  line-height: 1;
  margin-top: -4rpx;
  margin-left: -4rpx;
}

.subpage-title {
  position: absolute;
  left: 120rpx;
  right: 120rpx;
  text-align: center;
  font-size: 34rpx;
  font-weight: 700;
  color: #1a2c24;
  pointer-events: none;
}

/* ========== 1. 设备自适应 ========== */
.adapt-spacer { height: 380rpx; }

.adapt-card {
  margin: 0 28rpx;
  padding: 38rpx 28rpx 30rpx;
  background: #ffffff;
  border-radius: 28rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.06);
}

.adapt-tip-line {
  text-align: center;
  font-size: 30rpx;
  color: #3a4a44;
  line-height: 1.55;
}

.adapt-tip-bold {
  text-align: center;
  font-size: 34rpx;
  font-weight: 700;
  color: #1a2c24;
  margin: 4rpx 0;
}

.adapt-divider {
  margin: 24rpx 0 18rpx;
  height: 1rpx;
  background: #ececec;
}

.adapt-btn {
  margin: 0 auto;
  width: 60%;
  height: 88rpx;
  border-radius: 999rpx;
  background: #4cb6ec;
  color: #fff;
  font-size: 32rpx;
  text-align: center;
  line-height: 88rpx;
  font-weight: 600;
}

.adapt-btn.disabled {
  background: #b9d8e8;
}

.adapt-meta {
  margin-top: 24rpx;
  font-size: 28rpx;
  color: #8a9aa3;
}

.adapt-meta-row {
  display: flex;
  align-items: center;
  margin-top: 4rpx;
  flex-wrap: wrap;
}

.adapt-meta-label {
  width: 130rpx;
  color: #8a9aa3;
}

.adapt-meta-value {
  flex: 1;
  color: #8a9aa3;
}

.adapt-meta-refresh {
  font-size: 28rpx;
  color: #6aa0c0;
  margin-left: 8rpx;
}

/* ========== 2. 监测参数 ========== */
.param-section {
  background: #ffffff;
  padding: 32rpx;
}

.param-divider {
  height: 1rpx;
  background: #ececec;
  margin: 0 32rpx;
}

.param-row {
  display: flex;
  align-items: center;
  margin-bottom: 18rpx;
}

.param-label {
  flex: 1;
  font-size: 30rpx;
  color: #1a2c24;
  font-weight: 600;
}

.param-help {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  background: #6a7780;
  color: #fff;
  font-size: 28rpx;
  text-align: center;
  line-height: 36rpx;
}

.param-time-row {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.param-time-chip {
  flex: 1;
  height: 76rpx;
  background: #ffffff;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 28rpx;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.05);
  font-size: 28rpx;
  color: #2a3a34;
}

.param-time-sep {
  font-size: 28rpx;
  color: #6a7780;
}

.param-select-chip {
  height: 76rpx;
  background: #ffffff;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 32rpx;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.05);
  font-size: 28rpx;
  color: #2a3a34;
}

.caret {
  color: #9aa8a2;
  font-size: 28rpx;
}

/* ========== 3. 被监测人信息 ========== */
.user-cover {
  background: #3cbcef;
  padding: 24rpx 28rpx 90rpx;
  text-align: center;
  color: #ffffff;
}

.user-cover-name { font-size: 46rpx; font-weight: 700; line-height: 1.3; }
.user-cover-age { font-size: 34rpx; font-weight: 700; margin-top: 4rpx; }
.user-cover-sub { margin-top: 8rpx; font-size: 28rpx; color: rgba(255,255,255,0.85); }

.user-card {
  margin: -50rpx 24rpx 18rpx;
  background: #ffffff;
  border-radius: 22rpx;
  padding: 28rpx 28rpx 14rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.06);
  position: relative;
}
.user-card + .user-card { margin-top: 18rpx; }

.user-card-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1a2c24;
  margin-bottom: 12rpx;
}

.user-card-edit {
  position: absolute;
  top: 28rpx;
  right: 28rpx;
  font-size: 28rpx;
  color: #4cb6ec;
}

.user-field {
  display: flex;
  align-items: center;
  padding: 18rpx 0;
  border-bottom: 1rpx solid #f0f3f1;
}

.user-field:last-child { border-bottom: 0; }

.user-field-label {
  width: 240rpx;
  font-size: 28rpx;
  color: #1a2c24;
}

.required-star {
  color: #ff5252;
  margin-right: 4rpx;
}

.user-field-text {
  flex: 1;
  font-size: 28rpx;
  color: #1a2c24;
}

.user-field-value {
  flex: 1;
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: #f3f6f8;
  border-radius: 999rpx;
  padding: 12rpx 24rpx;
  font-size: 28rpx;
}

.user-field-value.chip { background: #f3f6f8; }

.user-edit-row {
  display: flex;
  align-items: center;
  padding: 14rpx 0;
  border-bottom: 1rpx solid #f0f3f1;
}

.user-edit-row:last-of-type { border-bottom: 0; }

.user-input {
  flex: 1;
  height: 64rpx;
  background: #f3f6f8;
  border-radius: 12rpx;
  padding: 0 22rpx;
  font-size: 28rpx;
  color: #1a2c24;
  display: flex;
  align-items: center;
}

.user-input.chip {
  justify-content: space-between;
}

.user-edit-actions {
  margin: 24rpx 24rpx 30rpx;
  display: flex;
  gap: 16rpx;
}

.user-btn {
  flex: 1;
  height: 84rpx;
  line-height: 84rpx;
  text-align: center;
  border-radius: 999rpx;
  font-size: 30rpx;
  font-weight: 600;
}

.user-btn-cancel { background: #eef1f3; color: #5a6b65; }
.user-btn-save { background: #3cbcef; color: #fff; }

/* ========== 4. 物联卡 ========== */
.sim-spacer { height: 200rpx; }

.sim-main-card {
  margin: 0 28rpx;
  padding: 36rpx 36rpx 28rpx;
  background: #ffffff;
  border-radius: 28rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.06);
}

.sim-main-title {
  text-align: center;
  font-size: 30rpx;
  font-weight: 700;
  color: #1a2c24;
  margin-bottom: 22rpx;
}

.sim-iccid {
  font-size: 30rpx;
  color: #1a2c24;
  font-weight: 500;
  margin-bottom: 22rpx;
  letter-spacing: 0.5rpx;
}

.sim-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 18rpx 24rpx;
}

.sim-grid-cell {
  font-size: 28rpx;
  color: #2a3a34;
  line-height: 1.6;
}

.sim-cell-right {
  text-align: right;
}

.sim-cell-label {
  color: #2a3a34;
}

.sim-cell-status {
  color: #1d8a5c;
}

.sim-cell-text {
  color: #2a3a34;
}

.sim-footnote {
  margin: 22rpx 36rpx 0;
  font-size: 28rpx;
  color: #8a9aa3;
  line-height: 1.6;
}

/* ========== 5. 预警设置 ========== */
.alert-emergency {
  position: relative;
  padding: 16rpx 24rpx 28rpx;
  text-align: center;
}

.alert-emergency-title {
  font-size: 32rpx;
  color: #1a2c24;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.alert-emergency-edit {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  margin-top: 4rpx;
}

.alert-emergency-icon {
  font-size: 28rpx;
  color: #3cbcef;
}

.alert-emergency-input {
  width: 80%;
  margin: 14rpx auto 0;
  height: 64rpx;
  background: #f5f7f9;
  border-radius: 12rpx;
  padding: 0 22rpx;
  font-size: 28rpx;
  color: #1a2c24;
  text-align: center;
}

.alert-thin-divider {
  height: 1rpx;
  background: #ececec;
  margin: 0 24rpx;
}

.alert-section {
  padding: 24rpx 32rpx;
}

.alert-section-head {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.alert-section-title {
  flex: 1;
  font-size: 32rpx;
  font-weight: 700;
  color: #1a2c24;
}

.alert-label {
  margin-top: 14rpx;
  font-size: 28rpx;
  color: #6a7780;
}

.alert-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 8rpx;
}

.alert-chip {
  flex: 1;
  height: 70rpx;
  background: #ffffff;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #2a3a34;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.05);
}

.alert-chip-full { flex: 1; }

.alert-sep {
  font-size: 28rpx;
  color: #6a7780;
}

.alert-check-list {
  margin-top: 16rpx;
}

.alert-check-row {
  display: flex;
  align-items: center;
  padding: 10rpx 0;
  gap: 12rpx;
}

.alert-check-box {
  width: 32rpx;
  height: 32rpx;
  border: 2rpx solid #c8d2d7;
  border-radius: 6rpx;
  background: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 28rpx;
  font-weight: 700;
  flex-shrink: 0;
}

.alert-check-box.checked {
  background: #3cbcef;
  border-color: #3cbcef;
}

.alert-check-text {
  font-size: 28rpx;
  color: #1a2c24;
}

.alert-save-btn {
  margin: 32rpx 24rpx 30rpx;
  height: 96rpx;
  line-height: 96rpx;
  text-align: center;
  background: #4cb6ec;
  color: #fff;
  border-radius: 999rpx;
  font-size: 32rpx;
  font-weight: 600;
}

/* ========== 6. 分享设备 ========== */
.share-hero {
  margin: 18rpx 24rpx;
  padding: 36rpx 24rpx;
  background: linear-gradient(135deg, #4cb6ec 0%, #6fd0e3 100%);
  border-radius: 24rpx;
  text-align: center;
  color: #fff;
}

.share-hero-emoji { font-size: 64rpx; line-height: 1; }
.share-hero-title { margin-top: 12rpx; font-size: 34rpx; font-weight: 700; }
.share-hero-sub { margin-top: 10rpx; font-size: 28rpx; opacity: 0.9; }

.share-invite-btn {
  margin: 24rpx auto 0;
  width: 60%;
  height: 80rpx;
  line-height: 80rpx;
  background: #fff;
  color: #2580b1;
  border-radius: 999rpx;
  font-size: 28rpx;
  font-weight: 600;
}

.share-card {
  margin: 0 24rpx;
  padding: 24rpx 28rpx;
  background: #ffffff;
  border-radius: 22rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}

.share-card-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #1a2c24;
  margin-bottom: 14rpx;
}

.share-empty {
  padding: 24rpx 0;
  text-align: center;
  color: #8a9aa3;
  font-size: 28rpx;
}

.share-user-row {
  display: flex;
  align-items: center;
  padding: 14rpx 0;
  border-bottom: 1rpx solid #f0f3f1;
}

.share-user-row:last-child { border-bottom: 0; }

.share-user-avatar {
  width: 70rpx;
  height: 70rpx;
  border-radius: 50%;
  background: #f3f6f8;
  text-align: center;
  line-height: 70rpx;
  font-size: 36rpx;
  margin-right: 16rpx;
}

.share-user-info { flex: 1; }

.share-user-name {
  display: block;
  font-size: 28rpx;
  color: #1a2c24;
  font-weight: 600;
}

.share-user-meta {
  display: block;
  margin-top: 6rpx;
  font-size: 28rpx;
  color: #8a9aa3;
}

.share-remove-btn {
  padding: 8rpx 18rpx;
  background: #fff0ed;
  color: #d85a30;
  border-radius: 999rpx;
  font-size: 28rpx;
}

/* ========== 7. 更多设置 ========== */
.more-list {
  margin: 18rpx 24rpx;
  background: #ffffff;
  border-radius: 22rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}

.more-item {
  height: 96rpx;
  display: flex;
  align-items: center;
  padding: 0 28rpx;
  border-bottom: 1rpx solid #f0f3f1;
}

.more-item:last-child { border-bottom: 0; }

.more-item-label {
  flex: 1;
  font-size: 28rpx;
  color: #1a2c24;
}

.more-item-extra {
  font-size: 28rpx;
  color: #8a9aa3;
  margin-right: 12rpx;
}

.more-item-arrow {
  font-size: 32rpx;
  color: #9aa8a2;
}

.more-item-logout {
  margin-top: 16rpx;
  justify-content: center;
}

.more-item-logout .more-item-label {
  flex: none;
  color: #d85a30;
  font-weight: 600;
  text-align: center;
}

/* ========== 通用选择器（底部弹层） ========== */
.picker-mask {
  position: fixed;
  left: 0; right: 0; top: 0; bottom: 0;
  background: rgba(0, 0, 0, 0.45);
  z-index: 100;
}

.picker-sheet {
  position: fixed;
  left: 0; right: 0; bottom: 0;
  background: #ffffff;
  border-radius: 24rpx 24rpx 0 0;
  z-index: 101;
  padding-bottom: env(safe-area-inset-bottom);
}

.picker-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 88rpx;
  padding: 0 28rpx;
  border-bottom: 1rpx solid #f0f3f1;
}

.picker-btn {
  font-size: 30rpx;
  padding: 12rpx;
  min-width: 80rpx;
}

.picker-btn-cancel { color: #5a6b65; }
.picker-btn-ok { color: #3cbcef; font-weight: 600; }

.picker-title {
  font-size: 28rpx;
  color: #1a2c24;
  font-weight: 500;
}

.picker-view {
  width: 100%;
  height: 460rpx;
}

.picker-col-item {
  line-height: 64rpx;
  text-align: center;
  font-size: 30rpx;
  color: #8a9aa3;
}

.picker-col-item.active {
  color: #1a2c24;
  font-weight: 700;
  font-size: 34rpx;
}

/* ========== 设备详情 ========== */
.device-detail-wrap {
  padding: 120rpx 24rpx 60rpx;
  text-align: center;
}

.device-illust-circle {
  width: 360rpx;
  height: 360rpx;
  border-radius: 50%;
  background: linear-gradient(180deg, #ffffff 0%, #f3f5f7 100%);
  margin: 0 auto;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 12rpx 36rpx rgba(0,0,0,0.06);
}

.device-illust-box {
  width: 200rpx;
  height: 200rpx;
  background: #ffffff;
  border-radius: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 22rpx rgba(0,0,0,0.08);
}

.device-illust-dot {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  border: 2rpx solid #c8d2d7;
}

.device-name-row {
  margin-top: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 14rpx;
}

.device-name-text {
  font-size: 38rpx;
  font-weight: 700;
  color: #1a2c24;
}

.device-name-edit {
  font-size: 32rpx;
  color: #6a7780;
}

.device-fw {
  margin-top: 18rpx;
  font-size: 28rpx;
  color: #a8b2b8;
}

.device-unbind-btn {
  position: fixed;
  left: 28rpx;
  right: 28rpx;
  bottom: 60rpx;
  height: 104rpx;
  line-height: 104rpx;
  background: #ee6e6e;
  color: #ffffff;
  text-align: center;
  border-radius: 56rpx;
  font-size: 34rpx;
  font-weight: 600;
  box-shadow: 0 8rpx 22rpx rgba(238, 110, 110, 0.25);
}

/* ===== 实时监测页 ===== */
/* ===== 实时监测页 ===== */
.rt-card {
  background: #fff;
  border-radius: 22rpx;
  margin: 18rpx 22rpx;
  padding: 28rpx 28rpx 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.05);
}
.rt-online-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 32rpx;
}
.rt-online-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
}
.rt-online-label { font-size: 32rpx; color: #1a2c24; font-weight: 700; }
.rt-online-pill {
  font-size: 24rpx;
  background: #1f8a6f;
  color: #ffffff;
  padding: 6rpx 18rpx;
  border-radius: 999rpx;
  font-weight: 600;
}
.rt-signal-bars { font-size: 38rpx; color: #4cd964; }

.rt-card-head {
  margin-bottom: 18rpx;
}
.rt-title-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 12rpx;
}
.rt-card-title { font-size: 32rpx; font-weight: 700; color: #1a2c24; }
.rt-status-pill {
  background: #c7e8dc;
  color: #0F6E56;
  font-size: 22rpx;
  font-weight: 700;
  padding: 4rpx 16rpx;
  border-radius: 999rpx;
}
.rt-value-wrap {
  display: flex;
  align-items: baseline;
  justify-content: flex-end;
  gap: 6rpx;
}
.rt-value { font-size: 56rpx; font-weight: 800; color: #1a2c24; line-height: 1; }
.rt-unit { font-size: 26rpx; color: #6a7a81; }

/* 雷达信号刻度 */
.rt-signal-axis {
  display: flex;
  justify-content: space-between;
  padding: 0 4rpx;
  margin-bottom: 10rpx;
  font-size: 26rpx;
  color: #6a7a81;
}
.rt-signal-bar {
  height: 22rpx;
  border-radius: 11rpx;
  background: linear-gradient(90deg, #ff8a80 0%, #ffd6cc 30%, #ffffff 50%, #cbe7fa 70%, #5fc1f0 100%);
  position: relative;
