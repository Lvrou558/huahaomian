  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: 16rpx;
  padding: 28rpx;
}
.ae-avatar-item {
  aspect-ratio: 1;
  background: #f4fbf9;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 3rpx solid transparent;
}
.ae-avatar-item.selected {
  border-color: #1F8A6F;
  background: #ecf6f1;
}
.ae-avatar-grid-emoji { font-size: 60rpx; }

/* —— 昵称输入弹层 —— */
.ae-input-modal {
  position: fixed;
  bottom: 0;
  left: 0; right: 0;
  background: #fff;
  border-radius: 24rpx 24rpx 0 0;
  z-index: 999;
  padding-bottom: env(safe-area-inset-bottom);
}
.ae-modal-body {
  padding: 28rpx 28rpx 40rpx;
}
.ae-input {
  width: 100%;
  height: 88rpx;
  border: 1rpx solid #d8e8e1;
  border-radius: 14rpx;
  padding: 0 20rpx;
  font-size: 30rpx;
  background: #f4fbf9;
  color: #14443a;
  box-sizing: border-box;
}
.ae-input-hint {
  display: block;
  margin-top: 12rpx;
  font-size: 22rpx;
  color: #8a978f;
}

/* —— 手机号修改流程弹层 —— */
.ae-phone-modal {
  position: fixed;
  bottom: 0;
  left: 0; right: 0;
  background: #fff;
  border-radius: 24rpx 24rpx 0 0;
  z-index: 999;
  padding-bottom: env(safe-area-inset-bottom);
}
.ae-step-bar {
  display: flex;
  align-items: center;
  padding: 30rpx 56rpx;
}
.ae-step {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  opacity: 0.4;
}
.ae-step.active { opacity: 1; }
.ae-step-dot {
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  background: #c8e8d6;
  color: #fff;
  font-size: 26rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
}
.ae-step.active .ae-step-dot { background: #1F8A6F; }
.ae-step-label { font-size: 22rpx; color: #6a8b82; }
.ae-step-line {
  flex: 1;
  height: 4rpx;
  background: #c8e8d6;
  margin: 0 16rpx;
  margin-bottom: 30rpx;
}
.ae-step-line.active { background: #1F8A6F; }

.ae-phone-step { padding: 0 28rpx 36rpx; }
.ae-phone-hint {
  font-size: 26rpx;
  color: #4a6a60;
  line-height: 1.6;
  padding: 16rpx 0 24rpx;
}
.ae-input-wrap { margin-bottom: 18rpx; }
.ae-input-group {
  display: flex;
  gap: 12rpx;
  margin-bottom: 28rpx;
}
.ae-input-code { flex: 1; }
.ae-code-btn {
  flex-shrink: 0;
  height: 88rpx;
  padding: 0 24rpx;
  background: #ecf6f1;
  color: #1F8A6F;
  font-size: 26rpx;
  font-weight: 600;
  border-radius: 14rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 1rpx solid #c8e8d6;
}
.ae-code-btn.disabled {
  background: #f0f4f2;
  color: #95a5a0;
  border-color: #e6ebe8;
}

.ae-primary-btn {
  height: 88rpx;
  background: #1F8A6F;
  color: #fff;
  font-size: 30rpx;
  font-weight: 700;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.ae-primary-btn.disabled {
  background: #a8d5c8;
}

/* —— 注销账号确认弹层 —— */
.ae-close-modal {
  position: fixed;
  left: 28rpx;
  right: 28rpx;
  top: 50%;
  transform: translateY(-50%);
  background: #fff;
  border-radius: 24rpx;
  padding: 36rpx 32rpx;
  z-index: 999;
}
.ae-close-title {
  display: block;
  font-size: 34rpx;
  font-weight: 800;
  color: #c43a2c;
  text-align: center;
  margin-bottom: 16rpx;
}
.ae-close-text {
  display: block;
  font-size: 26rpx;
  color: #14443a;
  line-height: 1.6;
  margin-bottom: 14rpx;
}
.ae-close-list {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  background: #fff5f2;
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
  margin-bottom: 24rpx;
}
.ae-close-list text {
  font-size: 24rpx;
  color: #8c4530;
  line-height: 1.6;
}
.ae-close-btn-row {
  display: flex;
  gap: 14rpx;
}
.ae-secondary-btn,
.ae-danger-btn {
  flex: 1;
  height: 80rpx;
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 700;
}
.ae-secondary-btn {
  background: #ecf6f1;
  color: #14443a;
}
.ae-danger-btn {
  background: #c43a2c;
  color: #fff;
}

/* ===== 会员订阅页 ===== */
.mp-hero {
  background: linear-gradient(135deg, #1a1d2a 0%, #2d3245 50%, #3d2e0e 100%);
  color: #fff;
  padding: 50rpx 36rpx 80rpx;
  position: relative;
  overflow: hidden;
}
.mp-hero::before {
  content: '';
  position: absolute;
  top: -100rpx; right: -100rpx;
  width: 400rpx; height: 400rpx;
  background: radial-gradient(circle, rgba(255, 215, 100, 0.15) 0%, transparent 70%);
  border-radius: 50%;
}
.mp-crown-big { font-size: 72rpx; margin-bottom: 14rpx; display: block; }
.mp-brand { display: flex; align-items: baseline; gap: 14rpx; margin-bottom: 14rpx; }
.mp-brand-name { font-size: 50rpx; font-weight: 800; color: #f3d990; }
.mp-brand-pro { font-size: 32rpx; font-weight: 700; color: #f3d990; }
.mp-tagline { font-size: 28rpx; color: rgba(255, 255, 255, 0.82); line-height: 1.6; }
.mp-status-pill {
  margin-top: 22rpx;
  background: rgba(255, 245, 196, 0.15);
  border: 1rpx solid rgba(243, 217, 144, 0.4);
  border-radius: 14rpx;
  padding: 14rpx 18rpx;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}
.mp-status-pill text { color: #f3d990; font-size: 28rpx; }
.mp-status-expire { color: rgba(243, 217, 144, 0.75) !important; font-size: 28rpx !important; }

.mp-features {
  margin: -60rpx 28rpx 0;
  background: #fff;
  border-radius: 22rpx;
  padding: 32rpx 28rpx;
  box-shadow: 0 14rpx 32rpx rgba(0, 0, 0, 0.1);
  position: relative;
  z-index: 2;
}
.mp-features-title { font-size: 28rpx; font-weight: 700; color: #1a2c24; margin-bottom: 18rpx; display: block; }
.mp-feature-item {
  display: flex;
  align-items: flex-start;
  gap: 18rpx;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f3f7f5;
}
.mp-feature-item:last-child { border-bottom: none; padding-bottom: 0; }
.mp-feature-icon {
  width: 64rpx; height: 64rpx;
  border-radius: 16rpx;
  background: linear-gradient(135deg, #fef9e8, #faf3e0);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 34rpx;
  flex-shrink: 0;
}
.mp-feature-text { flex: 1; }
.mp-feature-title { font-size: 28rpx; font-weight: 700; color: #1a2c24; display: block; margin-bottom: 6rpx; }
.mp-feature-cmp { font-size: 28rpx; line-height: 1.6; }
.mp-feature-cmp .free { color: #aab; }
.mp-feature-cmp .pro { color: #c0850f; font-weight: 600; }

.mp-pricing {
  margin: 26rpx 28rpx 0;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 18rpx;
}
.mp-price-card {
  background: #fff;
  border: 3rpx solid #eef4f1;
  border-radius: 18rpx;
  padding: 30rpx 16rpx;
  text-align: center;
  position: relative;
}
.mp-price-card.recommended {
  border-color: #d4a548;
  background: linear-gradient(135deg, #fff9e8 0%, #fff 100%);
  box-shadow: 0 10rpx 24rpx rgba(180, 130, 30, 0.18);
}
.mp-price-badge {
  position: absolute;
  top: -16rpx; left: 50%;
  transform: translateX(-50%);
  background: linear-gradient(135deg, #d4a548, #b3851e);
  color: #fff;
  font-size: 28rpx;
  font-weight: 700;
  padding: 6rpx 18rpx;
  border-radius: 999rpx;
  box-shadow: 0 4rpx 10rpx rgba(180, 130, 30, 0.35);
  white-space: nowrap;
}
.mp-price-name { font-size: 28rpx; color: #7a8a83; display: block; margin-bottom: 10rpx; }
.mp-price-num { font-size: 54rpx; font-weight: 800; color: #1a2c24; line-height: 1; display: block; }
.mp-price-card.recommended .mp-price-num { color: #c0850f; }
.mp-price-period { font-size: 28rpx; color: #7a8a83; display: block; margin-top: 6rpx; }
.mp-price-equiv { font-size: 28rpx; color: #1f8a6f; display: block; margin-top: 6rpx; font-weight: 600; }

.mp-trust {
  margin: 24rpx 28rpx 0;
  background: #ecfaf3;
  border-radius: 14rpx;
  padding: 16rpx 20rpx;
  display: flex;
  align-items: center;
  gap: 22rpx;
  justify-content: center;
  flex-wrap: wrap;
}
.mp-trust-item { font-size: 28rpx; color: #1f8a6f; font-weight: 600; }

.mp-cta-wrap { margin: 28rpx 28rpx 0; }
.mp-cta-trial {
  background: linear-gradient(135deg, #d4a548, #b3851e);
  color: #fff;
  text-align: center;
  padding: 28rpx;
  border-radius: 999rpx;
  font-size: 32rpx;
  font-weight: 700;
  box-shadow: 0 12rpx 24rpx rgba(180, 130, 30, 0.38);
}
.mp-cta-sub { text-align: center; font-size: 28rpx; color: #7a8a83; margin-top: 14rpx; display: block; }

.mp-faq {
  margin: 28rpx 28rpx 40rpx;
  padding: 24rpx 26rpx;
  background: #fff;
  border-radius: 16rpx;
}
.mp-faq-title { font-size: 28rpx; font-weight: 700; color: #1a2c24; display: block; margin-bottom: 14rpx; }
.mp-faq-item { font-size: 28rpx; color: #7a8a83; line-height: 1.7; display: block; padding: 4rpx 0; }
.mp-faq-bold { color: #1a2c24; font-weight: 600; }

/* ===== 账号与服务页 ===== */
.acc-section { margin: 24rpx 28rpx 0; }
.acc-section-title { font-size: 28rpx; color: #7B928C; font-weight: 600; margin-bottom: 12rpx; padding-left: 8rpx; display: block; }
.acc-card { background: #fff; border-radius: 18rpx; padding: 0 28rpx; box-shadow: 0 4rpx 14rpx rgba(0, 0, 0, 0.04); }
.acc-member-card {
  padding: 26rpx 28rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: linear-gradient(135deg, #fff9e8, #fff);
  border: 1rpx solid #f0e5cf;
}
.acc-mc-head { display: flex; align-items: center; gap: 14rpx; }
.acc-mc-icon { font-size: 44rpx; }
.acc-mc-status { font-size: 28rpx; font-weight: 700; color: #1a2c24; display: block; }
.acc-mc-expire { font-size: 28rpx; color: #7a8a83; display: block; margin-top: 4rpx; }
.acc-mc-action {
  background: linear-gradient(135deg, #d4a548, #b3851e);
  color: #fff;
  font-size: 28rpx;
  font-weight: 700;
  padding: 10rpx 22rpx;
  border-radius: 999rpx;
}
.acc-row { display: flex; align-items: center; justify-content: space-between; padding: 26rpx 0; }
.acc-row-left { display: flex; flex-direction: column; gap: 4rpx; flex: 1; }
.acc-row-title { font-size: 28rpx; color: #1a2c24; }
.acc-row-title.danger { color: #d97757; }
.acc-row-sub { font-size: 28rpx; color: #7a8a83; }
.acc-row-value { font-size: 28rpx; color: #7a8a83; }
.acc-arrow { font-size: 32rpx; color: #b5c4d0; }
.acc-divider { height: 1rpx; background: #f3f7f5; }
.acc-switch {
  width: 78rpx; height: 44rpx;
  background: #e5e9ec;
  border-radius: 999rpx;
  position: relative;
  transition: background 0.2s;
}
.acc-switch.on { background: #1f8a6f; }
.acc-switch-knob {
  position: absolute;
  top: 4rpx; left: 4rpx;
  width: 36rpx; height: 36rpx;
  background: #fff;
  border-radius: 50%;
  box-shadow: 0 2rpx 6rpx rgba(0,0,0,0.2);
  transition: left 0.2s;
}
.acc-switch.on .acc-switch-knob { left: 38rpx; }

/* ===== 联系我们页 ===== */
.cu-banner {
  background: linear-gradient(135deg, #e3f4ff, #f7fbff);
  padding: 36rpx 28rpx;
  text-align: center;
}
.cu-banner-emoji { font-size: 60rpx; display: block; margin-bottom: 8rpx; }
.cu-banner-title { font-size: 32rpx; font-weight: 700; color: #1a2c24; display: block; margin-bottom: 6rpx; }
.cu-banner-sub { font-size: 28rpx; color: #7a8a83; display: block; }
.cu-section { margin: 24rpx 28rpx 0; }
.cu-section-title { font-size: 28rpx; color: #7B928C; font-weight: 600; margin-bottom: 12rpx; padding-left: 8rpx; display: block; }
.cu-row {
  background: #fff;
  border-radius: 16rpx;
  padding: 22rpx 24rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 12rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.04);
}
.cu-row:active { background: #f7fbf9; }
.cu-icon { width: 64rpx; height: 64rpx; border-radius: 14rpx; display: flex; align-items: center; justify-content: center; font-size: 32rpx; flex-shrink: 0; }
.cu-text { flex: 1; display: flex; flex-direction: column; gap: 4rpx; }
.cu-title { font-size: 28rpx; font-weight: 600; color: #1a2c24; }
.cu-sub { font-size: 28rpx; color: #7a8a83; }
.cu-arrow { font-size: 32rpx; color: #b5c4d0; }
.cu-faq { background: #fff; border-radius: 14rpx; padding: 20rpx 22rpx; margin-bottom: 12rpx; box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.04); }
.cu-faq-q { font-size: 28rpx; font-weight: 700; color: #1a2c24; display: block; margin-bottom: 8rpx; }
.cu-faq-a { font-size: 28rpx; color: #6a7a81; line-height: 1.6; display: block; }
