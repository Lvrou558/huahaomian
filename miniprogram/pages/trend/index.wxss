/* 页面基础 */
.page { padding: 16rpx 18rpx 48rpx; background: #f4fbf9; }

/* 顶部状态栏 */
.top-status { background: #fff; border-radius: 14rpx; padding: 14rpx 16rpx; display:flex; justify-content:space-between; align-items:center; font-size:22rpx; color:#2a4a43; margin-bottom:14rpx; }
.status-left { display:flex; align-items:center; gap:8rpx; }
.status-icon { font-size:24rpx; }
.status-link { color:#1f8a6f; font-size:22rpx; }

/* 通用卡片 */
.card { background:#fff; border-radius:18rpx; padding:20rpx; margin-bottom:14rpx; box-shadow:0 4rpx 14rpx rgba(37,114,93,0.06); }

/* 摘要卡片 */
.summary-card { background: linear-gradient(165deg,#ecfaf5 0%,#fff 62%); padding: 24rpx 20rpx; }
.summary-text { font-size:26rpx; color:#4f7269; line-height:1.6; text-align:center; }

/* K线图区域 */
.chart-card { padding: 18rpx; }
.kline-header { margin-bottom:12rpx; }
.kline-title { font-size:26rpx; font-weight:700; color:#1f443c; margin-bottom:10rpx; }
.kline-toolbar { display:flex; flex-wrap:wrap; align-items:center; gap:8rpx; font-size:21rpx; margin-bottom:8rpx; }
.kline-toolbar .tab-text { color:#a8c4bd; padding:6rpx 10rpx; }
.kline-toolbar .tab-text.active { color:#1f8a6f; font-weight:600; }
.kline-toolbar .sep { color:#c8ddd7; margin:0 4rpx; }
.kline-toolbar .op { color:#8aa39c; padding:4rpx 6rpx; }
.kline-toolbar .op-hint { color:#9ab2ac; font-size:20rpx; }

.kline-wrap { background:#f8fcfb; border-radius:12rpx; padding:8rpx; }
.kline-canvas { width:100%; height:320rpx; }

.kline-meta { margin-top:8rpx; padding-left:50rpx; }
.kline-axis { display:flex; align-items:center; font-size:20rpx; color:#86a29b; margin-bottom:8rpx; }
.kline-axis .axis-label { width:60rpx; flex-shrink:0; }
.kline-axis .axis-items { flex:1; display:flex; justify-content:space-between; }
.kline-avgs { border-top:1rpx solid #e8f0ed; padding-top:8rpx; }
.avg-row { display:flex; align-items:center; font-size:20rpx; color:#6e9188; margin-bottom:4rpx; }
.avg-label { width:100rpx; flex-shrink:0; color:#7a9a92; }
.avg-line { flex:1; text-align:center; color:#8aa39c; letter-spacing:2rpx; }

.summary-strip { margin-top:14rpx; padding:12rpx 0; border-top:1rpx solid #e8f3ef; display:flex; flex-wrap:wrap; justify-content:center; gap:12rpx; font-size:22rpx; color:#5c7f75; }
.strip-sep { color:#c8ddd7; }
.trend-hints { margin-top:12rpx; padding-top:12rpx; border-top:1rpx solid #e8f3ef; }
.trend-note { font-size:24rpx; color:#1f8a6f; line-height:1.5; margin-bottom:8rpx; }
.trend-tip { font-size:22rpx; color:#4f7269; line-height:1.5; }

/* 折叠模块卡片 */
.module-card { background:#fff; border-radius:18rpx; margin-bottom:14rpx; box-shadow:0 4rpx 14rpx rgba(37,114,93,0.06); overflow:hidden; }
.module-card.expanded { padding-bottom: 10rpx; }

.module-header { padding: 24rpx 20rpx; display:flex; align-items:flex-start; gap:16rpx; background:#fff; }
.module-card.expanded .module-header { border-bottom:1rpx solid #f0f7f4; }

.module-num { font-size:32rpx; font-weight:700; color:#1f8a6f; line-height:1.2; }

.module-title-wrap { flex:1; }
.module-title { font-size:28rpx; font-weight:700; color:#1f443c; line-height:1.4; margin-bottom:8rpx; }
.vip-badge { font-size:20rpx; color:#ff8a65; font-weight:500; }
.module-desc { font-size:22rpx; color:#6e9188; line-height:1.5; }

.module-right { display:flex; flex-direction:column; align-items:flex-end; gap:8rpx; }
.mini-trend { display:flex; align-items:center; gap:8rpx; }
.mini-icon { font-size:28rpx; }
.mini-line { width:100rpx; height:6rpx; background:linear-gradient(90deg, #26A69A 0%, #4fc3f7 100%); border-radius:3rpx; }
.mini-line.breath-line { background:linear-gradient(90deg, #4fc3f7 0%, #81d4fa 100%); }
.mini-line.heart-line { background:linear-gradient(90deg, #ec407a 0%, #f48fb1 100%); }
.mini-line.sound-line { background:linear-gradient(90deg, #ffa726 0%, #ffcc80 100%); }

.module-toggle { font-size:20rpx; color:#1f8a6f; white-space:nowrap; }

/* 模块展开内容 */
.module-body { padding: 16rpx 20rpx; }

.metric-section { margin-bottom: 24rpx; padding-bottom: 16rpx; border-bottom: 1rpx solid #f0f7f4; }
.metric-section:last-child { margin-bottom: 0; padding-bottom: 0; border-bottom: none; }

.metric-row { display:flex; justify-content:space-between; align-items:center; flex-wrap:wrap; gap:10rpx; margin-bottom:8rpx; }
.metric-title { font-size:28rpx; font-weight:600; color:#1f443c; }
.metric-toolbar { display:flex; align-items:center; gap:8rpx; font-size:20rpx; }
.metric-toolbar .tab-text { color:#a8c4bd; padding:4rpx 8rpx; }
.metric-toolbar .tab-text.active { color:#1f8a6f; font-weight:600; }
.metric-toolbar .sep { color:#c8ddd7; margin:0 2rpx; }
.metric-toolbar .op { color:#8aa39c; padding:4rpx 6rpx; }

.chart-container { width:100%; height:200rpx; border-radius:12rpx; background:#f8fcfb; margin-top:10rpx; overflow:hidden; }
.trend-canvas { width:100%; height:100%; }

.chart-axis { margin-top:8rpx; padding-left:40rpx; display:flex; justify-content:space-between; font-size:20rpx; color:#8ca6a0; }
.chart-axis.long-axis { padding-left: 40rpx; font-size: 18rpx; }

.metric-insight { margin-top:12rpx; font-size:22rpx; color:#5c7f75; line-height:1.5; padding:12rpx 16rpx; background:#f8fcfb; border-radius:10rpx; border-left:3rpx solid #26A69A; }

/* 底部留白 */
.bottom-space { height: 40rpx; }

/* 旧样式兼容（保留） */
.chart-header { display:flex; justify-content:space-between; align-items:center; gap:12rpx; }
.chart-legend { display:flex; align-items:center; gap:8rpx; font-size:20rpx; color:#86a29b; }
.legend-line { width:28rpx; border-top:2rpx dashed #b7ceca; }
.metric-head { display:flex; justify-content:space-between; align-items:flex-end; gap:12rpx; }
.metric-sub { font-size:22rpx; color:#6e9188; margin-bottom:10rpx; }