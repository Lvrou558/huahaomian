.page { padding: 16rpx 18rpx 48rpx; background: #f4fbf9; }
.top-status { background: #fff; border-radius: 14rpx; padding: 14rpx 16rpx; display:flex; justify-content:space-between; font-size:22rpx; color:#2a4a43; margin-bottom: 14rpx; }
.status-link { color:#1f8a6f; }
.card { background:#fff; border-radius:18rpx; padding:20rpx; margin-bottom:14rpx; box-shadow:0 4rpx 14rpx rgba(37,114,93,0.06); }
.hero-card { background: linear-gradient(165deg,#ecfaf5 0%,#fff 62%); }
.hero-grid { display:flex; align-items:center; justify-content:space-between; }
.recover,.duration { width: 32%; }
.percent { font-size:44rpx; font-weight:700; color:#18433b; line-height:1; }
.recover-title,.dur-note { font-size:22rpx; color:#61837a; margin-top:8rpx; }
.recover-note,.dur-sub { font-size:22rpx; color:#2d9c7f; margin-top:6rpx; }
.score-center { width: 34%; text-align:center; }
.score-ring { width:150rpx; height:150rpx; border-radius:50%; margin:0 auto; background: conic-gradient(#26a69a 0 313deg, #dff0ea 313deg 360deg); display:flex; align-items:center; justify-content:center; color:#0f453d; font-weight:700; font-size:30rpx; }
.score-tip { display:block; margin-top:10rpx; color:#1f8a6f; font-size:22rpx; }
.dur-value { font-size:48rpx; font-weight:700; color:#153e36; line-height:1; text-align:right; }
.hero-second { margin-top:10rpx; width:40%; }
.hero-text { margin-top:10rpx; font-size:23rpx; color:#4f7269; line-height:1.55; }
.hero-note { margin-top:8rpx; font-size:22rpx; color:#2f9a7e; }
.hero-action { margin-top:12rpx; text-align:right; color:#1f8a6f; font-size:23rpx; }
.section-title { font-size:28rpx; font-weight:700; color:#1f443c; margin-bottom:8rpx; }
.fold-head { display:flex; justify-content:space-between; align-items:center; }
.fold-action { color:#1f8a6f; font-size:22rpx; }
.sub-title { font-size:23rpx; color:#577970; line-height:1.6; }
.time-row { display:flex; justify-content:space-between; color:#688b82; font-size:22rpx; margin-bottom:10rpx; }
.chart-lg { width:100%; height:220rpx; background:#f8fcfb; border-radius:12rpx; }
.chart-sm { width:100%; height:150rpx; background:#f8fcfb; border-radius:12rpx; margin-top:10rpx; }
.cycle-tags,.legend-row { margin-top:10rpx; display:flex; flex-wrap:wrap; gap:10rpx 14rpx; font-size:21rpx; color:#5a7e74; }
.metric-grid { display:grid; grid-template-columns:1fr 1fr; gap:10rpx; margin-top:10rpx; }
.metric-box { border:1rpx solid #e3f0ec; border-radius:12rpx; padding:14rpx; background:#fbfefd; }
.m-label { color:#6a8b82; font-size:21rpx; }
.m-value { margin-top:6rpx; color:#16443c; font-size:34rpx; font-weight:700; }
.m-level { margin-top:4rpx; color:#2e9f82; font-size:21rpx; }
.mini-title { margin-top:12rpx; font-size:24rpx; color:#21463e; font-weight:600; }
.axis { margin-top:8rpx; font-size:20rpx; color:#8ca6a0; letter-spacing:1rpx; }
.expand-link { margin-top:12rpx; text-align:right; color:#1f8a6f; font-size:23rpx; }
.vip { font-size:20rpx; color:#f5a623; margin-left:10rpx; }
.btn-row { margin-top:12rpx; display:flex; gap:10rpx; }
.btn { flex:1; border-radius:999rpx; font-size:22rpx; padding:0; line-height:72rpx; height:72rpx; }
.btn.primary { background:#1f8a6f; color:#fff; }
.btn.ghost { background:#edf8f4; color:#1f8a6f; border:1rpx solid #cfe8df; }
.tip { margin-top:8rpx; color:#7c9790; font-size:20rpx; line-height:1.5; }
.mt12 { margin-top:12rpx; }
.list-item { margin-top:8rpx; font-size:23rpx; color:#4f7269; line-height:1.58; }
.link-row { margin-top:12rpx; display:flex; flex-direction:column; gap:8rpx; color:#1f8a6f; font-size:22rpx; }