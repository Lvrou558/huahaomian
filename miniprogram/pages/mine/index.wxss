.page {
  padding: 20rpx;
  padding-bottom: 60rpx;
  background: #F4FBF9;
  min-height: 100vh;
  position: relative;
}

.card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(32, 132, 108, 0.06);
}

/* 弹窗 */
.privacy-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
}

.modal-content {
  position: relative;
  width: 85%;
  background: white;
  border-radius: 28rpx;
  padding: 40rpx;
  max-height: 80vh;
  overflow-y: auto;
}

.modal-header {
  text-align: center;
  margin-bottom: 32rpx;
}

.modal-icon {
  font-size: 56rpx;
  margin-bottom: 16rpx;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1B3A36;
}

.modal-body {
  margin-bottom: 40rpx;
}

.promise-item {
  display: flex;
  gap: 20rpx;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #E0F2F1;
}

.promise-item:last-child {
  border-bottom: none;
}

.promise-icon {
  font-size: 36rpx;
  flex-shrink: 0;
}

.promise-text {
  font-size: 26rpx;
  color: #5B7B73;
  line-height: 1.6;
}

.promise-text strong {
  color: #26A69A;
  font-weight: 600;
}

.modal-footer {
  display: flex;
  gap: 20rpx;
}

.btn-disagree,
.btn-agree {
  flex: 1;
  padding: 24rpx 0;
  border-radius: 16rpx;
  font-size: 28rpx;
  font-weight: 600;
  border: none;
}

.btn-disagree {
  background: #F5F5F5;
  color: #9E9E9E;
}

.btn-agree {
  background: linear-gradient(135deg, #26A69A 0%, #4DB6AC 100%);
  color: white;
}

/* 设备卡片 */
.device-card {
  background: linear-gradient(145deg, #E8F5F2 0%, #ffffff 60%);
}

.device-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.device-status {
  display: flex;
  align-items: center;
  gap: 12rpx;
  font-size: 26rpx;
  color: #1B3A36;
  font-weight: 600;
}

.status-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #B0BEC5;
}

.status-dot.connected {
  background: #66BB6A;
}

.device-battery {
  font-size: 24rpx;
  color: #5B7B73;
}

.device-info {
  margin-bottom: 24rpx;
  padding: 20rpx;
  background: rgba(255, 255, 255, 0.8);
  border-radius: 16rpx;
}

.device-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #1B3A36;
  margin-bottom: 8rpx;
}

.device-meta {
  font-size: 22rpx;
  color: #7B928C;
}

.device-actions {
  display: flex;
}

.device-btn {
  flex: 1;
  padding: 24rpx 0;
  border-radius: 16rpx;
  font-size: 28rpx;
  font-weight: 600;
  border: none;
}

.device-btn.primary {
  background: linear-gradient(135deg, #26A69A 0%, #4DB6AC 100%);
  color: white;
}

.device-btn.danger {
  background: #FFEBEE;
  color: #E57373;
}

/* 隐私卡片 */
.privacy-card {
  background: linear-gradient(180deg, #FFF8E1 0%, #FFFFFF 100%);
  border: 2rpx solid #FFE082;
}

.section-header {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 24rpx;
}

.section-icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: #FFE082;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1B3A36;
}

.section-subtitle {
  font-size: 22rpx;
  color: #7B928C;
  margin-top: 4rpx;
}

.privacy-promises {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.promise-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  font-size: 24rpx;
  color: #5B7B73;
}

.promise-check {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  background: #26A69A;
  color: white;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
}

/* 开关卡片 */
.switch-card {
  background: #ffffff;
}

.switch-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.switch-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1B3A36;
  margin-bottom: 8rpx;
}

.switch-desc {
  font-size: 22rpx;
  color: #7B928C;
}

.switch-note {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 16rpx;
  background: #E8F5E9;
  border-radius: 12rpx;
  font-size: 22rpx;
  color: #66BB6A;
}

.switch-note.disabled {
  background: #F5F5F5;
  color: #9E9E9E;
}

.note-icon {
  font-size: 24rpx;
}

/* 数据管理卡片 */
.data-card {
  background: #ffffff;
}

.data-stats {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-bottom: 24rpx;
  padding: 20rpx 0;
  border-top: 1rpx solid #E0F2F1;
  border-bottom: 1rpx solid #E0F2F1;
}

.data-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.data-label {
  font-size: 24rpx;
  color: #5B7B73;
}

.data-value {
  font-size: 28rpx;
  font-weight: 600;
  color: #1B3A36;
}

.data-actions {
  display: flex;
  gap: 16rpx;
}

.action-btn {
  flex: 1;
  padding: 20rpx 0;
  border-radius: 12rpx;
  font-size: 24rpx;
  border: none;
}

.action-btn.secondary {
  background: #F7FCFA;
  color: #26A69A;
}

.action-btn.danger {
  background: #FFEBEE;
  color: #E57373;
}

/* 帮助卡片 */
.help-card {
  background: #ffffff;
}

.help-list {
  display: flex;
  flex-direction: column;
}

.help-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #E0F2F1;
  font-size: 26rpx;
  color: #1B3A36;
}

.help-item:last-child {
  border-bottom: none;
}

.arrow {
  font-size: 28rpx;
  color: #B0BEC5;
}

/* 版本信息 */
.version-info {
  text-align: center;
  padding: 40rpx 0;
  font-size: 22rpx;
  color: #B0BEC5;
}