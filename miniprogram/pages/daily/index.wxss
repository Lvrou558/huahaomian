.movement-count-wrap { display:flex; align-items:baseline; gap:6rpx; color:#2b3940; }
.movement-count-label { font-size: 34rpx; line-height: 1; font-weight: 500; color:#4a5a60; }
.movement-count-value { font-size: 58rpx; line-height: 0.95; font-weight: 500; color:#1e2d32; }
.movement-count-unit { font-size: 28rpx; line-height: 1; color:#55666d; }
.movement-chart { margin-top: 10rpx; background:#f8fcfb; border:1rpx solid #e6f0ed; border-radius:12rpx; }
.movement-axis { margin-top: 10rpx; font-size: 19rpx; color:#8ca6a0; }
.movement-legend { margin-top: 10rpx; display:flex; justify-content:center; gap:28rpx; color:#587169; font-size:24rpx; }
.movement-legend-item { display:flex; align-items:center; gap:10rpx; line-height: 1; }
.movement-dot { width: 32rpx; height: 5rpx; border-radius: 999rpx; display:inline-block; }
.movement-dot-activity { background:#4fc3d8; }
