.page { padding: 16rpx 18rpx 48rpx; background: #f4fbf9; }

/* 星期选择器 */
.week-selector { background: #1a2a3a; border-radius: 18rpx; padding: 24rpx 20rpx; margin-bottom: 14rpx; }
.week-header { display: flex; align-items: center; margin-bottom: 24rpx; }
.week-title { font-size: 48rpx; font-weight: 700; color: #fff; }
.week-subtitle { font-size: 24rpx; color: #8a9baa; margin-left: 16rpx; flex: 1; }
.icon-calendar { font-size: 32rpx; }
/* 右上角日历入口（替换原 date-bar） */
.week-calendar-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 56rpx;
  height: 56rpx;
  border-radius: 14rpx;
  background: rgba(255, 255, 255, 0.08);
  border: 1rpx solid rgba(255, 255, 255, 0.12);
  flex-shrink: 0;
}
.week-calendar-btn .icon-calendar { font-size: 30rpx; }
.week-cal-hover { background: rgba(255, 255, 255, 0.18); }

.week-days { display: flex; justify-content: space-between; align-items: center; }
.day-item { display: flex; flex-direction: column; align-items: center; }
.day-circle { width: 80rpx; height: 80rpx; border-radius: 50%; display: flex; flex-direction: column; align-items: center; justify-content: center; border: 2rpx solid rgba(255,255,255,0.2); gap: 2rpx; }
.day-circle.active { border-color: #ff8a65; background: conic-gradient(from 0deg, #ff8a65 0deg, rgba(255,138,101,0.3) 0deg, rgba(255,255,255,0.1) 360deg); }
.day-text { font-size: 28rpx; color: #8a9baa; line-height: 1; }
.day-num { font-size: 28rpx; color: #b5c4d0; line-height: 1; font-weight: 600; }
.day-circle.active .day-text { color: #fff; }
.day-circle.active .day-num { color: #fff; }

/* 日期条 */
.date-bar { background: #2a3a4a; border-radius: 16rpx; padding: 24rpx 28rpx; display: flex; justify-content: flex-start; align-items: center; margin-bottom: 14rpx; }
.date-left { display: flex; align-items: center; gap: 16rpx; }
.date-text { font-size: 32rpx; color: #fff; font-weight: 500; }

/* 日历弹窗 */
.calendar-modal { position: fixed; top: 0; left: 0; right: 0; bottom: 0; z-index: 1000; display: flex; align-items: center; justify-content: center; }
.modal-mask { position: absolute; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.6); }
.modal-content { position: relative; background: #2a3a4a; border-radius: 24rpx; padding: 32rpx; width: 85%; max-width: 600rpx; }
.modal-header { display: flex; align-items: center; margin-bottom: 32rpx; }
.modal-title { font-size: 36rpx; font-weight: 700; color: #fff; }
.modal-subtitle { font-size: 24rpx; color: #8a9baa; margin-left: 16rpx; }
.modal-close { margin-left: auto; width: 56rpx; height: 56rpx; background: rgba(255,255,255,0.1); border-radius: 50%; display: flex; align-items: center; justify-content: center; color: #fff; font-size: 32rpx; }
.modal-month-nav { width: 60rpx; height: 60rpx; display: flex; align-items: center; justify-content: center; color: #fff; font-size: 40rpx; background: rgba(255,255,255,0.08); border-radius: 50%; }
.modal-month-nav:active { background: rgba(255,255,255,0.18); }

.calendar-grid { display: grid; grid-template-columns: repeat(7, 1fr); gap: 16rpx; }
.calendar-day { aspect-ratio: 1; display: flex; align-items: center; justify-content: center; border-radius: 12rpx; font-size: 28rpx; color: #fff; }
.calendar-day.has-data { background: rgba(255,255,255,0.1); }
.calendar-day.today { background: #ff8a65; }

.top-status { background: #fff; border-radius: 14rpx; padding: 12rpx 16rpx; display:flex; justify-content:space-between; align-items:center; font-size:22rpx; color:#2a4a43; margin-bottom: 14rpx; line-height:1.4; }
.status-link { color:#1f8a6f; }
.temple-icon-entry {
  margin-bottom: 14rpx;
  width: 126rpx;
  height: 126rpx;
  border-radius: 50%;
  background: linear-gradient(145deg, #fff9ef 0%, #fef1de 100%);
  border: 1rpx solid #f1dcc1;
  display:flex;
  flex-direction:column;
  align-items:center;
  justify-content:center;
  box-shadow: 0 6rpx 14rpx rgba(148, 111, 67, 0.12);
}
.temple-icon-emoji { font-size: 42rpx; line-height: 1; }
.temple-icon-text { margin-top: 8rpx; font-size: 28rpx; color: #8c6a43; font-weight: 600; line-height: 1.2; }
.temple-in-sleep { margin: 0 0 16rpx; }
.sleep-section-title {
  margin-top: 22rpx;
  padding-top: 18rpx;
  border-top: 1rpx solid #eef4f1;
  font-size: 28rpx;
  font-weight: 700;
  color: #1f443c;
  line-height: 1.4;
}

/* ===== 顶部「昨晚总览」独立卡片 ===== */
.overview-card {
  background: linear-gradient(165deg, #f3fbf7 0%, #ffffff 50%, #f0f7fd 100%);
  border: 1rpx solid #e3f1ea;
  padding: 24rpx 22rpx;
}

/* 标题栏 */
.overview-header {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-bottom: 18rpx;
}
.overview-emoji { font-size: 32rpx; line-height: 1; }
.overview-title {
  font-size: 34rpx;
  font-weight: 800;
  color: #14443a;
  letter-spacing: 1rpx;
  flex: 1;
}
.overview-date {
  font-size: 22rpx;
  color: #7a8c84;
  background: rgba(255, 255, 255, 0.7);
  padding: 4rpx 14rpx;
  border-radius: 10rpx;
  border: 1rpx solid #e6f0ea;
}

/* 综合总结块 */
.nightly-summary {
  padding: 18rpx;
  background: #ffffff;
  border: 1rpx solid #e6f0ea;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 14rpx rgba(31, 138, 111, 0.04);
}
.nightly-summary-headline {
  font-size: 28rpx;
  font-weight: 700;
  color: #1f8a6f;
  margin-bottom: 10rpx;
  line-height: 1.45;
}
.nightly-summary-progress {
  display: flex;
  align-items: center;
  gap: 12rpx;
}
.nsp-bar {
  flex: 1;
  height: 12rpx;
  background: #ecf3ef;
  border-radius: 6rpx;
  overflow: hidden;
}
.nsp-fill {
  height: 100%;
  background: linear-gradient(90deg, #4cd964 0%, #1f8a6f 100%);
  border-radius: 6rpx;
  transition: width 0.4s ease;
}
.nsp-count {
  font-size: 28rpx;
  color: #4a6a60;
  font-weight: 600;
  min-width: 60rpx;
  text-align: right;
}
.nightly-summary-paragraphs {
  margin-top: 16rpx;
  padding-top: 14rpx;
  border-top: 1rpx dashed #d8e8e0;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}
.nightly-summary-paragraphs.no-divider {
  margin-top: 0;
  padding-top: 0;
  border-top: none;
}
.ns-para {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}
.ns-para-label {
  font-size: 28rpx;
  font-weight: 700;
  color: #1f8a6f;
  letter-spacing: 0.5rpx;
}
.ns-para-text {
  font-size: 28rpx;
  color: #2e4a44;
  line-height: 1.6;
}

/* 双环上方的"近 7 天恢复趋势"跳转链接 */
.recovery-link-row {
  display: flex;
  justify-content: flex-end;
  align-items: center;
  gap: 6rpx;
  margin: 14rpx 4rpx 6rpx;
  font-size: 28rpx;
  color: #1f8a6f;
  font-weight: 600;
}
.recovery-link-text { line-height: 1; }
.recovery-link-arrow { font-size: 28rpx; line-height: 1; }
.recovery-link-row:active { opacity: 0.6; }

/* ===== 双环恢复度（新版美化） ===== */
.recovery-rings-row {
  display: flex;
  justify-content: space-evenly;
  align-items: stretch;
  margin-top: 24rpx;
  padding: 24rpx 12rpx;
  background: rgba(255, 255, 255, 0.85);
  border: 1rpx solid #e6f0ea;
  border-radius: 16rpx;
  gap: 16rpx;
}

.recovery-ring-box {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

/* 圆环外层容器，提供阴影与边框 */
.recovery-ring-outer {
  width: 184rpx;
  height: 184rpx;
  border-radius: 50%;
  padding: 7rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.recovery-ring-box.body .recovery-ring-outer {
  background: linear-gradient(145deg, #d9f4e3, #f7fcf9);
  box-shadow: 0 10rpx 26rpx rgba(31, 138, 111, 0.18),
              inset 0 2rpx 6rpx rgba(255, 255, 255, 0.9);
}
.recovery-ring-box.mind .recovery-ring-outer {
  background: linear-gradient(145deg, #d9e8f9, #f7faff);
  box-shadow: 0 10rpx 26rpx rgba(58, 108, 219, 0.18),
              inset 0 2rpx 6rpx rgba(255, 255, 255, 0.9);
}

.recovery-ring {
  width: 170rpx;
  height: 170rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}

/* 中间白色镂空圆（用 ::before 模拟） */
.recovery-ring::before {
  content: '';
  position: absolute;
  top: 14rpx;
  left: 14rpx;
  right: 14rpx;
  bottom: 14rpx;
  background: #ffffff;
  border-radius: 50%;
  box-shadow: inset 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.ring-inner {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 2rpx;
}
.ring-score {
  font-size: 60rpx;
  font-weight: 800;
  line-height: 1;
  letter-spacing: -2rpx;
}
.recovery-ring-box.body .ring-score { color: #1f8a6f; }
.recovery-ring-box.mind .ring-score { color: #3a6cdb; }

.ring-unit {
  font-size: 28rpx;
  color: #a3b5ad;
  font-weight: 600;
  margin-top: 2rpx;
}

.ring-label {
  margin-top: 16rpx;
  font-size: 28rpx;
  color: #4a5e57;
  font-weight: 600;
  letter-spacing: 1rpx;
}

.ring-status-pill {
  margin-top: 8rpx;
  padding: 4rpx 14rpx;
  border-radius: 12rpx;
  font-size: 22rpx;
  font-weight: 600;
}
.recovery-ring-box.body .ring-status-pill {
  color: #1f8a6f;
  background: #e6f5ee;
  border: 1rpx solid #c8e8d8;
}
.recovery-ring-box.mind .ring-status-pill {
  color: #3a6cdb;
  background: #ebf1fd;
  border: 1rpx solid #cfdcf8;
}

/* ===== 核心数据 5 项网格 ===== */
.core-metrics-grid {
  margin-top: 18rpx;
  background: #ffffff;
  border: 1rpx solid #e6f0ea;
  border-radius: 16rpx;
  padding: 4rpx 0;
  display: grid;
  grid-template-columns: 1fr 1fr 1fr 1fr 1fr;
  box-shadow: 0 4rpx 14rpx rgba(31, 138, 111, 0.04);
}
.core-metric {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 4rpx;
  position: relative;
}
.core-metric + .core-metric::before {
  content: '';
  position: absolute;
  left: 0;
  top: 22rpx;
  bottom: 22rpx;
  width: 1rpx;
  background: #ecf3ef;
}
.core-metric-label {
  font-size: 22rpx;
  color: #7a8c84;
  font-weight: 500;
}
.core-metric-value-wrap {
  margin-top: 10rpx;
  display: flex;
  align-items: baseline;
  gap: 2rpx;
}
.core-metric-value {
  font-size: 30rpx;
  font-weight: 700;
  color: #14443a;
  line-height: 1.1;
}
.core-metric-unit {
  font-size: 22rpx;
  color: #7a8c84;
  font-weight: 500;
}

/* 今晚医学建议两项 */
.sleep-suggestion-grid {
  margin-top: 14rpx;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 14rpx;
}
.sleep-suggestion {
  display: flex;
  align-items: center;
  gap: 14rpx;
  padding: 18rpx 20rpx;
  background: linear-gradient(135deg, #f0faf5 0%, #ffffff 100%);
  border: 1rpx solid #d9efe3;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 14rpx rgba(31, 138, 111, 0.05);
}
.ss-icon {
  font-size: 44rpx;
  line-height: 1;
  flex-shrink: 0;
}
.ss-text {
  display: flex;
  flex-direction: column;
  gap: 2rpx;
  flex: 1;
  min-width: 0;
}
.ss-label {
  font-size: 28rpx;
  color: #4a7a6c;
  font-weight: 500;
}
.ss-value {
  font-size: 34rpx;
  font-weight: 800;
  color: #14443a;
  line-height: 1.1;
  letter-spacing: 0.5rpx;
}
.ss-sub {
  font-size: 22rpx;
  color: #7a8c84;
  margin-top: 2rpx;
}

/* 子板块标题首项去除上分隔线 */
.sleep-section-title--first {
  margin-top: 8rpx;
  padding-top: 0;
  border-top: none;
}

/* ===== 今日建议打卡（顶部卡内） ===== */
.today-checkins {
  margin-top: 18rpx;
  padding: 18rpx;
  background: #ffffff;
  border: 1rpx solid #e6f0ea;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 14rpx rgba(31, 138, 111, 0.04);
}
.today-checkins-head {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 14rpx;
  padding-bottom: 12rpx;
  border-bottom: 1rpx dashed #d8e8e0;
}
.tc-head-emoji { font-size: 28rpx; }
.tc-head-text {
  font-size: 28rpx;
  font-weight: 700;
  color: #14443a;
  flex: 1;
}
.tc-head-meta {
  font-size: 28rpx;
  color: #7a8c84;
  background: #f0f7e9;
  padding: 2rpx 10rpx;
  border-radius: 8rpx;
}
.tc-head-deadline {
  font-size: 22rpx;
  color: #1f8a6f;
  background: #ecfaf3;
  padding: 4rpx 12rpx;
  border-radius: 999rpx;
  font-weight: 600;
  border: 1rpx solid #c8e8d6;
}

.today-checkin-item {
  display: flex;
  align-items: center;
  gap: 14rpx;
  padding: 14rpx 8rpx;
  border-bottom: 1rpx solid #f0f6f3;
  transition: background 0.2s, transform 0.15s;
  border-radius: 10rpx;
}
.today-checkin-item-hover {
  background: #f0faf5;
  transform: scale(0.985);
}
.today-checkin-item:last-child { border-bottom: none; }
.today-checkin-item.checked .tc-item-title {
  color: #7a8c84;
  text-decoration: line-through;
}
.today-checkin-item.checked .tc-item-sub { color: #aab9b3; }
.tc-item-emoji {
  font-size: 36rpx;
  line-height: 1;
  flex-shrink: 0;
  width: 56rpx;
  text-align: center;
}
.tc-item-text {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}
.tc-item-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #14443a;
  line-height: 1.35;
}
.tc-item-sub {
  font-size: 22rpx;
  color: #6a7a81;
  line-height: 1.45;
}
.tc-check-box {
  flex-shrink: 0;
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  border: 2rpx solid #c5d4ce;
  display: flex;
  align-items: center;
  justify-content: center;
}
.today-checkin-item.checked .tc-check-box {
  background: #1f8a6f;
  border-color: #1f8a6f;
}
.tc-check-icon {
  color: #fff;
  font-size: 28rpx;
  font-weight: 700;
  line-height: 1;
}
.card { background:#fff; border-radius:18rpx; padding:20rpx; margin-bottom:14rpx; box-shadow:0 4rpx 14rpx rgba(37,114,93,0.06); }
.hero-card { background: linear-gradient(165deg,#ecfaf5 0%,#fff 62%); }
.hero-grid { display:flex; align-items:center; justify-content:space-between; }
