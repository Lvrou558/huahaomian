}

.hp-score-unit {
  font-size: 22rpx;
  color: #6a7a81;
}

.hp-score-bar-wrap {
  position: relative;
  margin-bottom: 12rpx;
  height: 32rpx;
  display: flex;
  align-items: center;
}

.hp-score-bar {
  position: relative;
  width: 100%;
  height: 16rpx;
  background: linear-gradient(90deg, #F5B5A4 0%, #F5B5A4 30%, #D8D8D8 30%, #D8D8D8 55%, #A8E6DA 55%, #A8E6DA 100%);
  border-radius: 8rpx;
  overflow: hidden;
}

.hp-score-bar-fill {
  position: absolute;
  left: 0;
  top: 0;
  height: 100%;
  background: linear-gradient(90deg, #3DB9F0 0%, #A8DEF5 100%);
  border-radius: 8rpx;
  opacity: 0.8;
}

.hp-score-ticks {
  position: absolute;
  top: -6rpx;
  left: 0;
  width: 100%;
  height: 28rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0 4rpx;
  box-sizing: border-box;
}

.hp-tick {
  width: 2rpx;
  height: 8rpx;
  background: #FFFFFF;
  display: block;
  margin: 0 2rpx;
}

.hp-tick:nth-child(1),
.hp-tick:nth-child(3),
.hp-tick:nth-child(5),
.hp-tick:nth-child(7),
.hp-tick:nth-child(9),
.hp-tick:nth-child(11) {
  height: 10rpx;
  opacity: 1;
}

.hp-score-marker {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 2rpx;
  height: 28rpx;
  background: #1f443c;
  border-radius: 1rpx;
}

.hp-score-marker::before {
  content: '';
  position: absolute;
  top: -6rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 18rpx;
  height: 18rpx;
  background: #FFFFFF;
  border: 2rpx solid #1f443c;
  border-radius: 50%;
}

.hp-score-labels {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0 8rpx;
  font-size: 22rpx;
  color: #7a8b96;
  font-weight: 500;
}

/* 分割线 */
.card-divider {
  height: 1rpx;
  background: linear-gradient(90deg, transparent 0%, #e8f0ec 20%, #e8f0ec 80%, transparent 100%);
  margin: 20rpx 0;
}

/* ★ 1. 心脏健康指数卡（顶部封面） */
.heart-index-cover {
  background: linear-gradient(135deg, #E8F4FB 0%, #F5FAFC 100%);
  border: 1rpx solid #D1E8F2;
  padding: 24rpx;
}

.index-cover-content {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.index-cover-left {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.index-cover-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #1f443c;
}

.index-cover-status {
  font-size: 20rpx;
  font-weight: 600;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
  width: fit-content;
  line-height: 1.2;
}

.index-cover-status.excellent {
  background: #E7F7EE;
  color: #0F6E56;
}

.index-cover-status.normal {
  background: #E7F7EE;
  color: #0F6E56;
}

.index-cover-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 4rpx;
}

.index-cover-score {
  font-size: 64rpx;
  font-weight: 700;
  color: #1a1a1a;
  line-height: 1;
}

.index-cover-label {
  font-size: 22rpx;
  color: #6a7a81;
}

.index-cover-progress {
  width: 100%;
  height: 120rpx;
  background: transparent;
  border-radius: 0;
  overflow: hidden;
  display: flex;
  align-items: center;
  padding: 12rpx 0 24rpx 0;
}

.index-gauge-mini {
  width: 100%;
  height: 120rpx;
}

.index-gauge-labels {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 8rpx 0 0 0;
  font-size: 22rpx;
  color: #7a8b96;
  font-weight: 500;
}

.gauge-label-left {
  text-align: left;
}

.gauge-label-center {
  text-align: center;
  flex: 1;
}

.gauge-label-right {
  text-align: right;
}

/* ★ 2. 心脏健康主卡（四指标） */
.heart-main-card {
  padding: 24rpx;
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.card-title {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.card-title-emoji {
  font-size: 28rpx;
  line-height: 1;
}

.card-title-text {
  font-size: 28rpx;
  font-weight: 700;
  color: #1f443c;
}

.card-collapse-btn {
  font-size: 22rpx;
  color: #1f8a6f;
  font-weight: 500;
}

.card-subtitle {
  font-size: 23rpx;
  color: #577970;
  line-height: 1.6;
  margin-bottom: 14rpx;
}

.metrics-grid-2x2 {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12rpx;
}

.metric-box {
  background: #f8fdf9;
  border: 1rpx solid #e3f0ec;
  border-radius: 12rpx;
  padding: 16rpx 12rpx;
}

.metric-name {
  font-size: 20rpx;
  color: #6a8b82;
  line-height: 1.4;
  margin-bottom: 6rpx;
}

.metric-number {
  font-size: 32rpx;
  font-weight: 700;
  color: #16443c;
  line-height: 1.2;
  margin-bottom: 4rpx;
}

.metric-note {
  font-size: 20rpx;
  color: #2e9f82;
  line-height: 1.2;
}

/* ★ 3. 心率数据卡 */
.heart-rate-card {
  padding: 24rpx;
}

.card-title-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.card-title-bold {
  font-size: 26rpx;
  font-weight: 700;
  color: #1f443c;
}

/* 状态药丸 */
.status-pill {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 4rpx 10rpx;
  border-radius: 4rpx;
  font-size: 18rpx;
  line-height: 1.2;
}

.status-pill.normal {
  background: #E7F7EE;
  color: #0F6E56;
}

.status-pill.warning {
  background: #FBF3DC;
  color: #8C6C12;
}

.status-pill.alert {
  background: #FCEFE9;
  color: #B5391A;
}

.pill-icon {
  font-size: 16rpx;
  line-height: 1;
}

.pill-text {
  font-weight: 500;
}

/* 图表区域 */
.chart-header {
  display: flex;
  justify-content: flex-end;
  align-items: center;
  margin-bottom: 12rpx;
}

.chart-range {
  display: flex;
  align-items: baseline;
  gap: 6rpx;
}

.range-number {
  font-size: 28rpx;
  font-weight: 700;
  color: #2e3035;
  line-height: 1;
}

.range-unit {
  font-size: 20rpx;
  color: #6a7a81;
  line-height: 1;
}

.trend-chart {
  width: 100%;
  height: 200rpx;
  background: #fff;
  border: 1rpx solid #e6f0ed;
  border-radius: 12rpx;
  margin: 12rpx 0;
}

.chart-axis-labels {
  display: flex;
  justify-content: space-between;
  font-size: 18rpx;
  color: #8ca6a0;
  padding: 8rpx 16rpx 0;
  margin-bottom: 16rpx;
}

/* 分析信息框 */
.analysis-box {
  border-radius: 12rpx;
  padding: 16rpx;
  line-height: 1.6;
}

.analysis-box.blue-variant {
  background: #F7FBFD;
  border-left: 3rpx solid #3DB9F0;
}

.analysis-box.orange-variant {
  background: #FBF8F3;
  border-left: 3rpx solid #D89B5C;
}

.analysis-headline {
  display: block;
  font-size: 22rpx;
  font-weight: 600;
  color: #1a1a1a;
  margin-bottom: 12rpx;
  line-height: 1.5;
}

.bold {
  font-weight: 700;
}

/* 个人基线药丸 */
.baseline-pill {
  display: inline;
  background: rgba(29, 158, 117, 0.12);
  color: #0F6E56;
  padding: 2rpx 6rpx;
  border-radius: 3rpx;
  font-size: 19rpx;
  font-weight: 600;
  margin: 0 2rpx;
  line-height: 1.2;
}

.analysis-list {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.analysis-bullet {
  display: flex;
  gap: 8rpx;
  align-items: flex-start;
}

.bullet-dot {
  color: #3DB9F0;
  font-size: 20rpx;
  line-height: 1.2;
  min-width: 16rpx;
}

.bullet-dot.orange {
  color: #D89B5C;
}

.bullet-text {
  font-size: 20rpx;
  color: #577970;
  line-height: 1.5;
  flex: 1;
}

/* 术语解释 */
.tooltip-term {
  border-bottom: 1px dashed #3DB9F0;
  cursor: help;
  position: relative;
}

.analysis-box.orange-variant .tooltip-term {
  border-bottom-color: #D89B5C;
}

/* ★ 4. 心动图卡 */
.ecg-card {
  padding: 24rpx;
}

.ecg-waveform {
  width: 100%;
  height: 180rpx;
  background: #fff;
  border: 1rpx solid #e6efec;
  border-radius: 12rpx;
  margin: 12rpx 0;
}

.ecg-axis-labels {
  display: flex;
  justify-content: space-between;
  font-size: 18rpx;
  color: #9cb2ac;
  padding: 8rpx 16rpx 0;
  margin-bottom: 16rpx;
}