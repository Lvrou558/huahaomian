  color: #2d6a4f;
  line-height: 1.6;
}

.wins-section {
  margin-top: 16rpx;
}

.wins-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
}

.win-card {
