}
.cycle-tags,.legend-row { margin-top:10rpx; display:flex; flex-wrap:wrap; gap:10rpx 14rpx; font-size:28rpx; color:#5a7e74; }
.metric-grid { display:grid; grid-template-columns:1fr 1fr; gap:10rpx; margin-top:10rpx; }
.metric-box { border:1rpx solid #e3f0ec; border-radius:12rpx; padding:14rpx; background:#fbfefd; }
.m-label { color:#6a8b82; font-size:28rpx; }
.m-value { margin-top:6rpx; color:#16443c; font-size:34rpx; font-weight:700; }
.m-level { margin-top:4rpx; color:#2e9f82; font-size:28rpx; }
.mini-title { margin-top:12rpx; font-size:28rpx; color:#21463e; font-weight:600; }
.movement-head { margin-top: 12rpx; display:flex; justify-content:space-between; align-items:flex-end; }
.movement-title-wrap { display:flex; align-items:center; gap:8rpx; }
.movement-title { font-size: 30rpx; line-height: 1.2; color:#3a6960; font-weight: 600; }
.movement-help { font-size: 28rpx; color:#8ba8a0; line-height: 1; }
.movement-count-wrap { display:flex; align-items:baseline; gap:6rpx; color:#2b3940; }
.movement-count-label { font-size: 34rpx; line-height: 1; font-weight: 500; color:#4a5a60; }
.movement-count-value { font-size: 58rpx; line-height: 0.95; font-weight: 500; color:#1e2d32; }
.movement-count-unit { font-size: 28rpx; line-height: 1; color:#55666d; }
.movement-chart { margin-top: 10rpx; background:#f8fcfb; border:1rpx solid #e6f0ed; border-radius:12rpx; }
.movement-axis { margin-top: 10rpx; font-size: 28rpx; color:#8ca6a0; }
.movement-legend { margin-top: 10rpx; display:flex; justify-content:center; gap:28rpx; color:#587169; font-size:28rpx; }
