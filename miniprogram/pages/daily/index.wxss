.recover-title,.dur-note { font-size:28rpx; color:#61837a; margin-top:8rpx; }
.recover-note,.dur-sub { font-size:28rpx; color:#2d9c7f; margin-top:6rpx; }
.score-center { width: 34%; text-align:center; }
