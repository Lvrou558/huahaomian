/* ========== 新设计样式 ========== */
.hero-top {
  display: flex;
  gap: 20rpx;
  align-items: stretch;
  margin-bottom: 20rpx;
}

.axis-panel {
  flex: 1;
  min-width: 0;
  min-height: 460rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.axis-chart-row {
  flex: 1;
  display: flex;
  align-items: stretch;
  gap: 8rpx;
}

.axis-ticks {
  width: 64rpx;
  padding-top: 14rpx;
  padding-bottom: 82rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.axis-tick {
  color: #7a8493;
  font-size: 20rpx;
  line-height: 1;
}

.axis-rows {
  flex: 1;
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  gap: 10rpx;
  align-items: stretch;
}

.axis-col {
  background: #f8fbff;
  border-radius: 12rpx;
  padding: 10rpx 8rpx 12rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: inset 0 0 0 1rpx #e5ecf5;
}

.axis-time-top {
  font-size: 24rpx;
  line-height: 1.2;
  color: #2f3a49;
  font-weight: 700;
}

.axis-time-bottom {
  margin-top: 2rpx;
  font-size: 22rpx;
  line-height: 1.2;
  color: #4f5c6c;
  font-weight: 600;
}

.axis-time-top.highlight,
.axis-time-bottom.highlight {
  color: #ab7334;
}

.axis-canvas {
  width: 100%;
  flex: 1;
  min-height: 248rpx;
  margin: 8rpx 0 6rpx;
}

.axis-day {
  margin-top: 6rpx;
  font-size: 20rpx;
  color: #7f8b99;
}

.axis-duration {
  margin-top: 2rpx;
  font-size: 26rpx;
  color: #334155;
  font-weight: 700;
}

.axis-duration.highlight {
  color: #ab7334;
}

/* 双环形进度条区域 */
.recovery-rings-section {
  width: 284rpx;
  flex-shrink: 0;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  min-height: 460rpx;
  padding: 4rpx 0;
}

.recovery-ring-box {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.recovery-ring {
  width: 136rpx;
  height: 136rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  box-shadow: 0 8rpx 18rpx rgba(43, 118, 95, 0.12);
}

.ring-inner {
  width: 102rpx;
  height: 102rpx;
  background: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-direction: column;
}

.ring-score {
  font-size: 42rpx;
  font-weight: 700;
  color: #1a1a1a;
  line-height: 1;
}

.ring-unit {
  font-size: 20rpx;
  color: #4cd964;
  margin-top: 4rpx;
}

.ring-label {
  font-size: 22rpx;
  color: #4f7269;
  margin-top: 10rpx;
}

.ring-status {
  font-size: 21rpx;
  color: #1f8a6f;
  margin-top: 4rpx;
  font-weight: 500;
}

/* 核心睡眠数据 */
.core-data-section {
  background: #f8fdf9;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.core-data-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 24rpx 40rpx;
}

.core-data-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.core-data-label {
  font-size: 26rpx;
  color: #666;
}

.core-data-value {
  font-size: 30rpx;
  color: #1a1a1a;
  font-weight: 600;
}

/* 评价区域 */
.evaluation-section {
  margin-top: 16rpx;
}

.evaluation-box {
  background: #f0f9f4;
  border-radius: 16rpx;
  padding: 24rpx 28rpx;
  border: 1rpx solid #d4edda;
}

.evaluation-text {
