.hero-second { margin-top:10rpx; width:40%; }
.hero-text { margin-top:10rpx; font-size:28rpx; color:#4f7269; line-height:1.55; }
.hero-note { margin-top:8rpx; font-size:28rpx; color:#2f9a7e; }
.hero-action { margin-top:12rpx; text-align:right; color:#1f8a6f; font-size:28rpx; }
.section-title { font-size:28rpx; font-weight:700; color:#1f443c; margin-bottom:8rpx; }
.fold-head { display:flex; justify-content:space-between; align-items:center; }
.fold-action { color:#1f8a6f; font-size:28rpx; }
.sub-title { font-size:24rpx; color:#577970; line-height:1.6; }
.time-row { display:flex; justify-content:space-between; color:#688b82; font-size:28rpx; margin-bottom:10rpx; }
.chart-lg { width:100%; height:220rpx; background:#f8fcfb; border-radius:12rpx; }
.chart-sm { width:100%; height:150rpx; background:#f8fcfb; border-radius:12rpx; margin-top:10rpx; }
.heart-chart { height:178rpx; }
.heart-trend-head {
