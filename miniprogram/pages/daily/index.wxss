  flex-direction: column;
  align-items: center;
  text-align: center;
}

.win-icon {
  font-size: 34rpx;
  line-height: 1;
}

.win-title {
  margin-top: 10rpx;
  color: #2c5f53;
  font-size: 28rpx;
  font-weight: 600;
}

.win-desc {
  margin-top: 10rpx;
  color: #5e7f76;
  font-size: 28rpx;
  line-height: 1.45;
}

.wins-share {
  margin-top: 14rpx;
  text-align: right;
  color: #1f8a6f;
  font-size: 28rpx;
}

.sleep-phase-card {
  background: linear-gradient(180deg, #09141a 0%, #050b0f 100%);
  border: 1rpx solid #13262f;
  box-shadow: inset 0 0 24rpx rgba(80, 154, 180, 0.08);
}

.phase-time-row {
  color: #9ab0b8;
}

.phase-chart {
  background: transparent;
  border-radius: 12rpx;
  height: 250rpx;
}

.phase-time-axis {
  margin-top: 8rpx;
  padding: 0 10rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.phase-time-tick {
  font-size: 28rpx;
  color: rgba(152, 178, 191, 0.78);
  line-height: 1;
}

.phase-legend-grid {
  margin-top: 10rpx;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12rpx 16rpx;
}

.phase-legend-item {
  display: flex;
  align-items: center;
  gap: 10rpx;
  color: #8ea3ab;
  transition: all 0.2s ease;
}

.phase-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  display: inline-block;
  box-shadow: 0 0 10rpx rgba(110, 185, 210, 0.35);
}

.phase-text {
  font-size: 28rpx;
  line-height: 1.4;
}
.phase-pct {
  font-size: 28rpx;
  font-weight: 700;
  color: #2cd2c4;
  margin-left: 4rpx;
}

.phase-legend-item.active {
  color: #e8f6ff;
}

.phase-legend-item.active .phase-dot {
  width: 18rpx;
  height: 18rpx;
  box-shadow: 0 0 16rpx rgba(165, 227, 255, 0.7);
}

.phase-legend-item.active .phase-text {
  font-weight: 700;
}

.phase-legend-item.inactive {
  opacity: 0.45;
}

.cycle-analysis-wrap {
  margin-top: 16rpx;
  padding-top: 14rpx;
  border-top: 1rpx solid rgba(109, 144, 162, 0.28);
}

.cycle-analysis-title {
  font-size: 28rpx;
  color: #d4e7f3;
  font-weight: 700;
  margin-bottom: 12rpx;
}

.cycle-item {
  background: rgba(13, 28, 38, 0.66);
  border: 1rpx solid rgba(76, 118, 141, 0.36);
  border-radius: 12rpx;
  padding: 12rpx;
}

.cycle-item + .cycle-item {
  margin-top: 10rpx;
}

.cycle-item-title {
  display: block;
  font-size: 28rpx;
  color: #f0f8ff;
  font-weight: 700;
  line-height: 1.45;
}

.cycle-segment-row {
  margin-top: 10rpx;
}

.cycle-segment-track {
  display: flex;
  width: 100%;
  height: 42rpx;
  overflow: hidden;
  border-radius: 10rpx;
  background: rgba(146, 179, 197, 0.14);
}

.cycle-segment {
  height: 100%;
  min-width: 26rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.cycle-segment-text {
  font-size: 28rpx;
  color: #ffffff;
  font-weight: 600;
  line-height: 1;
  white-space: nowrap;
}

.cycle-recovery-text {
  display: block;
  margin-top: 10rpx;
  font-size: 28rpx;
  color: #a8cae4;
  line-height: 1.5;
}

/* ========== 心脏健康优化设计 ========== */

/* ★ 心脏健康主卡（包含指数仪表 + 四指标） */
.heart-main-card {
  padding: 24rpx;
  background: #fff;
  border-radius: 18rpx;
  margin-bottom: 14rpx;
  box-shadow: 0 4rpx 14rpx rgba(37, 114, 93, 0.06);
}

/* 心脏健康指数仪表（CSS实现） */
.hp-score-inline {
  margin-bottom: 20rpx;
  padding: 20rpx;
  background: linear-gradient(135deg, #f8fafc 0%, #f1f5f9 100%);
  border-radius: 16rpx;
  border: 1rpx solid #e8f0f5;
}

.hp-score-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 14rpx;
}

.hp-score-label {
  font-size: 28rpx;
  font-weight: 700;
  color: #1f443c;
}

.hp-score-pill {
  font-size: 28rpx;
  font-weight: 600;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
  line-height: 1.2;
}

.hp-score-pill.ok {
  background: #E7F7EE;
  color: #0F6E56;
}

.hp-score-pill.normal {
  background: #FFF0E5;
  color: #D85A30;
}

.hp-score-display {
  display: flex;
  align-items: baseline;
  justify-content: center;
  gap: 6rpx;
  margin-bottom: 14rpx;
}

.hp-score-value {
  font-size: 64rpx;
  font-weight: 700;
  color: #1a1a1a;
  line-height: 1;
}

.hp-score-unit {
  font-size: 28rpx;
  color: #6a7a81;
}

.hp-score-bar-wrap {
  position: relative;
  margin-bottom: 12rpx;
  height: 32rpx;
  display: flex;
  align-items: center;
}

.hp-score-bar {
  position: relative;
  width: 100%;
  height: 16rpx;
  background: linear-gradient(90deg, #F5B5A4 0%, #F5B5A4 30%, #D8D8D8 30%, #D8D8D8 55%, #A8E6DA 55%, #A8E6DA 100%);
  border-radius: 8rpx;
  overflow: hidden;
}

.hp-score-bar-fill {
  position: absolute;
  left: 0;
  top: 0;
  height: 100%;
  background: linear-gradient(90deg, #3DB9F0 0%, #A8DEF5 100%);
  border-radius: 8rpx;
  opacity: 0.8;
}

.hp-score-ticks {
  position: absolute;
  top: -6rpx;
  left: 0;
  width: 100%;
  height: 28rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0 4rpx;
  box-sizing: border-box;
}

.hp-tick {
  width: 2rpx;
  height: 8rpx;
  background: #FFFFFF;
  display: block;
  margin: 0 2rpx;
}

.hp-tick:nth-child(1),
.hp-tick:nth-child(3),
.hp-tick:nth-child(5),
.hp-tick:nth-child(7),
.hp-tick:nth-child(9),
.hp-tick:nth-child(11) {
  height: 10rpx;
  opacity: 1;
}

.hp-score-marker {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 2rpx;
  height: 28rpx;
  background: #1f443c;
  border-radius: 1rpx;
}

.hp-score-marker::before {
  content: '';
  position: absolute;
  top: -6rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 18rpx;
  height: 18rpx;
  background: #FFFFFF;
  border: 2rpx solid #1f443c;
  border-radius: 50%;
}

.hp-score-labels {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0 8rpx;
  font-size: 28rpx;
  color: #7a8b96;
  font-weight: 500;
}

/* 分割线 */
.card-divider {
  height: 1rpx;
  background: linear-gradient(90deg, transparent 0%, #e8f0ec 20%, #e8f0ec 80%, transparent 100%);
  margin: 20rpx 0;
}

/* ★ 1. 心脏健康指数卡（顶部封面） */
.heart-index-cover {
  background: linear-gradient(135deg, #E8F4FB 0%, #F5FAFC 100%);
  border: 1rpx solid #D1E8F2;
  padding: 24rpx;
}

.index-cover-content {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.index-cover-left {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.index-cover-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1f443c;
}

.index-cover-status {
  font-size: 28rpx;
  font-weight: 600;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
  width: fit-content;
  line-height: 1.2;
}

.index-cover-status.excellent {
  background: #E7F7EE;
  color: #0F6E56;
}

.index-cover-status.normal {
  background: #E7F7EE;
  color: #0F6E56;
}

.index-cover-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 4rpx;
}

.index-cover-score {
  font-size: 64rpx;
  font-weight: 700;
  color: #1a1a1a;
  line-height: 1;
}

.index-cover-label {
  font-size: 28rpx;
  color: #6a7a81;
}

.index-cover-progress {
  width: 100%;
  height: 120rpx;
  background: transparent;
  border-radius: 0;
  overflow: hidden;
  display: flex;
  align-items: center;
  padding: 12rpx 0 24rpx 0;
}

.index-gauge-mini {
  width: 100%;
  height: 120rpx;
}

.index-gauge-labels {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 8rpx 0 0 0;
  font-size: 28rpx;
  color: #7a8b96;
  font-weight: 500;
}

.gauge-label-left {
  text-align: left;
}

.gauge-label-center {
  text-align: center;
  flex: 1;
}

.gauge-label-right {
  text-align: right;
}

/* ★ 2. 心脏健康主卡（四指标） */
.heart-main-card {
  padding: 24rpx;
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.card-title {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.card-title-emoji {
  font-size: 28rpx;
  line-height: 1;
}

.card-title-text {
  font-size: 28rpx;
  font-weight: 700;
  color: #1f443c;
}

.card-collapse-btn {
  font-size: 28rpx;
  color: #1f8a6f;
  font-weight: normal;
}

.card-subtitle {
  font-size: 24rpx;
  color: #577970;
  line-height: 1.6;
  margin-bottom: 14rpx;
}

.metrics-grid-2x2 {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12rpx;
}

.metric-box {
  background: #f8fdf9;
  border: 1rpx solid #e3f0ec;
  border-radius: 12rpx;
  padding: 16rpx 12rpx;
}

.metric-name {
  font-size: 24rpx;
  color: #6a8b82;
  line-height: 1.4;
  margin-bottom: 6rpx;
}

.metric-number {
  font-size: 32rpx;
  font-weight: 700;
  color: #16443c;
  line-height: 1.2;
  margin-bottom: 4rpx;
}

.metric-note {
  font-size: 20rpx;
  color: #2e9f82;
  line-height: 1.3;
  font-weight: normal;
}

/* ★ 3. 心率数据卡 */
.heart-rate-card {
  padding: 24rpx;
}

.card-title-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.card-title-bold {
  font-size: 28rpx;
  font-weight: 700;
  color: #1f443c;
}

/* 状态药丸 */
.status-pill {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 4rpx 10rpx;
  border-radius: 4rpx;
  font-size: 28rpx;
  line-height: 1.2;
}

.status-pill.normal {
  background: #E7F7EE;
  color: #0F6E56;
}

.status-pill.warning {
  background: #FBF3DC;
  color: #8C6C12;
}

.status-pill.alert {
  background: #FCEFE9;
  color: #B5391A;
}

.status-pill.orange {
  background: #fdecde;
  color: #b86518;
}

.pill-icon {
  font-size: 26rpx;
  line-height: 1;
}

.pill-text {
  font-weight: 500;
}

/* mini 状态胶囊（用在心脏副标题、呼吸渐变条标题旁） */
.status-pill.mini {
  padding: 2rpx 10rpx;
  font-size: 22rpx;
  border-radius: 6rpx;
}
.status-pill.mini .pill-icon { font-size: 22rpx; }

/* ===== 状态行（4 个折叠卡的"不展开就能看的状态摘要"） ===== */
.status-line {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 6rpx 4rpx;
  margin-top: 10rpx;
  font-size: 22rpx;
  line-height: 1.8;
}
.sl-label {
  color: #6a8b82;
  font-weight: 500;
  font-size: 22rpx;
}
.sl-value {
  color: #14443a;
  font-weight: 700;
  font-size: 22rpx;
  margin-left: 2rpx;
}
.sl-divider {
  color: #c5d4ce;
  margin: 0 6rpx;
  font-weight: 600;
}

/* 一行紧凑版状态行（睡眠健康卡专用：时长/深睡/翻身 3 项压成一行） */
.status-line.status-line--one-row {
  flex-wrap: nowrap;
  gap: 3rpx 3rpx;
  font-size: 21rpx;
  overflow: hidden;
}
.status-line--one-row .sl-label,
.status-line--one-row .sl-value {
  font-size: 21rpx;
  white-space: nowrap;
  flex-shrink: 0;
}
.status-line--one-row .sl-divider {
  margin: 0 4rpx;
}
.status-line--one-row .status-pill.mini {
  padding: 2rpx 8rpx;
  flex-shrink: 0;
}
.status-line--one-row .status-pill.mini .pill-text {
  font-size: 20rpx;
}
.status-line--one-row .status-pill.mini .pill-icon {
  font-size: 20rpx;
}

/* 心脏具体数据 副标题行（夜间心率 ✅未见异常 · 心动图 ✅未见异常） */
.card-subtitle-row {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-top: 8rpx;
}
.card-sub-label {
  font-size: 26rpx;
  color: #577970;
}
.card-sub-divider {
  color: #b5c4d0;
  margin: 0 4rpx;
}

/* 呼吸健康指数标题行（标题 + ✅优秀 胶囊 同一行） */
.breath-overview-gauge {
  margin-top: 12rpx;
}
.hi-compact-title-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 12rpx;
}
.hi-compact-title-row .hi-compact-title {
  margin-bottom: 0;
}

/* 图表区域 */
.chart-header {
  display: flex;
  justify-content: flex-end;
  align-items: center;
  margin-bottom: 12rpx;
}

.chart-range {
  display: flex;
  align-items: baseline;
  gap: 6rpx;
}

.range-number {
  font-size: 28rpx;
  font-weight: 700;
  color: #2e3035;
  line-height: 1;
}

.range-unit {
  font-size: 28rpx;
  color: #6a7a81;
  line-height: 1;
}

.trend-chart {
  width: 100%;
  height: 200rpx;
  background: #fff;
  border: 1rpx solid #e6f0ed;
  border-radius: 12rpx;
  margin: 12rpx 0;
}

.chart-axis-labels {
  display: flex;
  justify-content: space-between;
  font-size: 22rpx;
  color: #8ca6a0;
  padding: 8rpx 16rpx 0;
  margin-bottom: 16rpx;
}

/* 分析信息框 */
.analysis-box {
  border-radius: 12rpx;
  padding: 16rpx;
  line-height: 1.6;
}

.analysis-box.blue-variant {
  background: #F7FBFD;
  border-left: 3rpx solid #3DB9F0;
}

.analysis-box.orange-variant {
  background: #FBF8F3;
  border-left: 3rpx solid #D89B5C;
}

.analysis-headline {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #1a1a1a;
  margin-bottom: 12rpx;
  line-height: 1.5;
}

.bold {
  font-weight: 700;
}

/* 个人基线药丸 */
.baseline-pill {
  display: inline;
  background: rgba(29, 158, 117, 0.12);
  color: #0F6E56;
  padding: 2rpx 6rpx;
  border-radius: 3rpx;
  font-size: 28rpx;
  font-weight: 600;
  margin: 0 2rpx;
  line-height: 1.2;
}

.analysis-list {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.analysis-bullet {
  display: flex;
  gap: 8rpx;
  align-items: flex-start;
}

.bullet-dot {
  color: #3DB9F0;
  font-size: 28rpx;
  line-height: 1.2;
  min-width: 16rpx;
}

.bullet-dot.orange {
  color: #D89B5C;
}

.bullet-text {
  font-size: 24rpx;
  color: #577970;
  line-height: 1.5;
  flex: 1;
}

/* 术语解释 */
.tooltip-term {
  border-bottom: 1px dashed #3DB9F0;
  cursor: help;
  position: relative;
}

.analysis-box.orange-variant .tooltip-term {
  border-bottom-color: #D89B5C;
}

/* ★ 4. 心动图卡 */
.ecg-card {
  padding: 24rpx;
}

.ecg-waveform {
  width: 100%;
  height: 180rpx;
  background: #fff;
  border: 1rpx solid #e6efec;
  border-radius: 12rpx;
  margin: 12rpx 0;
}

.ecg-axis-labels {
  display: flex;
  justify-content: space-between;
  font-size: 28rpx;
  color: #9cb2ac;
  padding: 8rpx 16rpx 0;
  margin-bottom: 16rpx;
}

/* ========== 心脏健康指数紧凑条 ========== */
/* ===== 顶部"昨夜心脏总览"专属样式 ===== */
.heart-overview-card {
  background: linear-gradient(165deg, #fff5f5 0%, #ffffff 50%, #f5fbf9 100%);
  border: 1rpx solid #ffe1e1;
}
/* 心脏健康指数渐变条（顶部） */
.heart-overview-gauge {
  margin-top: 4rpx;
  margin-bottom: 16rpx;
  padding-bottom: 14rpx;
  border-bottom: 1rpx solid #eef4f1;
}
.heart-overview-gauge .hi-compact-title {
  font-size: 26rpx;
  font-weight: 700;
  color: #1a2c24;
  margin-bottom: 12rpx;
}
/* 4 项核心指标（移至心脏具体数据顶部） */
.heart-detail-metrics {
  margin: 16rpx 0 14rpx;
}
/* 文字总概（底部） */
.heart-overview-text {
  font-size: 26rpx;
  color: #2e4a44;
  line-height: 1.7;
  padding: 14rpx 4rpx 4rpx;
  border-top: 1rpx dashed #eef4f1;
}

/* ===== 今日心脏疾病风险（总览核心区块，字体加大以突出） ===== */
.cardiac-risk-section {
  margin-top: 18rpx;
  padding-top: 16rpx;
  border-top: 1rpx dashed #eef4f1;
}

/* 免责说明（顶部，让用户清楚这是风险评估而非诊断） */
.cr-disclaimer {
  display: flex;
  align-items: flex-start;
  gap: 6rpx;
  padding: 10rpx 14rpx;
  margin-bottom: 12rpx;
  background: #f3f8f6;
  border-radius: 10rpx;
  border-left: 3rpx solid #c5d4ce;
}
.cr-disc-icon {
  font-size: 22rpx;
  flex-shrink: 0;
  line-height: 1.5;
}
.cr-disc-text {
  font-size: 22rpx;
  color: #5a6f6a;
  line-height: 1.5;
  flex: 1;
}
.cardiac-risk-title {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 14rpx;
  padding: 0 4rpx;
}
.cr-title-icon { font-size: 34rpx; }
.cr-title-text {
  font-size: 32rpx;
  font-weight: 800;
  color: #14443a;
  letter-spacing: 0.5rpx;
  flex: 1;
}
.cr-title-count {
  font-size: 22rpx;
  font-weight: 700;
  color: #b86518;
  background: #fdecde;
  padding: 3rpx 14rpx;
  border-radius: 999rpx;
}

/* 风险卡（核心区块，加大间距和左侧色带） */
.cardiac-risk-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 20rpx 22rpx;
  margin-bottom: 12rpx;
  border-left: 8rpx solid #d9b35c;
  box-shadow: 0 3rpx 12rpx rgba(0,0,0,0.05);
}
/* 轻度风险 → 黄色 */
.cardiac-risk-card.warning { border-left-color: #d9b35c; background: #fffbf3; }
/* 中度风险 → 橙色 */
.cardiac-risk-card.orange { border-left-color: #d4923a; background: #fff7ef; }
/* 重度风险 → 红色 */
.cardiac-risk-card.alert { border-left-color: #c43a2c; background: #fff1ee; }
.cardiac-risk-card.info { border-left-color: #4caf84; background: #f5fdf8; }
/* 正常项目（聚合卡）→ 绿色 */
.cardiac-risk-card.normal { border-left-color: #4caf84; background: #f5fdf8; }

/* 正常项目折叠分割线（与 web 端 cr-normal-divider 同步） */
.cr-normal-divider {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 16rpx 0;
  margin: 8rpx 0;
  border-top: 1rpx dashed #d0dcd6;
  font-size: 22rpx;
  color: #8a9baa;
  font-weight: 500;
}
.cr-normal-divider:active { color: #1F8A6F; }
.cardiac-risk-card.normal-group {
  border-left-color: #4caf84;
  background: #f5fdf8;
}
.cardiac-risk-card.normal-group .cr-title { color: #14443a; }
.cardiac-risk-card.normal-group .cr-summary { color: #2e6a52; }
.cardiac-risk-card.normal-group .cr-body { border-top-color: #c8e8d6; }
/* 聚合卡内每个绿色子项目（更紧凑展示） */
.normal-sub-item {
  background: #fff;
  border-radius: 12rpx;
  padding: 14rpx 16rpx;
  margin-top: 10rpx;
  border: 1rpx solid #d8ede1;
}
.normal-sub-item:first-child { margin-top: 0; }
.ng-head {
  display: flex;
  flex-direction: column;
  gap: 3rpx;
  margin-bottom: 8rpx;
}
.ng-title-row {
  display: flex;
  align-items: center;
  gap: 6rpx;
  flex-wrap: wrap;
  margin-bottom: 2rpx;
}
.ng-title {
  font-size: 30rpx;
  font-weight: 800;
  color: #14443a;
  line-height: 1.35;
}
.ng-summary {
  font-size: 24rpx;
  color: #5a6f6a;
  line-height: 1.4;
}

/* 重度风险标题强调红色 */
.cardiac-risk-card.alert .cr-title { color: #8c241a; }
.cardiac-risk-card.alert .cr-summary { color: #a14530; font-weight: 600; }

.cr-hover { opacity: 0.7; }

.cr-head {
  display: flex;
  align-items: center;
  gap: 14rpx;
}
.cr-icon { font-size: 40rpx; flex-shrink: 0; }
.cr-text {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}
.cr-title-row {
  display: flex;
  align-items: center;
  gap: 8rpx;
  flex-wrap: wrap;
}
.cr-title {
  font-size: 30rpx;
  font-weight: 800;
  color: #14443a;
  line-height: 1.35;
}
/* 急 / 慢 / 急·慢 徽章 */
.cr-ac-badge {
  display: inline-block;
  padding: 2rpx 10rpx;
  border-radius: 999rpx;
  font-size: 18rpx;
  font-weight: 700;
  line-height: 1.5;
  flex-shrink: 0;
}
/* 急性 → 暖红色 */
.cr-ac-acute {
  background: #fbe2dd;
  color: #b54a3a;
  border: 1rpx solid #f0c5bd;
}
/* 慢性 → 冷蓝色 */
.cr-ac-chronic {
  background: #dde7f3;
  color: #3a5a8a;
  border: 1rpx solid #c4d4e7;
}
/* 急·慢 兼具 → 中性紫 */
.cr-ac-both {
  background: #ece1f4;
  color: #6a3aa0;
  border: 1rpx solid #d4c1e3;
}
.cr-summary {
  font-size: 24rpx;
  color: #5a6f6a;
  font-weight: 500;
  line-height: 1.4;
}
.cr-arrow {
  font-size: 22rpx;
  color: #9aa8a2;
  font-weight: 600;
  margin-left: 6rpx;
}

/* 关联疾病标签行 */
.cr-disease-tags {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 16rpx;
  padding-bottom: 14rpx;
  border-bottom: 1rpx dashed #e8e4d8;
}
.cr-disease-tags-label {
  font-size: 22rpx;
  color: #7a8c84;
  font-weight: 600;
}
.cr-disease-tag {
  display: inline-block;
  font-size: 20rpx;
  color: #8c6c12;
  background: #fbf3dc;
  padding: 3rpx 10rpx;
  border-radius: 6rpx;
  font-weight: 600;
  line-height: 1.4;
}
.cardiac-risk-card.alert .cr-disease-tag {
  color: #8c241a;
  background: #fce4de;
}
.cardiac-risk-card.info .cr-disease-tag {
  color: #1d6e54;
  background: #e6f5ee;
}

/* 着色判定规则文本块 */
.cr-coloring-text {
  font-size: 22rpx;
  color: #4a5a63;
  line-height: 1.8;
  white-space: pre-line;
  background: #fafcfb;
  padding: 12rpx 16rpx;
  border-radius: 8rpx;
  border: 1rpx solid #eef2f0;
}

/* 展开后 */
.cr-body {
  margin-top: 12rpx;
  padding-top: 12rpx;
  border-top: 1rpx dashed #ede1c8;
}
.cardiac-risk-card.orange .cr-body { border-top-color: #ecd9c2; }
.cardiac-risk-card.alert .cr-body { border-top-color: #f0d2cb; }
.cardiac-risk-card.info .cr-body { border-top-color: #c8e8d6; }

.cr-detail-block {
  margin-bottom: 12rpx;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}
.cr-detail-block:last-child { margin-bottom: 0; }
.cr-detail-label {
  font-size: 24rpx;
  font-weight: 700;
  color: #14443a;
}
.cr-detail-text {
  font-size: 24rpx;
  color: #4a5a63;
  line-height: 1.65;
}
.cr-suggestion {
  font-size: 24rpx;
  color: #2e6a52;
  line-height: 1.7;
  padding: 2rpx 0;
}

/* 数据依据：三列布局（标签 / 值 / 参考），右侧用色带表达 status */
.cr-data-list {
  margin-top: 4rpx;
  border: 1rpx solid rgba(217,179,92,0.25);
  border-radius: 10rpx;
  overflow: hidden;
  background: rgba(255, 251, 240, 0.6);
}
.cardiac-risk-card.info .cr-data-list {
  border-color: rgba(76, 175, 132, 0.25);
  background: rgba(245, 253, 248, 0.6);
}
.cardiac-risk-card.alert .cr-data-list {
  border-color: rgba(196,58,44,0.25);
  background: rgba(255, 241, 238, 0.6);
}
.cr-data-row {
  display: flex;
  align-items: center;
  padding: 10rpx 14rpx;
  font-size: 21rpx;
  line-height: 1.4;
  border-bottom: 1rpx solid rgba(217,179,92,0.15);
}
.cr-data-row:last-child { border-bottom: none; }
.cardiac-risk-card.info .cr-data-row {
  border-bottom-color: rgba(76, 175, 132, 0.15);
}
.cr-data-label {
  flex: 0 0 38%;
  color: #5a6a63;
}
.cr-data-value {
  flex: 0 0 24%;
  font-weight: 700;
  color: #14443a;
}
.cr-data-ref {
  flex: 1;
  text-align: right;
  font-size: 20rpx;
  color: #8a978f;
}
/* 数据状态：low/high/border = 偏离, ok = 正常 */
.cr-data-row.low .cr-data-value,
.cr-data-row.high .cr-data-value,
.cr-data-row.border .cr-data-value {
  color: #b86a18;
}
.cardiac-risk-card.alert .cr-data-row.low .cr-data-value,
.cardiac-risk-card.alert .cr-data-row.high .cr-data-value,
.cardiac-risk-card.alert .cr-data-row.border .cr-data-value {
  color: #a14530;
}
.cr-data-row.ok .cr-data-value { color: #1f8a6f; }

.cr-link {
  margin-top: 8rpx;
  padding: 10rpx 14rpx;
  background: rgba(31, 138, 111, 0.08);
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 6rpx;
  font-size: 22rpx;
  color: #1f8a6f;
  font-weight: 600;
}
.cr-link-arrow { font-size: 22rpx; }
.cr-link:active { opacity: 0.6; }

/* 无风险时的积极状态 */
.cr-no-risk {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 16rpx 14rpx;
  background: #ecfaf3;
  border: 1rpx solid #c8e8d6;
  border-radius: 12rpx;
  margin-top: 14rpx;
}
.cr-no-risk-icon { font-size: 26rpx; }
.cr-no-risk-text {
  font-size: 22rpx;
  color: #1d6e54;
  font-weight: 600;
}
/* 心脏具体数据内的心脏健康指数（移至折叠区顶部） */
.heart-detail-gauge {
  margin-top: 4rpx;
  margin-bottom: 18rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #eef4f1;
}

/* "心脏具体数据" 折叠卡的"展开"按钮 — 与睡眠卡 fold-action 完全一致 */
.heart-main-card .card-collapse-btn {
  color: #1f8a6f;
  font-weight: normal;
}

.hi-compact {
  margin-top: 14rpx;
  margin-bottom: 6rpx;
}

.hi-compact-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #1f443c;
  margin-bottom: 12rpx;
}

.hi-gauge-wrap {
  position: relative;
  height: 48rpx;
  padding: 0 4rpx;
  background: #fafcfb;
  border-radius: 14rpx;
  border: 1rpx solid #eef2f0;
}

.hi-bar {
  position: absolute;
  left: 12rpx;
  right: 12rpx;
  top: 50%;
  transform: translateY(-50%);
  height: 26rpx;
  border-radius: 13rpx;
  background: linear-gradient(90deg, #ef9a9a 0%, #f4c5bd 22%, #f6e1da 42%, #f0ece9 50%, #d4e2ea 58%, #b6d4e6 78%, #8ec2dc 100%);
  display: flex;
  align-items: center;
  justify-content: space-around;
  padding: 0 8rpx;
  box-sizing: border-box;
  overflow: hidden;
}

.hi-tick {
  width: 2rpx;
  height: 46%;
  background: rgba(255, 255, 255, 0.85);
  display: block;
  border-radius: 1rpx;
}

.hi-pointer {
  position: absolute;
  top: 2rpx;
  bottom: 2rpx;
  transform: translateX(-50%);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 2;
}

.hi-ptr-line {
  width: 2rpx;
  height: 100%;
  background: #2c3a3a;
  border-radius: 1rpx;
}

.hi-ptr-circle {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 22rpx;
  height: 22rpx;
  background: #fff;
  border: 2rpx solid #2c3a3a;
  border-radius: 50%;
}

/* 呼吸健康指数 + 呼吸暂停统计 */
.breath-gauge { margin-top: 4rpx; margin-bottom: 18rpx; }

.breath-stats-row {
  display: flex;
  align-items: stretch;
  justify-content: space-between;
  background: #fafcfb;
  border: 1rpx solid #eef2f0;
  border-radius: 12rpx;
  padding: 18rpx 8rpx;
  margin-bottom: 14rpx;
}
.breath-stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}
.breath-stat-item.highlight .breath-stat-num { color: #58c7f5; }
.breath-stat-num {
  font-size: 38rpx;
  font-weight: 700;
  color: #2e3035;
  line-height: 1;
  display: flex;
  align-items: baseline;
  gap: 4rpx;
}
.breath-stat-unit {
  font-size: 28rpx;
  font-weight: 600;
  color: inherit;
  margin-left: 2rpx;
}
.breath-stat-label {
  margin-top: 10rpx;
  font-size: 28rpx;
  color: #6a7a81;
}
.breath-stat-divider {
  width: 1rpx;
  background: #e6ece9;
  margin: 6rpx 0;
}

.hi-legend {
  display: flex;
  justify-content: space-between;
  margin-top: 8rpx;
  padding: 0 4rpx;
  font-size: 22rpx;
  color: #8a99a3;
}
/* ===== 声音监测 8 项指标 2 列网格 ===== */
.sound-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
}
.sound-box {
  background: #fafffd;
  border: 1rpx solid #e6f0ea;
  border-radius: 16rpx;
  padding: 18rpx 20rpx;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  position: relative;
}
.sound-box.tappable {
  background: linear-gradient(135deg, #f0faf5 0%, #ffffff 80%);
  border-color: #c8e8d6;
}
.sb-label {
  font-size: 24rpx;
  color: #4a6a60;
  font-weight: 500;
}
.sb-value {
  font-size: 38rpx;
  font-weight: 800;
  color: #14443a;
  line-height: 1.1;
}
.sb-level {
  font-size: 22rpx;
  color: #1f8a6f;
  font-weight: 600;
}
.sb-hint {
  margin-top: 6rpx;
  font-size: 20rpx;
  color: #1f8a6f;
  font-weight: 600;
  letter-spacing: 0.2rpx;
}

/* ===== 声音录音弹窗 ===== */
.sound-modal {
  position: fixed;
  inset: 0;
  z-index: 2000;
  background: rgba(20, 30, 26, 0.55);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 40rpx;
}
.sound-modal-card {
  width: 100%;
  max-width: 640rpx;
  background: #ffffff;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.25);
}
.sm-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 28rpx 16rpx;
  border-bottom: 1rpx solid #eef4f1;
}
.sm-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #14443a;
  flex: 1;
}
.sm-close {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: #f0f4f1;
  color: #6a7a81;
  text-align: center;
  line-height: 56rpx;
  font-size: 28rpx;
  font-weight: 600;
}
.sm-body {
  padding: 8rpx 28rpx 28rpx;
  max-height: 60vh;
  overflow-y: auto;
}
.sm-empty {
  text-align: center;
  padding: 60rpx 0;
  font-size: 28rpx;
  color: #9aa8a2;
}
.sm-rec-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 18rpx 0;
  border-bottom: 1rpx solid #f3f7f5;
}
.sm-rec-item:last-child { border-bottom: none; }
.sm-rec-left {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}
.sm-rec-time {
  font-size: 30rpx;
  font-weight: 700;
  color: #14443a;
}
.sm-rec-label {
  font-size: 28rpx;
  color: #6a7a81;
}
.sm-rec-play {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: #1f8a6f;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 12rpx rgba(31, 138, 111, 0.3);
}
.sm-rec-play-icon {
  color: #ffffff;
  font-size: 28rpx;
  margin-left: 4rpx;
}

/* ===== 声音监测示例数据横幅 ===== */
.sound-demo-banner {
  margin: 0 0 14rpx;
  padding: 20rpx 24rpx;
  background: linear-gradient(135deg, #fff9e8 0%, #fef3d3 100%);
  border: 1rpx solid #f0e5cf;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 4rpx 14rpx rgba(180, 130, 30, 0.1);
}
.sdb-left {
  display: flex;
  align-items: center;
  gap: 14rpx;
  flex: 1;
}
.sdb-icon { font-size: 38rpx; line-height: 1; }
.sdb-text { display: flex; flex-direction: column; gap: 4rpx; }
.sdb-title { font-size: 28rpx; font-weight: 700; color: #5a3a0e; }
.sdb-sub { font-size: 28rpx; color: #8a6a3a; }
.sdb-cta {
  background: linear-gradient(135deg, #d4a548, #b3851e);
  color: #fff;
  font-size: 28rpx;
  font-weight: 700;
  padding: 10rpx 20rpx;
  border-radius: 999rpx;
  white-space: nowrap;
  margin-left: 14rpx;
}

/* ===== 付费弹窗（与长期页共用） ===== */
.pw-mask {
  position: fixed;
  inset: 0;
  background: rgba(20, 30, 26, 0.6);
  z-index: 5000;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 40rpx;
}
.pw-card {
  width: 100%;
  max-width: 640rpx;
  background: #ffffff;
  border-radius: 22rpx;
  overflow: hidden;
  box-shadow: 0 20rpx 50rpx rgba(0, 0, 0, 0.25);
}
.pw-header {
  background: linear-gradient(135deg, #f6e8c3 0%, #f3d990 100%);
  padding: 36rpx 22rpx 28rpx;
  text-align: center;
}
.pw-icon-circle {
  width: 110rpx; height: 110rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #fff, #fef3d3);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 58rpx;
  margin: 0 auto 14rpx;
  box-shadow: 0 8rpx 20rpx rgba(180, 130, 30, 0.22);
}
.pw-title { font-size: 34rpx; font-weight: 800; color: #5a3a0e; margin-bottom: 6rpx; }
.pw-sub { font-size: 28rpx; color: #8a6a3a; }
.pw-body { padding: 20rpx 26rpx 18rpx; }
.pw-feature {
  display: flex;
  align-items: flex-start;
  gap: 14rpx;
  padding: 14rpx 0;
  border-bottom: 1rpx dashed #f0e5cf;
}
.pw-feature:last-of-type { border-bottom: none; }
.pw-feature-icon {
  width: 56rpx; height: 56rpx;
  border-radius: 14rpx;
  background: #faf3e0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  flex-shrink: 0;
}
.pw-feature-text { flex: 1; }
.pw-feature-title { font-size: 28rpx; font-weight: 700; color: #1a2c24; display: block; margin-bottom: 4rpx; }
.pw-feature-sub { font-size: 28rpx; color: #7a8a83; line-height: 1.5; display: block; }
.pw-price-row {
  margin-top: 22rpx;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 14rpx;
}
.pw-price-card {
  background: #fafffd;
  border: 2rpx solid #eef4f1;
  border-radius: 16rpx;
  padding: 24rpx 14rpx 18rpx;
  text-align: center;
  position: relative;
}
.pw-price-card.recommended {
  border-color: #d4a548;
  background: linear-gradient(135deg, #fff9e8 0%, #fff 100%);
  box-shadow: 0 8rpx 18rpx rgba(180, 130, 30, 0.18);
}
.pw-price-badge {
  position: absolute;
  top: -12rpx; left: 50%;
  transform: translateX(-50%);
  background: linear-gradient(135deg, #d4a548, #b3851e);
  color: #fff;
  font-size: 28rpx;
  font-weight: 700;
  padding: 4rpx 14rpx;
  border-radius: 999rpx;
  box-shadow: 0 4rpx 8rpx rgba(180, 130, 30, 0.3);
  white-space: nowrap;
}
.pw-price-name { font-size: 28rpx; color: #7a8a83; display: block; margin-bottom: 6rpx; }
.pw-price-num { font-size: 40rpx; font-weight: 800; color: #1a2c24; display: block; line-height: 1.1; }
.pw-price-card.recommended .pw-price-num { color: #c0850f; }
.pw-price-orig {
  font-size: 28rpx;
  color: #b0aea2;
  text-decoration: line-through;
  display: block;
  margin-top: 4rpx;
  min-height: 26rpx;
}
.pw-price-equiv { font-size: 28rpx; color: #1f8a6f; font-weight: 600; display: block; margin-top: 2rpx; }
.pw-actions {
  padding: 8rpx 26rpx 26rpx;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}
.pw-btn-primary {
  background: linear-gradient(135deg, #d4a548, #b3851e);
  color: #fff;
  text-align: center;
  padding: 22rpx;
  border-radius: 999rpx;
  font-size: 28rpx;
  font-weight: 700;
  box-shadow: 0 8rpx 18rpx rgba(180, 130, 30, 0.36);
}
.pw-btn-ghost { text-align: center; padding: 12rpx; font-size: 28rpx; color: #7a8a83; }
