}

.cycle-segment {
  height: 100%;
  min-width: 26rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.cycle-segment-text {
  font-size: 18rpx;
  color: #ffffff;
  font-weight: 600;
  line-height: 1;
  white-space: nowrap;
}

.cycle-recovery-text {
  display: block;
  margin-top: 10rpx;
  font-size: 21rpx;
  color: #a8cae4;
  line-height: 1.5;
}

/* ========== 心脏健康优化设计 ========== */

