}

.win-icon {
  font-size: 34rpx;
  line-height: 1;
}

.win-title {
  margin-top: 10rpx;
  color: #2c5f53;
  font-size: 24rpx;
  font-weight: 600;
}

.win-desc {
  margin-top: 10rpx;
  color: #5e7f76;
  font-size: 21rpx;
  line-height: 1.45;
}

.wins-share {
  margin-top: 14rpx;
  text-align: right;
  color: #1f8a6f;
  font-size: 23rpx;
}

.sleep-phase-card {
  background: linear-gradient(180deg, #09141a 0%, #050b0f 100%);
  border: 1rpx solid #13262f;
  box-shadow: inset 0 0 24rpx rgba(80, 154, 180, 0.08);
}

.phase-time-row {
  color: #9ab0b8;
}

.phase-chart {
  background: transparent;
  border-radius: 12rpx;
  height: 250rpx;
}

.phase-time-axis {
  margin-top: 8rpx;
  padding: 0 10rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.phase-time-tick {
  font-size: 18rpx;
  color: rgba(152, 178, 191, 0.78);
  line-height: 1;
}

.phase-legend-grid {
  margin-top: 10rpx;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12rpx 16rpx;
}

.phase-legend-item {
  display: flex;
  align-items: center;
  gap: 10rpx;
  color: #8ea3ab;
  transition: all 0.2s ease;
}

.phase-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  display: inline-block;
  box-shadow: 0 0 10rpx rgba(110, 185, 210, 0.35);
}

.phase-text {
  font-size: 22rpx;
  line-height: 1.4;
}

.phase-legend-item.active {
  color: #e8f6ff;
}

.phase-legend-item.active .phase-dot {
  width: 18rpx;
  height: 18rpx;
  box-shadow: 0 0 16rpx rgba(165, 227, 255, 0.7);
}

.phase-legend-item.active .phase-text {
  font-weight: 700;
}

.phase-legend-item.inactive {
  opacity: 0.45;
}

.cycle-analysis-wrap {
  margin-top: 16rpx;
  padding-top: 14rpx;
  border-top: 1rpx solid rgba(109, 144, 162, 0.28);
}

.cycle-analysis-title {
  font-size: 24rpx;
  color: #d4e7f3;
  font-weight: 700;
  margin-bottom: 12rpx;
}

.cycle-item {
  background: rgba(13, 28, 38, 0.66);
  border: 1rpx solid rgba(76, 118, 141, 0.36);
  border-radius: 12rpx;
  padding: 12rpx;
}

.cycle-item + .cycle-item {
