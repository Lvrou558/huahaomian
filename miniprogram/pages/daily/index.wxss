.axis { margin-top:8rpx; font-size:20rpx; color:#8ca6a0; letter-spacing:1rpx; }
.trend-axis { margin-top:8rpx; display:flex; justify-content:space-between; font-size:18rpx; color:#8ca6a0; letter-spacing:0; }
.ecg-head { margin-top: 16rpx; }
.ecg-title-wrap { display:flex; align-items:center; gap:12rpx; }
.ecg-title { font-size: 30rpx; font-weight: 700; color:#1f443c; }
.ecg-ai-tag { font-size:20rpx; color:#3b89d9; border:1rpx solid #9ed1ff; background:#f3f9ff; border-radius:999rpx; padding:4rpx 12rpx; }
.ecg-chart { margin-top:10rpx; width:100%; height:190rpx; background:#fff; border:1rpx solid #e6efec; border-radius:12rpx; }
.ecg-axis { margin-top:8rpx; display:flex; justify-content:space-between; color:#9cb2ac; font-size:18rpx; }
.ecg-index-title { margin-top:18rpx; font-size:30rpx; font-weight:700; color:#1f443c; }
.heart-index-gauge { margin-top:10rpx; width:100%; height:76rpx; background:#fff; border:1rpx solid #e6efec; border-radius:12rpx; }
