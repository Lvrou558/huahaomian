.movement-dot { width: 32rpx; height: 5rpx; border-radius: 999rpx; display:inline-block; }
.movement-dot-activity { background:#4fc3d8; }
.movement-dot-turnover { background:#c95b77; }
.axis { margin-top:8rpx; font-size:28rpx; color:#8ca6a0; letter-spacing:1rpx; }
.trend-axis { margin-top:8rpx; display:flex; justify-content:space-between; font-size:28rpx; color:#8ca6a0; letter-spacing:0; }
.ecg-head { margin-top: 16rpx; }
.ecg-title-wrap { display:flex; align-items:center; gap:12rpx; }
.ecg-title { font-size: 30rpx; font-weight: 700; color:#1f443c; }
.ecg-ai-tag { font-size:28rpx; color:#3b89d9; border:1rpx solid #9ed1ff; background:#f3f9ff; border-radius:999rpx; padding:4rpx 12rpx; }
.ecg-chart { margin-top:10rpx; width:100%; height:190rpx; background:#fff; border:1rpx solid #e6efec; border-radius:12rpx; }
.ecg-axis { margin-top:8rpx; display:flex; justify-content:space-between; color:#9cb2ac; font-size:28rpx; }
.ecg-index-title { margin-top:18rpx; font-size:30rpx; font-weight:700; color:#1f443c; }
.heart-index-gauge { margin-top:10rpx; width:100%; height:76rpx; background:#fff; border:1rpx solid #e6efec; border-radius:12rpx; }
.heart-index-labels { margin-top:8rpx; display:flex; justify-content:space-between; color:#6f8f87; font-size:28rpx; padding:0 8rpx; }
.expand-link { margin-top:12rpx; text-align:right; color:#1f8a6f; font-size:28rpx; }
.sound-collapse-row { display:flex; justify-content:flex-end; margin: 4rpx 6rpx 12rpx; }
.improve-card { position: relative; }
.sound-collapse-row.in-improve-card { margin: 10rpx 0 0; justify-content: flex-end; }
.sound-collapse-btn { width: 48rpx; height: 34rpx; border-radius: 8rpx; border:1rpx solid #cfe4dd; background:#e9f5f1; display:flex; align-items:center; justify-content:center; box-shadow:0 2rpx 5rpx rgba(46,107,88,0.10); }
.sound-collapse-icon { color:#3f6d61; font-size:28rpx; line-height:1; transform: translateY(-1rpx) rotate(0deg); transition: transform .2s ease, color .2s ease; }
.sound-collapse-icon.expanded { transform: translateY(-1rpx) rotate(180deg); }
.btn-row { margin-top:12rpx; display:flex; gap:10rpx; }
.btn { flex:1; border-radius:999rpx; font-size:28rpx; padding:0; line-height:72rpx; height:72rpx; }
.btn.primary { background:#1f8a6f; color:#fff; }
.btn.ghost { background:#edf8f4; color:#1f8a6f; border:1rpx solid #cfe8df; }
.tip { margin-top:8rpx; color:#7c9790; font-size:28rpx; line-height:1.5; }
.mt12 { margin-top:12rpx; }
.list-item { margin-top:8rpx; font-size:28rpx; color:#4f7269; line-height:1.58; }
.end-card { padding: 22rpx 20rpx 24rpx; }
.risk-item { margin-top: 10rpx; font-size: 28rpx; color:#476a62; line-height: 1.66; }
.advice-item { margin-top: 14rpx; font-size: 28rpx; color:#325c52; font-weight: 600; line-height: 1.5; }
.advice-sub { margin-top: 6rpx; margin-left: 8rpx; font-size: 28rpx; color:#51756d; line-height: 1.62; }
.link-row { margin-top:12rpx; display:flex; flex-direction:column; gap:8rpx; color:#1f8a6f; font-size:28rpx; }

/* ========== 新设计样式 ========== */
.hero-top {
  display: flex;
  gap: 20rpx;
  align-items: stretch;
  margin-bottom: 20rpx;
}

.axis-panel {
  flex: 1;
  min-width: 0;
  min-height: 460rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.axis-chart-row {
  flex: 1;
  display: flex;
  align-items: stretch;
  gap: 8rpx;
}

.axis-ticks {
  width: 64rpx;
  padding-top: 14rpx;
  padding-bottom: 82rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.axis-tick {
  color: #7a8493;
  font-size: 28rpx;
  line-height: 1;
}

.axis-rows {
  flex: 1;
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  gap: 10rpx;
  align-items: stretch;
}

.axis-col {
  background: #f8fbff;
  border-radius: 12rpx;
  padding: 10rpx 8rpx 12rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: inset 0 0 0 1rpx #e5ecf5;
}

.axis-time-top {
  font-size: 28rpx;
  line-height: 1.2;
  color: #2f3a49;
  font-weight: 700;
}

.axis-time-bottom {
  margin-top: 2rpx;
  font-size: 28rpx;
  line-height: 1.2;
  color: #4f5c6c;
  font-weight: 600;
}

.axis-time-top.highlight,
.axis-time-bottom.highlight {
  color: #ab7334;
}

.axis-canvas {
  width: 100%;
  flex: 1;
  min-height: 248rpx;
  margin: 8rpx 0 6rpx;
}

.axis-day {
  margin-top: 6rpx;
  font-size: 28rpx;
  color: #7f8b99;
}

.axis-duration {
  margin-top: 2rpx;
  font-size: 28rpx;
  color: #334155;
  font-weight: 700;
}

.axis-duration.highlight {
  color: #ab7334;
}

/* 双环形进度条区域 */
.recovery-rings-section {
  width: 284rpx;
  flex-shrink: 0;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  min-height: 460rpx;
  padding: 4rpx 0;
}

.recovery-ring-box {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.recovery-ring {
  width: 136rpx;
  height: 136rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  box-shadow: 0 8rpx 18rpx rgba(43, 118, 95, 0.12);
}

.ring-inner {
  width: 102rpx;
  height: 102rpx;
  background: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-direction: column;
}

.ring-score {
  font-size: 42rpx;
  font-weight: 700;
  color: #1a1a1a;
  line-height: 1;
}

.ring-unit {
  font-size: 28rpx;
  color: #4cd964;
  margin-top: 4rpx;
}

.ring-label {
  font-size: 28rpx;
  color: #4f7269;
  margin-top: 10rpx;
}

.ring-status {
  font-size: 28rpx;
  color: #1f8a6f;
  margin-top: 4rpx;
  font-weight: 500;
}

/* 核心睡眠数据 */
.core-data-section {
  background: #f8fdf9;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.core-data-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 24rpx 40rpx;
}

.core-data-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.core-data-label {
  font-size: 28rpx;
  color: #666;
}

.core-data-value {
  font-size: 30rpx;
  color: #1a1a1a;
  font-weight: 600;
}

/* 评价区域 */
.evaluation-section {
  margin-top: 16rpx;
}

.evaluation-box {
  background: #f0f9f4;
  border-radius: 16rpx;
  padding: 24rpx 28rpx;
  border: 1rpx solid #d4edda;
}

.evaluation-text {
  font-size: 28rpx;
  color: #2d6a4f;
  line-height: 1.6;
}

.wins-section {
  margin-top: 16rpx;
}

.wins-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
}

.win-card {
  border: 1rpx solid #d7ebe3;
  border-radius: 14rpx;
  background: #fbfefd;
  padding: 20rpx 16rpx;
  min-height: 174rpx;
