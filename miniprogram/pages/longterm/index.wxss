.page {
  padding: 20rpx 20rpx 54rpx;
  background: #f0f7f4;
}

.card {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 22rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.top-status {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 14rpx;
}

.status-left {
  display: flex;
  align-items: center;
  gap: 10rpx;
  flex: 1;
  min-width: 0;
}

.status-icon {
  font-size: 24rpx;
}

.status-text {
  font-size: 22rpx;
  color: #2a5a48;
  line-height: 1.4;
}

.status-link {
  font-size: 22rpx;
  color: #7a8f87;
  white-space: nowrap;
}

.summary-card {
  background: #ffffff;
}

.summary-text {
  text-align: center;
  font-size: 28rpx;
  color: #4c645b;
  line-height: 1.6;
}

.kline-card {
  padding-top: 24rpx;
}

.kline-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #213a34;
  margin-bottom: 16rpx;
}

.toolbar-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 14rpx;
}

.toolbar-tabs,
.toolbar-ops,
.metric-toolbar {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 8rpx;
}

.tab-chip {
  font-size: 20rpx;
  padding: 6rpx 18rpx;
  border-radius: 10rpx;
  color: #6e7f79;
  background: #edf2f0;
}

.tab-chip.active {
  color: #ffffff;
  background: #34a853;
}

.op-btn {
  font-size: 20rpx;
  color: #6d7f77;
  padding: 2rpx 8rpx;
}

.op-btn.disabled {
  color: #b6c2bc;
  opacity: 0.55;
}

.op-hint {
  font-size: 20rpx;
  color: #84958f;
}

.kline-wrap {
  border-radius: 16rpx;
  background: linear-gradient(180deg, #0f1b35 0%, #0c152b 100%);
  border: 1rpx solid rgba(130, 151, 182, 0.25);
  padding: 8rpx;
}

.kline-canvas {
  width: 100%;
  height: 460rpx;
}

.chart-axis {
  display: flex;
  justify-content: space-between;
  gap: 8rpx;
  margin-top: 10rpx;
  color: #9eb1cd;
  font-size: 20rpx;
}

.axis-days {
  padding: 0 6rpx;
}

.kline-scrollbar {
  margin-top: 12rpx;
  height: 8rpx;
  border-radius: 8rpx;
  background: #e6ece9;
  overflow: hidden;
}

.kline-scrollbar-thumb {
  height: 100%;
  border-radius: 8rpx;
  background: linear-gradient(90deg, #36b37e 0%, #47c993 100%);
  box-shadow: 0 0 0 1rpx rgba(78, 170, 128, 0.25);
}

.avg-panel {
  margin-top: 14rpx;
  padding: 12rpx 0;
}

.avg-row {
  display: flex;
  align-items: center;
  margin-bottom: 10rpx;
  gap: 10rpx;
}

.avg-row:last-child {
  margin-bottom: 0;
}

.avg-label {
  width: 108rpx;
  flex-shrink: 0;
  font-size: 22rpx;
  color: #81938d;
}

.avg-divider {
  height: 1rpx;
  flex: 1;
  background: #d6e2dd;
}

.avg-value {
  font-size: 24rpx;
  color: #2f4f45;
  font-weight: 600;
}

.kpi-strip {
  margin-top: 8rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.kpi-item {
  flex: 1;
  min-width: 140rpx;
  border-radius: 12rpx;
  background: #f7fbfa;
  padding: 12rpx 10rpx;
  text-align: center;
}

.kpi-label {
  display: block;
  font-size: 20rpx;
  color: #69827a;
  margin-bottom: 6rpx;
}

.kpi-value {
  display: block;
  font-size: 28rpx;
  color: #2f9c63;
  font-weight: 700;
}

.insight-block {
  margin-top: 14rpx;
}

.insight-line {
  font-size: 23rpx;
  color: #3d5b51;
  line-height: 1.6;
}

.insight-line.tip {
  margin-top: 8rpx;
}

.insight-source {
  margin-top: 10rpx;
  font-size: 20rpx;
  color: #93a49e;
}

.module-card {
  background: #ffffff;
  border-radius: 20rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
  overflow: hidden;
}

.module-header {
  padding: 22rpx;
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 12rpx;
}

.module-left {
  flex: 1;
  min-width: 0;
  display: flex;
  align-items: flex-start;
  gap: 10rpx;
}

.module-index {
  font-size: 30rpx;
  color: #283d37;
  font-weight: 700;
  line-height: 1.4;
}

.module-title {
  font-size: 30rpx;
  color: #243f37;
  font-weight: 700;
  line-height: 1.4;
}

.module-desc {
  margin-top: 6rpx;
  font-size: 22rpx;
  color: #6e837b;
  line-height: 1.5;
}

.module-link {
  font-size: 22rpx;
  color: #4e91d4;
  line-height: 1.4;
  white-space: nowrap;
}

.vip-badge {
  font-size: 20rpx;
  color: #f39d52;
}

.module-body {
  padding: 0 22rpx 20rpx;
}

.metric-section {
  margin-top: 18rpx;
  border-radius: 14rpx;
  background: #fafcfc;
  padding: 16rpx;
  border: 1rpx solid #ebf1ee;
}

.metric-section.focused {
  background: #f0fbf7;
  border-color: #79c9a5;
  box-shadow: 0 0 0 4rpx rgba(52, 168, 83, 0.08);
}

.metric-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  flex-wrap: wrap;
  gap: 10rpx;
}

.metric-title {
  font-size: 28rpx;
  color: #203a33;
  font-weight: 700;
}

.metric-subline {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #5f7870;
}

.metric-toolbar .tab-chip {
  padding: 4rpx 12rpx;
}

.metric-toolbar .op-btn {
  font-size: 22rpx;
}

.chart-container {
  margin-top: 10rpx;
  width: 100%;
  height: 220rpx;
  border-radius: 12rpx;
  background: linear-gradient(180deg, #0f1b35 0%, #0c1529 100%);
  border: 1rpx solid rgba(133, 150, 185, 0.28);
  box-shadow: inset 0 0 0 1rpx rgba(255, 255, 255, 0.03);
  overflow: hidden;
}

.trend-canvas {
  width: 100%;
  height: 100%;
}

.metric-insight {
  margin-top: 10rpx;
  font-size: 22rpx;
  line-height: 1.5;
  color: #576f67;
}

.point-tip {
  margin-top: 8rpx;
  padding: 8rpx 12rpx;
  border-radius: 8rpx;
  font-size: 20rpx;
  color: #5f737f;
  background: #eff5f3;
  line-height: 1.5;
}

.bottom-space {
  height: 40rpx;
}