  background: #FBF3DC;
}

.module-body {
  padding: 0 22rpx 20rpx;
}

.metric-section {
  margin-top: 18rpx;
  border-radius: 14rpx;
  background: #fafcfc;
  padding: 16rpx;
  border: 1rpx solid #ebf1ee;
}

.metric-section.focused {
  background: #f0fbf7;
  border-color: #46C79E;
  box-shadow: 0 0 0 4rpx rgba(31, 138, 111, 0.08);
}

.metric-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  flex-wrap: wrap;
  gap: 10rpx;
}

.metric-title {
  font-size: 28rpx;
  color: #203a33;
  font-weight: 700;
}

.metric-subline {
  margin-top: 8rpx;
  font-size: 28rpx;
  color: #5f7870;
}

.metric-toolbar .tab-chip {
  padding: 4rpx 12rpx;
}

.metric-toolbar .op-btn {
  font-size: 28rpx;
}

.chart-container {
  margin-top: 10rpx;
  width: 100%;
  height: 220rpx;
  border-radius: 12rpx;
  /* 趋势图深色背景统一为品牌深绿，跟 K线 / hd-banner 同色系 */
  background: linear-gradient(180deg, #0D3A30 0%, #14443A 100%);
  border: 1rpx solid rgba(70, 199, 158, 0.18);
