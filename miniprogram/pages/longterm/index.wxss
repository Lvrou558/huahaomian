}

.status-icon {
  font-size: 28rpx;
}

.status-text {
  font-size: 28rpx;
  color: #2a5a48;
  line-height: 1.4;
}

.status-link {
  font-size: 28rpx;
  color: #7a8f87;
  white-space: nowrap;
}

.summary-card {
  background: #ffffff;
}

.summary-text {
  text-align: center;
  font-size: 28rpx;
  color: #4c645b;
  line-height: 1.6;
}

.kline-card {
  padding-top: 24rpx;
}

.kline-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #213a34;
  margin-bottom: 16rpx;
}

.toolbar-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 14rpx;
}

.toolbar-tabs,
.toolbar-ops,
.metric-toolbar {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
