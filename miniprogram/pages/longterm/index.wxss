  background: #eff5f3;
  line-height: 1.5;
}

.bottom-space {
  height: 40rpx;
}

/* ========== 作息走势卡（睡眠板块第一张） ========== */
.schedule-card {
  padding-bottom: 22rpx;
}

.schedule-canvas-wrap {
  /* viewBox 420×320，比例与其他 hc-card 一致 */
  height: 560rpx;
}

.schedule-card .avg-panel {
  margin: 18rpx 18rpx 0;
  padding: 14rpx 0 0;
  border-top: 1rpx solid #ececec;
}

.schedule-card .kpi-strip {
  margin: 14rpx 18rpx 0;
}

.schedule-card .insight-block {
  margin: 14rpx 18rpx 0;
}

/* ========== 心肺健康重设计 ========== */

/* 心脏年龄总览卡 */
.heart-age-card {
  margin-top: 18rpx;
  background: linear-gradient(135deg, #e9f7ef 0%, #f4faf3 100%);
  border-radius: 16rpx;
  padding: 20rpx 22rpx;
  border: 1rpx solid #d6ecde;
}

.ha-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 14rpx;
}

.ha-title-row {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
}

.ha-leaf {
  font-size: 28rpx;
  line-height: 1;
}

.ha-label {
  font-size: 28rpx;
  color: #3a6a52;
  font-weight: 500;
}

.ha-age {
  font-size: 40rpx;
  font-weight: 700;
  color: #1a2c24;
  line-height: 1;
  margin-left: 6rpx;
}

.ha-unit {
  font-size: 28rpx;
  color: #4f6960;
  margin-right: 6rpx;
}

.ha-actual {
  font-size: 28rpx;
  color: #6a857a;
}

.ha-badge {
  background: #d4ebe1;
  color: #1d6e54;
  font-size: 28rpx;
  font-weight: 600;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
}

.ha-metrics {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12rpx;
}

.ha-metric {
  background: #ffffff;
  border-radius: 12rpx;
  padding: 14rpx 16rpx;
  border: 1rpx solid #e1efe7;
}

.ha-mname {
  display: block;
  font-size: 28rpx;
  color: #6a857a;
  margin-bottom: 8rpx;
}

.ha-mvalue-row {
  display: flex;
  align-items: baseline;
  gap: 6rpx;
}

.ha-mnum {
  font-size: 32rpx;
  font-weight: 700;
  color: #1a2c24;
  line-height: 1;
}

.ha-munit {
  font-size: 28rpx;
  color: #6a857a;
}

.ha-mdelta {
  margin-left: 8rpx;
  font-size: 28rpx;
  font-weight: 600;
}

.ha-mdelta.up {
  color: #1F8A6F;
}

.ha-mdelta.down {
  /* 原本 up/down 同色（疑似笔误），改为红色提示恶化 */
  color: #C43A2C;
}

/* 浅色主题图表卡（夜间心率/HRV） */
.hc-card {
  margin-top: 16rpx;
  background: #ffffff;
  border-radius: 16rpx;
  padding: 18rpx 6rpx 14rpx;
  border: 1rpx solid #ebf1ee;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.03);
}

.hc-card.focused {
  border-color: #46C79E;
  box-shadow: 0 0 0 4rpx rgba(31, 138, 111, 0.08);
}

.hc-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0 16rpx;
  margin-bottom: 6rpx;
  flex-wrap: wrap;
  gap: 8rpx;
}

.hc-title-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.hc-title {
  font-size: 28rpx;
  color: #1f3a32;
  font-weight: 700;
}

.hc-healthy {
  display: inline-block;
  font-size: 28rpx;
  color: #1d6e54;
  background: #e3f3ea;
  padding: 4rpx 12rpx;
  border-radius: 999rpx;
}
.hc-range {
  display: inline-block;
  font-size: 24rpx;
  font-weight: 600;
  color: #4a5a63;
  background: #f0f4f7;
  padding: 4rpx 14rpx;
  border-radius: 999rpx;
  margin-left: 8rpx;
  letter-spacing: 0.5rpx;
}

.hc-toolbar {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.hc-tabs {
  display: flex;
  gap: 4rpx;
  background: #f1f4f3;
  border-radius: 10rpx;
  padding: 3rpx;
}

.hc-nav {
  display: flex;
  align-items: center;
  gap: 2rpx;
  padding-left: 8rpx;
  border-left: 1rpx solid #d8e2dd;
}

.hc-nav-btn {
  font-size: 28rpx;
  color: #4a857a;
  padding: 4rpx 8rpx;
  min-width: 28rpx;
  text-align: center;
  line-height: 1;
}

.hc-nav-btn.disabled {
  color: #c4d0cb;
  opacity: 0.6;
}

.hc-tab {
  font-size: 28rpx;
  color: #6c7c75;
  padding: 4rpx 14rpx;
  border-radius: 8rpx;
}

.hc-tab.active {
  background: #ffffff;
  color: #1F8A6F;
  font-weight: 600;
  box-shadow: 0 1rpx 3rpx rgba(0, 0, 0, 0.06);
}

.hc-canvas-wrap {
  width: 100%;
  /* viewBox 420×345（含 2 行日期 X 轴），按 ~698rpx 卡宽计算：698 * 345/420 ≈ 573rpx */
  height: 570rpx;
  margin-top: 8rpx;
}

.hc-canvas {
  width: 100%;
  height: 100%;
}

.hc-legend {
  display: flex;
  flex-wrap: nowrap;
  align-items: center;
  gap: 0 10rpx;
  padding: 8rpx 12rpx 0;
  margin-top: 4rpx;
  overflow: hidden;
}

.hc-legend-item {
  display: flex;
  align-items: center;
  gap: 4rpx;
  font-size: 20rpx;
  color: #6c7c75;
  white-space: nowrap;
  flex-shrink: 0;
}

.hc-dot {
  width: 18rpx;
  height: 18rpx;
  border-radius: 4rpx;
}

.hc-dot.green {
  background: #C7E8DC;
}

.hc-dot.yellow {
  background: #F3D990;  /* 健康区→警戒区→异常区，对应 design system warning-light */
}

.hc-dot.red {
  background: #F4CECE;
}

.hc-line {
  width: 22rpx;
  height: 0;
  /* 14 天均值线：品牌深绿，按 design system chart-line 规范 */
  border-top: 2rpx dashed #14443A;
}

.hc-line.gray {
  /* 同龄人参考线：design system chart-ref */
  border-top-color: #8A9BAA;
}

/* 全局交互提示（页面顶部，仅一次） */
.global-tip {
  margin: 10rpx 16rpx 6rpx;
  padding: 10rpx 14rpx;
  border-radius: 10rpx;
  background: #f4f8f6;
  color: #5d7770;
  font-size: 28rpx;
  border-left: 4rpx solid #1f8a6f;
}
.hc-tip {
  margin: 8rpx 16rpx 0;
  padding: 10rpx 12rpx;
  border-radius: 8rpx;
  background: #f4f8f6;
  color: #5d7770;
  font-size: 28rpx;
  line-height: 1.5;
}

.hc-summary {
  margin: 10rpx 16rpx 0;
  font-size: 28rpx;
  line-height: 1.55;
  color: #4a655c;
}
/* ===== 长期风险提示 + 长期改进建议卡（罗列式，无交互） ===== */
.lt-section-card {
  background: #ffffff;
  border: 1rpx solid #e6f0ea;
  border-radius: 18rpx;
  padding: 22rpx 20rpx;
  margin-top: 16rpx;
  box-shadow: 0 4rpx 14rpx rgba(31, 138, 111, 0.04);
}

/* ===== 付费弹窗（长期视图 / 声音监测共用） ===== */
.pw-mask {
  position: fixed;
  inset: 0;
  background: rgba(20, 30, 26, 0.6);
  z-index: 5000;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 40rpx;
}
.pw-card {
  width: 100%;
  max-width: 640rpx;
  background: #ffffff;
  border-radius: 22rpx;
  overflow: hidden;
  box-shadow: 0 20rpx 50rpx rgba(0, 0, 0, 0.25);
  animation: pwSlideIn 0.22s ease-out;
}
@keyframes pwSlideIn {
  from { opacity: 0; transform: scale(0.94); }
  to { opacity: 1; transform: scale(1); }
}
.pw-header {
  background: linear-gradient(135deg, #f6e8c3 0%, #f3d990 100%);
  padding: 36rpx 22rpx 28rpx;
  text-align: center;
}
.pw-icon-circle {
  width: 110rpx;
  height: 110rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #fff, #fef3d3);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 58rpx;
  margin: 0 auto 14rpx;
  box-shadow: 0 8rpx 20rpx rgba(180, 130, 30, 0.22);
}
.pw-title {
  font-size: 34rpx;
  font-weight: 800;
  color: #5a3a0e;
  margin-bottom: 6rpx;
}
.pw-sub { font-size: 28rpx; color: #8a6a3a; }

.pw-body { padding: 20rpx 26rpx 18rpx; }
.pw-feature {
  display: flex;
  align-items: flex-start;
  gap: 14rpx;
  padding: 14rpx 0;
  border-bottom: 1rpx dashed #f0e5cf;
}
.pw-feature:last-of-type { border-bottom: none; }
.pw-feature-icon {
  width: 56rpx; height: 56rpx;
  border-radius: 14rpx;
  background: #faf3e0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  flex-shrink: 0;
}
.pw-feature-text { flex: 1; }
.pw-feature-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #1a2c24;
  display: block;
  margin-bottom: 4rpx;
}
.pw-feature-sub { font-size: 28rpx; color: #7a8a83; line-height: 1.5; display: block; }

/* 弹窗内价格对比（年付推荐 + 月付） */
.pw-price-row {
  margin-top: 22rpx;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 14rpx;
}
.pw-price-card {
  background: #fafffd;
  border: 2rpx solid #eef4f1;
  border-radius: 16rpx;
  padding: 24rpx 14rpx 18rpx;
  text-align: center;
  position: relative;
}
.pw-price-card.recommended {
  border-color: #d4a548;
  background: linear-gradient(135deg, #fff9e8 0%, #fff 100%);
  box-shadow: 0 8rpx 18rpx rgba(180, 130, 30, 0.18);
}
.pw-price-badge {
  position: absolute;
  top: -12rpx; left: 50%;
  transform: translateX(-50%);
  background: linear-gradient(135deg, #d4a548, #b3851e);
  color: #fff;
  font-size: 28rpx;
  font-weight: 700;
  padding: 4rpx 14rpx;
  border-radius: 999rpx;
  box-shadow: 0 4rpx 8rpx rgba(180, 130, 30, 0.3);
  white-space: nowrap;
}
.pw-price-name { font-size: 28rpx; color: #7a8a83; display: block; margin-bottom: 6rpx; }
.pw-price-num {
  font-size: 40rpx;
  font-weight: 800;
  color: #1a2c24;
  display: block;
  line-height: 1.1;
}
.pw-price-card.recommended .pw-price-num { color: #c0850f; }
.pw-price-orig {
  font-size: 28rpx;
  color: #b0aea2;
  text-decoration: line-through;
  display: block;
  margin-top: 4rpx;
  min-height: 26rpx;
}
.pw-price-equiv {
  font-size: 28rpx;
  color: #1f8a6f;
  font-weight: 600;
  display: block;
  margin-top: 2rpx;
}

.pw-actions {
  padding: 8rpx 26rpx 26rpx;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}
.pw-btn-primary {
  background: linear-gradient(135deg, #d4a548, #b3851e);
  color: #fff;
  text-align: center;
  padding: 22rpx;
  border-radius: 999rpx;
  font-size: 28rpx;
  font-weight: 700;
  box-shadow: 0 8rpx 18rpx rgba(180, 130, 30, 0.36);
}
.pw-btn-primary:active { opacity: 0.85; }
.pw-btn-ghost {
  text-align: center;
  padding: 12rpx;
  font-size: 28rpx;
  color: #7a8a83;
}

