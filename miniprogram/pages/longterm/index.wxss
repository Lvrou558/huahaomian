.page {
  padding: 24rpx 24rpx 54rpx;
  background: #f4f8f7;
}

/* ===== 顶部页面标题 ===== */
.page-header {
  padding: 8rpx 4rpx 24rpx;
}
.page-title {
  display: block;
  font-size: 56rpx;
  font-weight: 800;
  color: #14443a;
  line-height: 1.15;
  letter-spacing: 1rpx;
}
.page-subtitle {
  display: block;
  margin-top: 10rpx;
  font-size: 26rpx;
  color: #8a9b95;
  line-height: 1.4;
}

/* ===== 全局提示卡（💡 + 文字 + 📅） ===== */
.global-tip-card {
  display: flex;
  align-items: center;
  gap: 18rpx;
  background: #eef9f2;
  border: 1rpx solid #d6ecdf;
  border-radius: 20rpx;
  padding: 22rpx 24rpx;
  margin-bottom: 28rpx;
}
.tip-icon {
  font-size: 44rpx;
  flex-shrink: 0;
}
.tip-text {
  flex: 1;
  font-size: 26rpx;
  color: #4a6a60;
  line-height: 1.55;
}
.tip-calendar {
  font-size: 56rpx;
  flex-shrink: 0;
  line-height: 1;
}

/* ============================================== */
/* 长期页默认视图重构：徽章 + 评分 + 好转 + 模块     */
/* 视觉与 module-card 统一：白底、22rpx 圆角、淡阴影 */
/* ============================================== */

/* 分组标题（与页面其它板块标题语感一致） */
.lt-h {
  font-size: 28rpx;
  color: #14443a;
  margin: 28rpx 8rpx 14rpx;
  font-weight: 700;
}

/* ① 顶部 Hero 卡（深绿背景 + 大数字 + 3 芯片，合并原 badge-bar 和 lt-score 焦点卡） */
.lt-hero-v2 {
  background: linear-gradient(160deg, #0D3A30 0%, #14443A 35%, #1a5548 70%, #0F3B30 100%);
  border-radius: 24rpx;
  padding: 36rpx 28rpx 30rpx;
  margin-bottom: 16rpx;
  position: relative;
  overflow: hidden;
  box-shadow: 0 6rpx 20rpx rgba(13,58,48,0.18);
}
/* 右上装饰光晕，提升品牌感 */
.lt-hero-v2::after {
  content: '';
  position: absolute;
  top: -60rpx;
  right: -50rpx;
  width: 240rpx;
  height: 240rpx;
  background: radial-gradient(circle, rgba(70,199,158,0.20) 0%, rgba(70,199,158,0) 70%);
  border-radius: 50%;
  pointer-events: none;
}
.lt-hero-v2-title {
  font-size: 32rpx;
  font-weight: 800;
  color: #E8F5F0;
  letter-spacing: 0.5rpx;
  display: block;
  margin-bottom: 14rpx;
  position: relative;
  z-index: 1;
}
.lt-hero-v2-streak {
  display: flex;
  align-items: baseline;
  gap: 10rpx;
  margin-bottom: 16rpx;
  position: relative;
  z-index: 1;
}
.lt-hero-v2-num {
  font-size: 100rpx;
  font-weight: 900;
  color: #ffffff;
  line-height: 1;
  letter-spacing: -3rpx;
}
.lt-hero-v2-unit {
  font-size: 36rpx;
  font-weight: 700;
  color: #C8E8D6;
}
.lt-hero-v2-sub {
  font-size: 24rpx;
  color: #8AAD9F;
  font-weight: 500;
  line-height: 1.55;
  display: block;
  margin-bottom: 22rpx;
  position: relative;
  z-index: 1;
}
.lt-hero-v2-chips {
  display: flex;
  gap: 10rpx;
  position: relative;
  z-index: 1;
}
.lt-hero-v2-chip {
  flex: 1;
  min-width: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  background: rgba(255,255,255,0.10);
  border: 1rpx solid rgba(70,199,158,0.18);
  border-radius: 999rpx;
  padding: 10rpx 12rpx;
}
.lt-hero-v2-chip-icon { font-size: 24rpx; }
.lt-hero-v2-chip-label {
  font-size: 22rpx;
  color: #C8E8D6;
  font-weight: 500;
}
.lt-hero-v2-chip-num {
  font-size: 26rpx;
  font-weight: 800;
  color: #46C79E;
  margin-left: 2rpx;
}
.lt-hero-v2-chip-unit {
  font-size: 20rpx;
  color: #C8E8D6;
  font-weight: 500;
}

/* 好转亮点卡（沿用 module-card 的形态；三档 accent 色：green/blue/coral） */
.lt-win {
  background: #ffffff;
  border-radius: 22rpx;
  padding: 22rpx 22rpx 20rpx;
  margin-bottom: 14rpx;
  box-shadow: 0 4rpx 14rpx rgba(0,0,0,0.04);
  border-left: 6rpx solid #1F8A6F;
}
/* 坚持见效卡 3 个变体统一为品牌绿，靠数据本身的方向（↑↓）和文案区分语义 */
.lt-win.lt-win-green,
.lt-win.lt-win-blue,
.lt-win.lt-win-coral { border-left-color: #1F8A6F; }

.lt-win-top {
  display: flex;
  align-items: center;
  gap: 14rpx;
  margin-bottom: 12rpx;
}
.lt-win-ic-wrap {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.lt-win-ic-wrap.lt-win-ic-green,
.lt-win-ic-wrap.lt-win-ic-blue,
.lt-win-ic-wrap.lt-win-ic-coral { background: #E7F7EE; }
.lt-win-ic { font-size: 36rpx; }

.lt-win-ti {
  flex: 1;
  font-size: 28rpx;
  font-weight: 700;
  color: #14443a;
}
.lt-win-badge {
  font-size: 22rpx;
  font-weight: 700;
  padding: 6rpx 16rpx;
  border-radius: 999rpx;
}
.lt-win-badge.lt-win-badge-green,
.lt-win-badge.lt-win-badge-blue,
.lt-win-badge.lt-win-badge-coral { color: #1F8A6F; background: #E7F7EE; }

.lt-win-flow {
  font-size: 24rpx;
  color: #4a6a60;
  line-height: 1.6;
  margin-bottom: 14rpx;
}
.lt-win-act { color: #14443a; font-weight: 700; }

.lt-win-bar {
  height: 12rpx;
  background: #eef3f0;
  border-radius: 8rpx;
  overflow: hidden;
  position: relative;
}
.lt-win-bar-fill {
  position: absolute;
  left: 0; top: 0;
  height: 100%;
  border-radius: 8rpx;
}
.lt-win-bar-fill.lt-win-bar-green,
.lt-win-bar-fill.lt-win-bar-blue,
.lt-win-bar-fill.lt-win-bar-coral { background: linear-gradient(90deg, #1F8A6F, #46C79E); }

.lt-win-meta {
  display: flex;
  justify-content: space-between;
  font-size: 22rpx;
  color: #8aa093;
  margin-top: 10rpx;
}
.lt-win-now { font-weight: 700; }
.lt-win-now.lt-win-now-green,
.lt-win-now.lt-win-now-blue,
.lt-win-now.lt-win-now-coral { color: #1F8A6F; }

/* 旧的评分环 + sparkline 样式（lt-score / lt-ring / lt-spark）已废弃，
   合并入新的 .lt-hero-v2 深绿 hero 卡 */

/* ===== 健康关注中心 Dashboard ===== */
.hd-banner {
  background: linear-gradient(135deg, #0f2f2b 0%, #1a3a34 40%, #143430 100%);
  border-radius: 20rpx;
  padding: 28rpx 24rpx;
  margin-bottom: 14rpx;
}
.hd-banner-title {
  font-size: 32rpx;
  font-weight: 800;
  color: #e8f5f0;
  letter-spacing: 1rpx;
  margin-bottom: 10rpx;
  display: block;
}
.hd-banner-summary {
  font-size: 22rpx;
  color: #8aad9f;
  display: flex;
  align-items: center;
  gap: 6rpx;
  flex-wrap: wrap;
}
.hd-banner-dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  display: inline-block;
}
.hd-banner-dot.warn { background: #D4A548; }
.hd-banner-dot.good { background: #46C79E; }
.hd-banner-improved { color: #46C79E; font-weight: 600; }

.hd-risk-row {
  display: flex;
  gap: 10rpx;
  margin-bottom: 14rpx;
}
.hd-risk-card {
  flex: 1;
  min-width: 0;
  border-radius: 16rpx;
  padding: 20rpx 10rpx 14rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
}
.hd-risk-card.warn {
  background: linear-gradient(135deg, #FDE7E7 0%, #FBDADA 100%);
  border: 2rpx solid #F4CECE;
}
.hd-risk-card.caution {
  background: linear-gradient(135deg, #FBF3DC 0%, #F8EAC2 100%);
  border: 2rpx solid #F0E0B0;
}
.hd-risk-card.ok {
  background: linear-gradient(135deg, #E7F7EE 0%, #D4F0E4 100%);
  border: 2rpx solid #C8E8D6;
}
.hd-risk-icon { font-size: 30rpx; line-height: 1; }
.hd-risk-name {
  font-size: 20rpx;
  color: #6a8b82;
  font-weight: 500;
  text-align: center;
  line-height: 1.3;
}
.hd-risk-value-wrap { display: flex; align-items: baseline; }
.hd-risk-value {
  font-size: 28rpx;
  font-weight: 800;
  line-height: 1;
}
.hd-risk-card.warn .hd-risk-value { color: #C43A2C; }
.hd-risk-card.caution .hd-risk-value { color: #8C6C12; }
.hd-risk-card.ok .hd-risk-value { color: #1F8A6F; }
.hd-risk-unit {
  font-size: 20rpx;
  font-weight: 500;
  margin-left: 2rpx;
}
.hd-risk-trend {
  font-size: 20rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  gap: 2rpx;
}
.hd-risk-trend.improving { color: #1F8A6F; }
.hd-risk-trend.worsening { color: #C43A2C; }
.hd-risk-trend.stable { color: #8A978F; }
.hd-risk-tag {
  font-size: 18rpx;
  font-weight: 600;
  padding: 2rpx 10rpx;
  border-radius: 999rpx;
  line-height: 1.4;
}
.hd-risk-card.warn .hd-risk-tag { background: #FDE7E7; color: #C43A2C; }
.hd-risk-card.caution .hd-risk-tag { background: #FBF3DC; color: #8C6C12; }
.hd-risk-card.ok .hd-risk-tag { background: #D4F0E4; color: #0F6E56; }

.hd-advice-section {
  background: #ffffff;
  border-radius: 18rpx;
  padding: 22rpx 20rpx;
  margin-bottom: 14rpx;
  box-shadow: 0 4rpx 14rpx rgba(37,114,93,0.06);
}
.hd-advice-section-title {
  font-size: 26rpx;
  font-weight: 700;
  color: #14443a;
  margin-bottom: 14rpx;
  display: block;
}
.hd-advice-card {
  display: flex;
  gap: 14rpx;
  align-items: flex-start;
  padding: 18rpx 18rpx;
  background: #f9fdfb;
  border-radius: 14rpx;
  border-left: 6rpx solid #1f8a6f;
  margin-bottom: 12rpx;
}
.hd-advice-card:last-child { margin-bottom: 0; }
.hd-advice-num {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: #1f8a6f;
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.hd-advice-body { flex: 1; min-width: 0; }
.hd-advice-title {
  font-size: 26rpx;
  font-weight: 700;
  color: #14443a;
  display: block;
}
.hd-advice-desc {
  font-size: 22rpx;
  color: #577970;
  line-height: 1.55;
  margin-top: 4rpx;
  display: block;
}
.hd-advice-target {
  font-size: 22rpx;
  color: #1f8a6f;
  font-weight: 600;
  margin-top: 10rpx;
  display: flex;
  align-items: center;
  gap: 10rpx;
}
.hd-advice-target-label { flex-shrink: 0; }
.hd-advice-progress {
  flex: 1;
  height: 8rpx;
  background: #e0efe8;
  border-radius: 4rpx;
  overflow: hidden;
}
.hd-advice-progress-fill {
  height: 100%;
  background: #1f8a6f;
  border-radius: 4rpx;
}

/* ===== 健康关注 分组标题 + 筛选 ===== */
.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin: 12rpx 4rpx 20rpx;
}
.section-title {
  font-size: 38rpx;
  font-weight: 800;
  color: #14443a;
  letter-spacing: 0.5rpx;
}
.filter-pill {
  display: flex;
  align-items: center;
  gap: 6rpx;
  background: #ffffff;
  border: 1rpx solid #e6efea;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  color: #5a6e67;
}
.filter-icon {
  font-size: 20rpx;
  color: #7a8c84;
}

/* ===== 新版 module-card 设计（icon圆 + 信息 + sparkline + ›） ===== */
.module-card {
  background: #ffffff;
  border-radius: 22rpx;
  margin-bottom: 18rpx;
  box-shadow: 0 4rpx 14rpx rgba(0, 0, 0, 0.04);
  overflow: hidden;
}
.module-card .module-header {
  padding: 26rpx 24rpx;
  display: flex;
  align-items: flex-start;
  gap: 18rpx;
}
.module-icon-circle {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
  flex-shrink: 0;
  margin-top: 4rpx;
}
/* 4 个模块身份靠 emoji 颜色 + 标题区分，背景统一品牌浅绿调，消除"花色调色盘"感 */
.module-icon-circle.heart { background: linear-gradient(135deg, #E7F7EE, #C8E8D6); }
.module-icon-circle.breath { background: linear-gradient(135deg, #EEF4F1, #D8ECE2); }
.module-icon-circle.sleep { background: linear-gradient(135deg, #EEF4F1, #D8ECE2); }
.module-icon-circle.sound { background: linear-gradient(135deg, #E7F7EE, #C8E8D6); }

.module-info {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}
.module-info .module-title-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-wrap: wrap;
}
.module-info .module-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #14443a;
  line-height: 1.3;
}
.module-info .module-score-pill {
  font-size: 24rpx;
  font-weight: 700;
  padding: 4rpx 16rpx;
  border-radius: 999rpx;
  line-height: 1.4;
}

.module-stats {
  display: flex;
  align-items: center;
  gap: 12rpx;
  font-size: 24rpx;
  color: #7a8c84;
  flex-wrap: wrap;
  margin-top: 2rpx;
}
.stat-item { font-size: 24rpx; color: #7a8c84; }
.stat-item.good { color: #1F8A6F; font-weight: 600; }
.stat-item.warn { color: #8C6C12; font-weight: 600; }
.stat-divider { color: #d4ddd9; }

.module-focus {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #4a6a60;
  line-height: 1.5;
}

.module-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  justify-content: center;
  gap: 8rpx;
  flex-shrink: 0;
  padding-left: 4rpx;
  align-self: center;
}
.sparkline {
  width: 120rpx;
  height: 50rpx;
  background-repeat: no-repeat;
  background-position: center;
  background-size: contain;
}
/* SVG 小折线（各模块都是绿色平稳/上升趋势） */
.sparkline.heart {
  background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 120 50'><path d='M4 38 Q20 36 30 28 T55 22 T80 14 L112 8' fill='none' stroke='%231F8A6F' stroke-width='3' stroke-linecap='round' stroke-linejoin='round'/><circle cx='30' cy='28' r='2.5' fill='%231F8A6F'/><circle cx='112' cy='8' r='3.5' fill='%231F8A6F'/></svg>");
}
.sparkline.breath {
  background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 120 50'><path d='M4 30 Q22 32 38 24 T68 18 T98 10 L112 6' fill='none' stroke='%231F8A6F' stroke-width='3' stroke-linecap='round' stroke-linejoin='round'/><circle cx='38' cy='24' r='2.5' fill='%231F8A6F'/><circle cx='112' cy='6' r='3.5' fill='%231F8A6F'/></svg>");
}
.sparkline.sleep {
  background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 120 50'><path d='M4 32 Q22 34 38 26 T68 18 T98 10 L112 8' fill='none' stroke='%231F8A6F' stroke-width='3' stroke-linecap='round' stroke-linejoin='round'/><circle cx='38' cy='26' r='2.5' fill='%231F8A6F'/><circle cx='112' cy='8' r='3.5' fill='%231F8A6F'/></svg>");
}
.sparkline.sound {
  background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 120 50'><path d='M4 28 Q22 30 38 24 T70 22 T98 14 L112 16' fill='none' stroke='%231F8A6F' stroke-width='3' stroke-linecap='round' stroke-linejoin='round'/><circle cx='38' cy='24' r='2.5' fill='%231F8A6F'/><circle cx='112' cy='16' r='3.5' fill='%231F8A6F'/></svg>");
}

.module-arrow-new {
  font-size: 38rpx;
  color: #c5d4ce;
  font-weight: 400;
  line-height: 1;
}

/* 会员专属 badge */
.vip-badge {
  display: inline-block;
  background: linear-gradient(135deg, #ffd180, #ff9d3d);
  color: #7a3f0a;
  font-size: 18rpx;
  font-weight: 700;
  padding: 2rpx 10rpx;
  border-radius: 6rpx;
  margin-left: 6rpx;
  vertical-align: middle;
}

