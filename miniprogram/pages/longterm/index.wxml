<view class="page">
  <!-- 全局交互提示（左侧💡 + 文字） -->
  <view class="global-tip-card">
    <text class="tip-icon">💡</text>
    <text class="tip-text">点击数据点查看当日详情 · 月/全周期视图可拖动查看任意日期</text>
  </view>

  <!-- ============================================== -->
  <!-- 重排：顶部小徽章 → 评分焦点 → 好转亮点 → 模块       -->
  <!-- ============================================== -->

  <!-- ① 顶部 Hero 卡（合并原徽章条 + 87 分焦点卡：大数字主导 + 3 芯片浓缩关键指标） -->
  <view class="lt-hero-v2">
    <text class="lt-hero-v2-title">坚持有回报</text>
    <view class="lt-hero-v2-streak">
      <text class="lt-hero-v2-num">{{rewardHero.streakDays}}</text>
      <text class="lt-hero-v2-unit">天</text>
    </view>
    <text class="lt-hero-v2-sub">{{weekScore.trendText}} · {{weekScore.summary}}</text>
    <view class="lt-hero-v2-chips">
      <view class="lt-hero-v2-chip">
        <text class="lt-hero-v2-chip-icon">📈</text>
        <text class="lt-hero-v2-chip-label">评分</text>
        <text class="lt-hero-v2-chip-num">{{weekScore.value}}</text>
        <text class="lt-hero-v2-chip-unit">分</text>
      </view>
      <view class="lt-hero-v2-chip">
        <text class="lt-hero-v2-chip-icon">📊</text>
        <text class="lt-hero-v2-chip-label">进步</text>
        <text class="lt-hero-v2-chip-num">{{rewardHero.improvedCount}}</text>
        <text class="lt-hero-v2-chip-unit">项</text>
      </view>
      <view class="lt-hero-v2-chip">
        <text class="lt-hero-v2-chip-icon">✅</text>
        <text class="lt-hero-v2-chip-label">达标</text>
        <text class="lt-hero-v2-chip-num">{{rewardHero.goalDays}}/7</text>
      </view>
    </view>
  </view>

  <!-- ③ 好转亮点（卡片色彩区分但保持和谐） -->
  <view class="lt-h">你的坚持正在见效</view>
  <view class="lt-win lt-win-{{item.accent}}" wx:for="{{rewardWins}}" wx:key="id">
    <view class="lt-win-top">
      <view class="lt-win-ic-wrap lt-win-ic-{{item.accent}}">
        <text class="lt-win-ic">{{item.icon}}</text>
      </view>
      <text class="lt-win-ti">{{item.title}}</text>
      <text class="lt-win-badge lt-win-badge-{{item.accent}}">{{item.deltaText}}</text>
    </view>
    <view class="lt-win-flow">你坚持<text class="lt-win-act">{{item.action}}</text> → {{item.flowText}}</view>
    <view class="lt-win-bar"><view class="lt-win-bar-fill lt-win-bar-{{item.accent}}" style="width:{{item.progressPct}}%"></view></view>
    <view class="lt-win-meta">
      <text>目标 {{item.goalText}}</text>
      <text class="lt-win-now lt-win-now-{{item.accent}}">当前 {{item.currentText}} · 已完成 {{item.progressPct}}%</text>
    </view>
  </view>

  <!-- ④ 板块状态区分组标题 -->
  <view class="lt-h">板块状态</view>

  <!-- ★ 1. 心脏健康（默认展开） -->
  <view class="module-card {{expanded.heart ? 'expanded' : ''}}">
    <view class="module-header" bindtap="toggleModule" data-module="heart">
      <view class="module-icon-circle heart">❤️</view>
      <view class="module-info">
        <view class="module-title-row">
          <text class="module-title">心脏健康</text>
          <text class="module-score-pill {{moduleSummaries.heart.statusKey}}">{{moduleSummaries.heart.score}} 分 · {{moduleSummaries.heart.status}}</text>
        </view>
        <view class="module-focus">{{moduleSummaries.heart.focus}}</view>
      </view>
      <view class="module-right">
        <text class="module-arrow-new">›</text>
      </view>
    </view>

    <view class="module-body" wx:if="{{expanded.heart}}">
      <!-- 心脏年龄总览卡 -->
      <view class="heart-age-card">
        <view class="ha-head">
          <view class="ha-title-row">
            <text class="ha-leaf">🌿</text>
            <text class="ha-label">心脏年龄</text>
            <text class="ha-age">{{heartAgeSummary.age}}</text>
            <text class="ha-unit">岁</text>
            <text class="ha-actual">实际 {{heartAgeSummary.actualAge}} 岁</text>
          </view>
          <view class="ha-badge {{heartAgeSummary.youngerThanActual ? '' : 'warn'}}">
            <text wx:if="{{heartAgeSummary.youngerThanActual}}">↓ 年轻 {{heartAgeSummary.diff}} 岁</text>
            <text wx:elif="{{heartAgeSummary.diff > 0}}">↑ 偏老 {{heartAgeSummary.diff}} 岁</text>
            <text wx:else>= 与实际一致</text>
          </view>
        </view>
        <view class="ha-metrics">
          <view class="ha-metric">
            <text class="ha-mname">本周 HRV 均值</text>
            <view class="ha-mvalue-row">
              <text class="ha-mnum">{{heartAgeSummary.hrvAvg}}</text>
              <text class="ha-munit">ms</text>
              <text class="ha-mdelta up">↑ {{heartAgeSummary.hrvDelta}}</text>
            </view>
          </view>
          <view class="ha-metric">
            <text class="ha-mname">本周静息心率</text>
            <view class="ha-mvalue-row">
              <text class="ha-mnum">{{heartAgeSummary.restingHr}}</text>
              <text class="ha-munit">bpm</text>
              <text class="ha-mdelta down">↓ {{heartAgeSummary.hrDelta}}</text>
            </view>
          </view>
        </view>
      </view>

      <!-- 夜间平均心率 -->
      <view class="hc-card {{focusMetric === 'heartRate' ? 'focused' : ''}}">
        <view class="hc-head">
          <view class="hc-title-row">
            <text class="hc-title">夜间平均心率</text>
            <text class="hc-healthy">本周 {{heartRateHealthDays}} 天健康</text>
          </view>
          <view class="hc-toolbar">
            <view class="hc-tabs">
              <text class="hc-tab {{chartPeriods.heartRate === '7' ? 'active' : ''}}" bindtap="switchPeriod" data-chart="heartRate" data-period="7">周</text>
              <text class="hc-tab {{chartPeriods.heartRate === '30' ? 'active' : ''}}" bindtap="switchPeriod" data-chart="heartRate" data-period="30">月</text>
              <text class="hc-tab {{chartPeriods.heartRate === '90' ? 'active' : ''}}" bindtap="switchPeriod" data-chart="heartRate" data-period="90">全周期</text>
            </view>
            <view class="hc-nav">
              <text class="hc-nav-btn" bindtap="jumpToStart" data-chart="heartRate">«</text>
              <text class="hc-nav-btn" bindtap="panLeft" data-chart="heartRate">‹</text>
              <text class="hc-nav-btn" bindtap="panRight" data-chart="heartRate">›</text>
              <text class="hc-nav-btn" bindtap="jumpToEnd" data-chart="heartRate">»</text>
            </view>
          </view>
        </view>
        <view class="hc-canvas-wrap" bindtouchstart="onChartDragStart" bindtouchmove="onChartDragMove" bindtouchend="onChartDragEnd" data-chart="heartRate">
          <canvas type="2d" id="heartRateChart" class="hc-canvas" bindtap="onTapChartPoint" data-chart="heartRate"></canvas>
        </view>
        <view class="hc-legend">
          <view class="hc-legend-item"><view class="hc-dot green"></view><text>{{chartLegends.heartRate.h}}</text></view>
          <view class="hc-legend-item"><view class="hc-dot yellow"></view><text>{{chartLegends.heartRate.sh}}</text></view>
          <view class="hc-legend-item"><view class="hc-line dark"></view><text>{{chartLegends.heartRate.avg}}</text></view>
          <view class="hc-legend-item"><view class="hc-line gray"></view><text>{{chartLegends.heartRate.peer}}</text></view>
        </view>
        <view class="hc-summary">本周夜间平均心率整体平稳，多数处于健康区间。5/30 受多重因素影响短暂升高，建议保持规律作息，持续优化生活习惯。</view>
      </view>

      <!-- HRV心率变异性 -->
      <view class="hc-card {{focusMetric === 'hrv' ? 'focused' : ''}}">
        <view class="hc-head">
          <view class="hc-title-row">
            <text class="hc-title">HRV 心率变异性</text>
            <text class="hc-healthy">本周 {{hrvHealthDays}} 天健康</text>
          </view>
          <view class="hc-toolbar">
            <view class="hc-tabs">
              <text class="hc-tab {{chartPeriods.hrv === '7' ? 'active' : ''}}" bindtap="switchPeriod" data-chart="hrv" data-period="7">周</text>
              <text class="hc-tab {{chartPeriods.hrv === '30' ? 'active' : ''}}" bindtap="switchPeriod" data-chart="hrv" data-period="30">月</text>
              <text class="hc-tab {{chartPeriods.hrv === '90' ? 'active' : ''}}" bindtap="switchPeriod" data-chart="hrv" data-period="90">全周期</text>
            </view>
            <view class="hc-nav">
              <text class="hc-nav-btn" bindtap="jumpToStart" data-chart="hrv">«</text>
              <text class="hc-nav-btn" bindtap="panLeft" data-chart="hrv">‹</text>
              <text class="hc-nav-btn" bindtap="panRight" data-chart="hrv">›</text>
              <text class="hc-nav-btn" bindtap="jumpToEnd" data-chart="hrv">»</text>
            </view>
          </view>
        </view>
        <view class="hc-canvas-wrap" bindtouchstart="onChartDragStart" bindtouchmove="onChartDragMove" bindtouchend="onChartDragEnd" data-chart="hrv">
          <canvas type="2d" id="hrvChart" class="hc-canvas" bindtap="onTapChartPoint" data-chart="hrv"></canvas>
        </view>
        <view class="hc-legend">
          <view class="hc-legend-item"><view class="hc-dot green"></view><text>{{chartLegends.hrv.h}}</text></view>
          <view class="hc-legend-item"><view class="hc-dot yellow"></view><text>{{chartLegends.hrv.sh}}</text></view>
          <view class="hc-legend-item"><view class="hc-line dark"></view><text>{{chartLegends.hrv.avg}}</text></view>
          <view class="hc-legend-item"><view class="hc-line gray"></view><text>{{chartLegends.hrv.peer}}</text></view>
        </view>
        <view class="hc-summary">{{trendTexts.hrv[period]}}</view>
      </view>

      <!-- 心脏健康指数 -->
      <view class="hc-card {{focusMetric === 'heartIndex' ? 'focused' : ''}}">
        <view class="hc-head">
          <view class="hc-title-row">
            <text class="hc-title">心脏健康指数</text>
            <text class="hc-healthy">本周 6/7 天达标</text>
          </view>
          <view class="hc-toolbar">
            <view class="hc-tabs">
              <text class="hc-tab {{chartPeriods.heartIndex === '7' ? 'active' : ''}}" bindtap="switchPeriod" data-chart="heartIndex" data-period="7">周</text>
              <text class="hc-tab {{chartPeriods.heartIndex === '30' ? 'active' : ''}}" bindtap="switchPeriod" data-chart="heartIndex" data-period="30">月</text>
              <text class="hc-tab {{chartPeriods.heartIndex === '90' ? 'active' : ''}}" bindtap="switchPeriod" data-chart="heartIndex" data-period="90">全周期</text>
            </view>
            <view class="hc-nav">
              <text class="hc-nav-btn" bindtap="jumpToStart" data-chart="heartIndex">«</text>
              <text class="hc-nav-btn" bindtap="panLeft" data-chart="heartIndex">‹</text>
              <text class="hc-nav-btn" bindtap="panRight" data-chart="heartIndex">›</text>
              <text class="hc-nav-btn" bindtap="jumpToEnd" data-chart="heartIndex">»</text>
            </view>
          </view>
        </view>
        <view class="hc-canvas-wrap" bindtouchstart="onChartDragStart" bindtouchmove="onChartDragMove" bindtouchend="onChartDragEnd" data-chart="heartIndex">
          <canvas type="2d" id="heartIndexChart" class="hc-canvas" bindtap="onTapChartPoint" data-chart="heartIndex"></canvas>
        </view>
        <view class="hc-legend">
          <view class="hc-legend-item"><view class="hc-dot green"></view><text>{{chartLegends.heartIndex.h}}</text></view>
          <view class="hc-legend-item"><view class="hc-dot yellow"></view><text>{{chartLegends.heartIndex.sh}}</text></view>
          <view class="hc-legend-item"><view class="hc-line dark"></view><text>{{chartLegends.heartIndex.avg}}</text></view>
          <view class="hc-legend-item"><view class="hc-line gray"></view><text>{{chartLegends.heartIndex.peer}}</text></view>
        </view>
        <view class="hc-summary">{{trendTexts.heartIndex[period]}}</view>
      </view>
    </view>
  </view>

  <!-- ★ 2. 呼吸健康（默认展开） -->
  <view class="module-card {{expanded.breath ? 'expanded' : ''}}">
    <view class="module-header" bindtap="toggleModule" data-module="breath">
      <view class="module-icon-circle breath">🫁</view>
      <view class="module-info">
        <view class="module-title-row">
          <text class="module-title">呼吸健康</text>
          <text class="module-score-pill {{moduleSummaries.breath.statusKey}}">{{moduleSummaries.breath.score}} 分 · {{moduleSummaries.breath.status}}</text>
        </view>
        <view class="module-focus">{{moduleSummaries.breath.focus}}</view>
      </view>
      <view class="module-right">
        <text class="module-arrow-new">›</text>
      </view>
    </view>

    <view class="module-body" wx:if="{{expanded.breath}}">
      <!-- 平均夜间呼吸频率（升级为区间柱形图） -->
      <view class="hc-card {{focusMetric === 'breathRate' ? 'focused' : ''}}">
        <view class="hc-head">
          <view class="hc-title-row">
            <text class="hc-title">平均夜间呼吸频率</text>
            <text class="hc-healthy">本周 6/7 天健康</text>
          </view>
          <view class="hc-toolbar">
            <view class="hc-tabs">
              <text class="hc-tab {{chartPeriods.breathRate === '7' ? 'active' : ''}}" bindtap="switchPeriod" data-chart="breathRate" data-period="7">周</text>
              <text class="hc-tab {{chartPeriods.breathRate === '30' ? 'active' : ''}}" bindtap="switchPeriod" data-chart="breathRate" data-period="30">月</text>
              <text class="hc-tab {{chartPeriods.breathRate === '90' ? 'active' : ''}}" bindtap="switchPeriod" data-chart="breathRate" data-period="90">全周期</text>
            </view>
            <view class="hc-nav">
              <text class="hc-nav-btn" bindtap="jumpToStart" data-chart="breathRate">«</text>
              <text class="hc-nav-btn" bindtap="panLeft" data-chart="breathRate">‹</text>
              <text class="hc-nav-btn" bindtap="panRight" data-chart="breathRate">›</text>
              <text class="hc-nav-btn" bindtap="jumpToEnd" data-chart="breathRate">»</text>
            </view>
          </view>
        </view>
        <view class="hc-canvas-wrap" bindtouchstart="onChartDragStart" bindtouchmove="onChartDragMove" bindtouchend="onChartDragEnd" data-chart="breathRate">
          <canvas type="2d" id="breathRateChart" class="hc-canvas" bindtap="onTapChartPoint" data-chart="breathRate"></canvas>
        </view>
        <view class="hc-legend">
          <view class="hc-legend-item"><view class="hc-dot green"></view><text>{{chartLegends.breathRate.h}}</text></view>
          <view class="hc-legend-item"><view class="hc-dot yellow"></view><text>{{chartLegends.breathRate.sh}}</text></view>
          <view class="hc-legend-item"><view class="hc-line dark"></view><text>{{chartLegends.breathRate.avg}}</text></view>
          <view class="hc-legend-item"><view class="hc-line gray"></view><text>{{chartLegends.breathRate.peer}}</text></view>
        </view>
        <view class="hc-summary">本周呼吸频率维持在 11-18 次/分钟，14 天均值 14.5 次/分，整体处于健康成人区间</view>
      </view>

      <!-- AHI 呼吸暂停指数 -->
      <view class="hc-card {{focusMetric === 'ahi' ? 'focused' : ''}}">
        <view class="hc-head">
          <view class="hc-title-row">
            <text class="hc-title">AHI 呼吸暂停指数</text>
            <text class="hc-healthy">本周 5/7 天达标</text>
          </view>
          <view class="hc-toolbar">
            <view class="hc-tabs">
              <text class="hc-tab {{chartPeriods.ahi === '7' ? 'active' : ''}}" bindtap="switchPeriod" data-chart="ahi" data-period="7">周</text>
              <text class="hc-tab {{chartPeriods.ahi === '30' ? 'active' : ''}}" bindtap="switchPeriod" data-chart="ahi" data-period="30">月</text>
              <text class="hc-tab {{chartPeriods.ahi === '90' ? 'active' : ''}}" bindtap="switchPeriod" data-chart="ahi" data-period="90">全周期</text>
            </view>
            <view class="hc-nav">
              <text class="hc-nav-btn" bindtap="jumpToStart" data-chart="ahi">«</text>
              <text class="hc-nav-btn" bindtap="panLeft" data-chart="ahi">‹</text>
              <text class="hc-nav-btn" bindtap="panRight" data-chart="ahi">›</text>
              <text class="hc-nav-btn" bindtap="jumpToEnd" data-chart="ahi">»</text>
            </view>
          </view>
        </view>
        <view class="hc-canvas-wrap" bindtouchstart="onChartDragStart" bindtouchmove="onChartDragMove" bindtouchend="onChartDragEnd" data-chart="ahi">
          <canvas type="2d" id="ahiChart" class="hc-canvas" bindtap="onTapChartPoint" data-chart="ahi"></canvas>
        </view>
        <view class="hc-legend">
          <view class="hc-legend-item"><view class="hc-dot green"></view><text>{{chartLegends.ahi.h}}</text></view>
          <view class="hc-legend-item"><view class="hc-dot yellow"></view><text>{{chartLegends.ahi.sh}}</text></view>
          <view class="hc-legend-item"><view class="hc-line dark"></view><text>{{chartLegends.ahi.avg}}</text></view>
          <view class="hc-legend-item"><view class="hc-line gray"></view><text>{{chartLegends.ahi.peer}}</text></view>
        </view>
        <view class="hc-summary">{{trendTexts.ahi[period]}}</view>
      </view>

      <!-- 最长呼吸暂停时长 -->
      <view class="hc-card {{focusMetric === 'apnea' ? 'focused' : ''}}">
        <view class="hc-head">
          <view class="hc-title-row">
            <text class="hc-title">最长呼吸暂停时长</text>
            <text class="hc-healthy hc-healthy-warn">本周 4/7 天达标</text>
          </view>
          <view class="hc-toolbar">
            <view class="hc-tabs">
              <text class="hc-tab {{chartPeriods.apnea === '7' ? 'active' : ''}}" bindtap="switchPeriod" data-chart="apnea" data-period="7">周</text>
              <text class="hc-tab {{chartPeriods.apnea === '30' ? 'active' : ''}}" bindtap="switchPeriod" data-chart="apnea" data-period="30">月</text>
              <text class="hc-tab {{chartPeriods.apnea === '90' ? 'active' : ''}}" bindtap="switchPeriod" data-chart="apnea" data-period="90">全周期</text>
            </view>
            <view class="hc-nav">
              <text class="hc-nav-btn" bindtap="jumpToStart" data-chart="apnea">«</text>
              <text class="hc-nav-btn" bindtap="panLeft" data-chart="apnea">‹</text>
              <text class="hc-nav-btn" bindtap="panRight" data-chart="apnea">›</text>
              <text class="hc-nav-btn" bindtap="jumpToEnd" data-chart="apnea">»</text>
            </view>
          </view>
        </view>
        <view class="hc-canvas-wrap" bindtouchstart="onChartDragStart" bindtouchmove="onChartDragMove" bindtouchend="onChartDragEnd" data-chart="apnea">
          <canvas type="2d" id="apneaChart" class="hc-canvas" bindtap="onTapChartPoint" data-chart="apnea"></canvas>
        </view>
        <view class="hc-legend">
          <view class="hc-legend-item"><view class="hc-dot green"></view><text>{{chartLegends.apnea.h}}</text></view>
          <view class="hc-legend-item"><view class="hc-dot yellow"></view><text>{{chartLegends.apnea.sh}}</text></view>
          <view class="hc-legend-item"><view class="hc-line dark"></view><text>{{chartLegends.apnea.avg}}</text></view>
          <view class="hc-legend-item"><view class="hc-line gray"></view><text>{{chartLegends.apnea.peer}}</text></view>
        </view>
        <view class="hc-summary">{{trendTexts.apnea[period]}}</view>
      </view>
    </view>
  </view>

  <!-- ★ 3. 睡眠板块（默认折叠） -->
  <view class="module-card {{expanded.sleep ? 'expanded' : ''}}">
    <view class="module-header" bindtap="toggleModule" data-module="sleep">
      <view class="module-icon-circle sleep">🛏️</view>
      <view class="module-info">
        <view class="module-title-row">
          <text class="module-title">睡眠板块</text>
          <text class="module-score-pill {{moduleSummaries.sleep.statusKey}}">{{moduleSummaries.sleep.score}} 分 · {{moduleSummaries.sleep.status}}</text>
        </view>
        <view class="module-focus">{{moduleSummaries.sleep.focus}}</view>
      </view>
      <view class="module-right">
        <text class="module-arrow-new">›</text>
      </view>
    </view>

    <view class="module-body" wx:if="{{expanded.sleep}}">
      <!-- 0. 长期睡眠趋势 · 作息走势（柱形图） -->
      <view class="hc-card schedule-card">
        <view class="hc-head">
          <view class="hc-title-row">
            <text class="hc-title">长期睡眠趋势</text>
          </view>
          <view class="hc-toolbar">
            <view class="hc-tabs">
              <text class="hc-tab {{chartPeriods.schedule === '7' ? 'active' : ''}}" bindtap="switchPeriod" data-chart="schedule" data-period="7">周</text>
              <text class="hc-tab {{chartPeriods.schedule === '30' ? 'active' : ''}}" bindtap="switchPeriod" data-chart="schedule" data-period="30">月</text>
              <text class="hc-tab {{chartPeriods.schedule === '90' ? 'active' : ''}}" bindtap="switchPeriod" data-chart="schedule" data-period="90">全周期</text>
            </view>
            <view class="hc-nav">
              <text class="hc-nav-btn" bindtap="jumpToStart" data-chart="schedule">«</text>
              <text class="hc-nav-btn" bindtap="panLeft" data-chart="schedule">‹</text>
              <text class="hc-nav-btn" bindtap="panRight" data-chart="schedule">›</text>
              <text class="hc-nav-btn" bindtap="jumpToEnd" data-chart="schedule">»</text>
            </view>
          </view>
        </view>
        <view class="hc-canvas-wrap schedule-canvas-wrap" bindtouchstart="onChartDragStart" bindtouchmove="onChartDragMove" bindtouchend="onChartDragEnd" data-chart="schedule">
          <canvas type="2d" id="scheduleBarChart" class="hc-canvas" bindtap="onTapChartPoint" data-chart="schedule"></canvas>
        </view>

        <!-- 底部 KPI 与洞察 -->
        <view class="kpi-strip">
          <view class="kpi-item">
            <text class="kpi-label">平均上床</text>
            <text class="kpi-value">{{klineSummary.avgBed}}</text>
          </view>
          <view class="kpi-item">
            <text class="kpi-label">平均起床</text>
            <text class="kpi-value">{{klineSummary.avgWake}}</text>
          </view>
          <view class="kpi-item">
            <text class="kpi-label">健康窗口入睡</text>
            <text class="kpi-value">{{klineSummary.healthyBedRate}}%</text>
          </view>
          <view class="kpi-item">
            <text class="kpi-label">作息规律度</text>
